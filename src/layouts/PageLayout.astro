---
import Layout from "./Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  intro?: string;
}

const { title, description, eyebrow, heading, intro } = Astro.props;
---

<Layout title={title} description={description}>
  <Nav />
  <main class="relative pt-36 sm:pt-44 pb-24 sm:pb-32">
    <div class="mx-auto max-w-3xl px-6">
      <!-- Header -->
      <header class="mb-16">
        {eyebrow && (
          <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
            {eyebrow}
          </p>
        )}
        <h1 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
          <span class="text-gradient-ink">{heading}</span>
        </h1>
        {intro && (
          <p class="mt-8 text-lg text-ink-700 leading-relaxed max-w-2xl">
            {intro}
          </p>
        )}
      </header>

      <!-- Content -->
      <article class="prose-content space-y-7 text-[16px] text-ink-700 leading-relaxed">
        <slot />
      </article>

      <!-- Back link -->
      <div class="mt-20 pt-8 border-t border-ink-900/8">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm text-ink-700 hover:text-ink-900 transition-colors group"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:-translate-x-0.5" aria-hidden="true">
            <path d="M9 6H3m0 0l3.5-3.5M3 6l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Back to home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .prose-content h2 {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    line-height: 1.2;
    font-weight: 500;
    color: var(--color-ink-900);
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-content h2:first-child {
    margin-top: 0;
  }
  .prose-content h3 {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.3;
    font-weight: 500;
    color: var(--color-ink-900);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-content p {
    margin-bottom: 1rem;
  }
  .prose-content ul {
    list-style: none;
    padding: 0;
    margin-bottom: 1rem;
  }
  .prose-content ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .prose-content ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: var(--color-accent);
  }
  .prose-content a {
    color: var(--color-accent-deep);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }
  .prose-content a:hover {
    color: var(--color-accent);
  }
  .prose-content strong {
    color: var(--color-ink-900);
    font-weight: 600;
  }
</style>
