---
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  heading: string;
  italic?: string;
  lead?: string;
  byline?: string;
  noindex?: boolean;
  showNewsletter?: boolean;
}

const { title, description, eyebrow, heading, italic, lead, byline, noindex = false, showNewsletter = true } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={noindex} showNewsletter={showNewsletter}>
  <header class="relative pt-32 sm:pt-40 pb-16 sm:pb-20 border-b border-ink/8">
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div
        class="absolute top-1/3 right-[10%] h-[40vh] w-[40vh] rounded-full opacity-30 blur-[120px]"
        style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
      ></div>
    </div>
    <div class="mx-auto max-w-6xl px-6">
      {eyebrow && <p class="reveal eyebrow mb-6">{eyebrow}</p>}
      <h1 class="reveal display-lg max-w-4xl">
        {heading}
        {italic && <> <span class="italic-grad">{italic}</span></>}
      </h1>
      {lead && <p class="reveal serif-lg text-ink-soft mt-7 max-w-prose">{lead}</p>}
      {byline && (
        <p class="reveal byline text-ink-mute mt-10 pt-6 border-t border-ink/8 max-w-3xl">
          {byline}
        </p>
      )}
    </div>
  </header>

  <article class="py-16 sm:py-20">
    <slot />
  </article>
</BaseLayout>
