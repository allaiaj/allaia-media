---
import "../styles/global.css";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} - ${site.tagline}`,
  description = site.description,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#faf9f6" />
    <meta name="color-scheme" content="light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: site.name,
        url: `https://www.${site.domain}`,
        description: site.description,
        areaServed: site.markets,
        sameAs: [site.instagram],
      })}
    />
  </head>
  <body class="relative min-h-screen text-ink-900 antialiased" style="background: linear-gradient(180deg, #faf9f6 0%, #f8f3fd 30%, #fdf3f8 60%, #f7f4ee 100%);">
    <!-- Vibrant mesh aurora -->
    <div
      class="pointer-events-none fixed inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <!-- Violet -->
      <div
        class="absolute -top-32 -left-40 h-[75vh] w-[75vh] rounded-full opacity-70 blur-[110px]"
        style="background: radial-gradient(circle, rgba(167,139,250,0.85) 0%, rgba(167,139,250,0.3) 40%, transparent 70%); animation: var(--animate-aurora);"
      >
      </div>
      <!-- Pink -->
      <div
        class="absolute top-1/4 -right-40 h-[70vh] w-[70vh] rounded-full opacity-65 blur-[110px]"
        style="background: radial-gradient(circle, rgba(251,182,206,0.9) 0%, rgba(251,182,206,0.3) 40%, transparent 70%); animation: var(--animate-aurora); animation-delay: -5s;"
      >
      </div>
      <!-- Peach -->
      <div
        class="absolute top-1/2 left-1/3 h-[60vh] w-[60vh] rounded-full opacity-60 blur-[110px]"
        style="background: radial-gradient(circle, rgba(254,205,170,0.9) 0%, rgba(254,205,170,0.3) 40%, transparent 70%); animation: var(--animate-aurora); animation-delay: -10s;"
      >
      </div>
      <!-- Mint -->
      <div
        class="absolute bottom-1/4 -left-32 h-[55vh] w-[55vh] rounded-full opacity-50 blur-[110px]"
        style="background: radial-gradient(circle, rgba(167,243,208,0.7) 0%, rgba(167,243,208,0.2) 40%, transparent 70%); animation: var(--animate-aurora); animation-delay: -15s;"
      >
      </div>
      <!-- Sky -->
      <div
        class="absolute bottom-0 right-1/4 h-[65vh] w-[65vh] rounded-full opacity-55 blur-[110px]"
        style="background: radial-gradient(circle, rgba(186,213,250,0.8) 0%, rgba(186,213,250,0.25) 40%, transparent 70%); animation: var(--animate-aurora); animation-delay: -20s;"
      >
      </div>

      <!-- Brightening wash on top so text stays readable -->
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 100% 60% at 50% 50%, rgba(255,255,255,0.35) 0%, transparent 70%);"
      ></div>

      <!-- Subtle grid texture -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgb(14 13 10 / 0.5) 1px, transparent 1px), linear-gradient(90deg, rgb(14 13 10 / 0.5) 1px, transparent 1px); background-size: 64px 64px;"
      >
      </div>

      <!-- Subtle film grain for organic feel -->
      <div
        class="absolute inset-0 opacity-[0.025] mix-blend-overlay"
        style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
      ></div>
    </div>

    <slot />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => io.observe(el));
    </script>
  </body>
</html>
