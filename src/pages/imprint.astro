---
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@data/site';
---

<PageLayout
  title="Imprint"
  description="Imprint and legal information for ALLAIA Media."
  eyebrow="Legal · Impressum"
  heading="Imprint."
  italic=""
  lead="Operational entity behind allaiamedia.com, Allaia Power, the book Become Her, The Architecture coaching room, and Coven (community)."
  byline={`Contact — ${site.email}`}
>
  <div class="mx-auto max-w-prose px-6 prose-essay">
    <h2>Operator</h2>
    <p>
      ALLAIA Media<br/>
      Operating mainly between Dubai and Bali.<br/>
      Email — <a href={`mailto:${site.email}`}>{site.email}</a><br/>
      Web — <a href={site.url}>{site.url.replace('https://', '')}</a>
    </p>

    <h2>Founder + represented person</h2>
    <p>
      Luise Allaiaj Ramiscal (publishing as Allaia)<br/>
      Author, COO at Blacklyne AI, artist at @allaia.art.
    </p>

    <h2>Responsible for content</h2>
    <p>
      Luise Allaiaj Ramiscal — content responsibility per applicable press-law in the EU, UK, and AE jurisdictions where this site is published.
    </p>

    <h2>Design + build</h2>
    <p>
      Designed and built by <a href={site.blacklyne} target="_blank" rel="noopener">Blacklyne</a>, the studio Allaia operates as COO. Allaia Media is a separate operational entity.
    </p>

    <h2>Liability</h2>
    <p>
      External links are provided for reference. We do not assume responsibility for the content of third-party sites linked from allaiamedia.com.
    </p>
  </div>
</PageLayout>
