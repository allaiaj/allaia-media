---
// The Studio — editorial cover for Blacklyne. Focus is the studio,
// not the person; CTAs route to blacklyne.ai everywhere. Pops the
// Blacklyne preview modal on every visit.
import BaseLayout from '@layouts/BaseLayout.astro';
import StudioModal from '@components/StudioModal.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<BaseLayout
  title="The Studio — Blacklyne"
  description="Blacklyne — premium digital presence and AI search optimisation. Be seen. Be named. Be chosen. Across Berlin, Dubai, and New York."
>
  <!-- ====================================================================
       HERO — editorial split: copy + Blacklyne preview (no portrait)
  ==================================================================== -->
  <section class="studio-hero relative overflow-hidden">
    <!-- Atmospheric warmth -->
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div
        class="absolute top-0 right-0 h-[80vh] w-[80vh] rounded-full opacity-32 blur-[180px]"
        style="background: radial-gradient(circle, rgba(184,85,66,0.55), transparent 70%);"
      ></div>
      <div
        class="absolute bottom-0 left-0 h-[70vh] w-[70vh] rounded-full opacity-28 blur-[160px]"
        style="background: radial-gradient(circle, rgba(139,157,126,0.5), transparent 70%);"
      ></div>
    </div>

    <div class="mx-auto max-w-[1380px] px-6 lg:px-10 pt-32 sm:pt-40 pb-16 sm:pb-20">
      <!-- Masthead row -->
      <div class="reveal flex items-center justify-between gap-6 mb-12 sm:mb-16 pb-6 border-b border-ink/10">
        <p class="font-display italic text-base sm:text-lg text-ink-soft">
          The Studio · <span class="text-ink">blacklyne</span>
        </p>
        <p class="hidden sm:block byline text-ink-mute tabular-nums tracking-wider">
          Issue 01 · 2026
        </p>
        <a href={site.blacklyne} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial whitespace-nowrap inline-flex items-center gap-1.5">
          Visit blacklyne.ai <ArrowUpRight size={11} />
        </a>
      </div>

      <!-- Editorial split: copy + studio preview -->
      <div class="grid lg:grid-cols-[7fr_5fr] gap-12 lg:gap-16 items-center">
        <!-- LEFT — copy -->
        <div class="reveal order-2 lg:order-1">
          <div class="flex items-center gap-3 mb-7">
            <span class="h-1.5 w-1.5 rounded-full bg-terracotta studio-pulse"></span>
            <p class="text-[0.6875rem] uppercase tracking-[0.32em] text-terracotta-deep font-medium">
              The studio · live
            </p>
          </div>

          <h1
            class="font-display leading-[0.92] text-ink mb-9"
            style="font-size: clamp(3rem, 8vw, 7.5rem); letter-spacing: -0.035em;"
          >
            <span class="block">Be seen.</span>
            <span class="block">Be named.</span>
            <span class="block italic-grad">Be chosen.</span>
          </h1>

          <p class="font-display italic text-[clamp(1.5rem,2.4vw,2rem)] text-brown leading-[1.22] mb-7 max-w-2xl">
            Blacklyne builds the authority that makes a brand the obvious choice — across every surface the market sees you.
          </p>
          <p class="serif-lg text-ink-soft mb-9 max-w-prose">
            Websites that close. AI search so the brand is the one ChatGPT names. A careers funnel that brings in the people you actually want. One brand a week — since 2024.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href={site.blacklyne} target="_blank" rel="noopener" class="cta-dark">
              Visit Blacklyne <ArrowUpRight size={12} />
            </a>
            <a href={`${site.blacklyne}/#contact`} target="_blank" rel="noopener" class="cta-ghost">
              Brief the studio <ArrowUpRight size={12} />
            </a>
          </div>
        </div>

        <!-- RIGHT — Blacklyne preview (replaces the portrait) -->
        <a
          href={site.blacklyne}
          target="_blank"
          rel="noopener"
          class="reveal order-1 lg:order-2 group block"
          aria-label="Visit blacklyne.ai"
        >
          <figure class="hero-preview relative">
            <!-- Browser-window frame -->
            <div class="relative rounded-[1.25rem] overflow-hidden bg-anthracite shadow-photo border border-ink/10">
              <div class="flex items-center gap-2 px-4 py-3 bg-anthracite-warm border-b border-cream/8">
                <span class="flex gap-1.5" aria-hidden="true">
                  <span class="h-2.5 w-2.5 rounded-full bg-cream/20"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-cream/20"></span>
                  <span class="h-2.5 w-2.5 rounded-full bg-cream/20"></span>
                </span>
                <span class="ml-3 flex-1 px-3 py-1 rounded-full bg-cream/10 text-[0.625rem] tracking-[0.08em] text-cream/70 truncate">
                  blacklyne.ai/en
                </span>
                <span class="inline-flex items-center gap-1.5 text-[0.6875rem] uppercase tracking-[0.18em] text-cream/70">
                  Live <span class="h-1.5 w-1.5 rounded-full bg-terracotta studio-pulse"></span>
                </span>
              </div>
              <div class="relative aspect-[16/11] overflow-hidden">
                <img
                  src="/img/studio/blacklyne-preview.jpg"
                  alt="Blacklyne — premium digital presence + AI search optimisation"
                  loading="eager"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1400ms] ease-editorial group-hover:scale-[1.025]"
                />
                <span
                  class="absolute inset-x-0 bottom-0 px-5 py-3 flex items-center justify-between text-[0.6875rem] uppercase tracking-[0.16em] text-cream/90 transition-transform duration-500 ease-editorial group-hover:-translate-y-1"
                  style="background: linear-gradient(to top, rgba(14,13,11,0.9), transparent);"
                >
                  <span>Tap to open</span>
                  <span class="inline-flex items-center gap-1.5">blacklyne.ai <ArrowUpRight size={11} /></span>
                </span>
              </div>
            </div>
            <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
              <span class="uppercase tracking-[0.22em] text-[0.625rem]">The studio</span>
              <span>FIG. 01</span>
            </figcaption>
          </figure>
        </a>
      </div>

      <!-- Receipts mast row -->
      <div class="reveal mt-16 sm:mt-20 pt-10 border-t border-ink/10">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 sm:gap-10">
          {[
            { v: '162', l: 'Live sites · see them on blacklyne.ai' },
            { v: '4.8 / 5', l: 'Trustpilot · 160+ businesses' },
            { v: '1 / week', l: 'Cadence, since 2024' },
            { v: '3', l: 'Berlin · Dubai · New York' },
          ].map((m) => (
            <div>
              <p class="font-display italic text-[clamp(2rem,3.4vw,3rem)] text-terracotta leading-none mb-2">
                {m.v}
              </p>
              <p class="byline text-ink-mute">{m.l}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       SERVICES — each with its own blacklyne CTA
  ==================================================================== -->
  <section class="relative py-28 sm:py-36 overflow-hidden">
    <div class="mx-auto max-w-6xl px-6 mb-14 sm:mb-20">
      <div class="reveal pb-6 border-b border-ink/10">
        <p class="eyebrow mb-5">What the studio builds</p>
        <h2 class="display-md max-w-3xl">
          Three surfaces. <span class="italic-grad">One outcome.</span>
        </h2>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-6 space-y-7 sm:space-y-10">
      {[
        {
          n: '01',
          eyebrow: 'Webdesign',
          tagline: 'The site that closes for you.',
          body: 'Custom-engineered, never templated. Built so a high-value customer commits in the first five seconds — and the site loads under 0.7 seconds doing it. Mobile-first, designed in the editorial register the brand actually deserves.',
          metric: '162 live sites',
          metricLabel: 'Shipped to date',
          ctaLabel: 'See live builds on blacklyne.ai',
          ctaHref: `${site.blacklyne}/#work`,
        },
        {
          n: '02',
          eyebrow: 'AI search',
          tagline: 'The brand the AI recommends.',
          body: 'Structured for ChatGPT, Perplexity, and Google to name you out loud. Schema, llms.txt, Google Business + Maps maintained the way Yelp pages used to be. Answer-engine optimisation built into every surface — so when the prompt is asked, you are the answer.',
          metric: '+47%',
          metricLabel: 'Inquiries in 90 days',
          ctaLabel: 'Read the AI search playbook on blacklyne.ai',
          ctaHref: `${site.blacklyne}/#ai-search`,
        },
        {
          n: '03',
          eyebrow: 'Talent branding',
          tagline: 'The people you actually want.',
          body: 'A careers page that reads like the rest of the brand. Recruitment ads that hit the right candidates, not the cheapest ones. An application funnel built to filter for fit before the first call.',
          metric: '3.4×',
          metricLabel: 'Applications, vs baseline',
          ctaLabel: 'View talent branding on blacklyne.ai',
          ctaHref: `${site.blacklyne}/#talent`,
        },
      ].map((s) => (
        <article class="reveal group">
          <div class="grid lg:grid-cols-[1fr_2fr] gap-6 lg:gap-12 p-7 sm:p-9 lg:p-11 rounded-[1.5rem] border border-ink/10 bg-bone hover:border-ink/20 transition-colors duration-500 ease-editorial">
            <div>
              <p class="font-mono text-[11px] tracking-[0.22em] text-ink-mute mb-4">{s.n} · {s.eyebrow}</p>
              <h3 class="font-display italic text-[clamp(1.875rem,3vw,2.625rem)] leading-[1.04] mb-7 max-w-md">
                <span class="italic-grad">{s.tagline}</span>
              </h3>
              <div class="flex items-baseline gap-3 pt-5 border-t border-ink/10">
                <p class="font-display italic text-3xl text-terracotta">{s.metric}</p>
                <p class="byline text-ink-mute">{s.metricLabel}</p>
              </div>
            </div>
            <div class="lg:pl-8 lg:border-l border-ink/10 flex flex-col">
              <p class="serif-lg text-ink-soft max-w-prose mb-7">{s.body}</p>
              <a
                href={s.ctaHref}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-1.5 text-ink hover:text-terracotta transition-colors duration-300 ease-editorial mt-auto self-start byline border-b border-ink/30 hover:border-terracotta pb-1"
              >
                <span class="font-medium">{s.ctaLabel}</span> <ArrowUpRight size={11} />
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ====================================================================
       FULL-WIDTH BLACKLYNE SHOWCASE — second prominent CTA
  ==================================================================== -->
  <section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 0%, rgba(184,85,66,0.06) 50%, transparent 100%);"></div>
    </div>

    <div class="mx-auto max-w-6xl px-6">
      <div class="reveal text-center mb-12 sm:mb-16">
        <p class="eyebrow mb-5">Look at the work</p>
        <h2 class="display-md max-w-3xl mx-auto">
          The studio, <span class="italic-grad">live.</span>
        </h2>
      </div>

      <a
        href={site.blacklyne}
        target="_blank"
        rel="noopener"
        class="reveal block group rounded-[1.75rem] overflow-hidden border border-ink/10 shadow-photo hover:border-ink/20 transition-all duration-500 ease-editorial"
        aria-label="Open blacklyne.ai"
      >
        <div class="relative aspect-[16/9] sm:aspect-[16/8] overflow-hidden bg-anthracite">
          <img
            src="/img/studio/blacklyne-preview.jpg"
            alt="Blacklyne homepage — premium digital presence + AI search optimisation"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[1400ms] ease-editorial group-hover:scale-[1.03]"
          />
          <!-- Editorial overlay -->
          <div
            class="absolute inset-0 flex items-end p-7 sm:p-12 lg:p-16 text-cream"
            style="background: linear-gradient(180deg, transparent 30%, rgba(14,13,11,0.85) 100%);"
          >
            <div class="w-full flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
              <div>
                <p class="text-[0.625rem] uppercase tracking-[0.32em] text-cream/60 mb-3">
                  blacklyne.ai/en
                </p>
                <p class="font-display italic text-[clamp(1.5rem,3vw,2.5rem)] leading-[1.04] max-w-md">
                  See the live studio — 162 sites in.
                </p>
              </div>
              <span class="inline-flex items-center gap-2 px-5 py-3 rounded-full bg-cream text-ink text-sm font-medium whitespace-nowrap group-hover:-translate-y-1 transition-transform duration-500 ease-editorial">
                Open blacklyne.ai <ArrowUpRight size={12} />
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ====================================================================
       PRINCIPLE PULL
  ==================================================================== -->
  <section class="relative py-24 sm:py-32 overflow-hidden">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <p class="reveal pullquote italic-grad max-w-3xl mx-auto">
        "You do not have to take our word for it — that is exactly why we build first."
      </p>
      <p class="reveal byline text-ink-mute mt-5 mb-9">— the studio principle</p>
      <a
        href={site.blacklyne}
        target="_blank"
        rel="noopener"
        class="reveal cta-ghost"
      >
        See 162 live builds <ArrowUpRight size={12} />
      </a>
    </div>
  </section>

  <!-- ====================================================================
       THE DOOR
  ==================================================================== -->
  <section class="relative py-28 sm:py-36 overflow-hidden">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <p class="reveal eyebrow mb-5">When you are ready</p>
      <h2 class="reveal display-md mb-7">
        The studio's <span class="italic-grad">door.</span>
      </h2>
      <p class="reveal serif-lg text-ink-soft mb-10 max-w-2xl mx-auto">
        If you need the build — the website, the AI presence, the careers funnel, or all three — the brief form is on blacklyne.ai. One brand a week. We take the next available slot.
      </p>
      <div class="reveal flex flex-col sm:flex-row gap-3 justify-center">
        <a href={site.blacklyne} target="_blank" rel="noopener" class="cta-dark">
          Open blacklyne.ai <ArrowUpRight size={12} />
        </a>
        <a href={`${site.blacklyne}/#contact`} target="_blank" rel="noopener" class="cta-ghost">
          Brief the studio <ArrowUpRight size={12} />
        </a>
      </div>
    </div>
  </section>

  <!-- Persistent floating CTA — sticks to the corner past the hero -->
  <a
    href={site.blacklyne}
    target="_blank"
    rel="noopener"
    class="studio-floating-cta fixed z-[60] bottom-5 right-5 sm:bottom-7 sm:right-7 inline-flex items-center gap-2 pl-5 pr-4 py-3 rounded-full bg-ink text-cream text-sm font-medium shadow-anthracite hover:bg-anthracite hover:-translate-y-0.5 transition-all duration-300 ease-editorial"
    data-studio-floating-cta
    aria-label="Visit blacklyne.ai"
  >
    <span class="h-1.5 w-1.5 rounded-full bg-terracotta studio-pulse"></span>
    <span>Visit blacklyne.ai</span>
    <ArrowUpRight size={12} />
  </a>

  <StudioModal />
</BaseLayout>

<style>
  /* Subtle ken-burns on the preview screenshot until tap */
  .hero-preview img {
    will-change: transform;
  }
  .studio-pulse { animation: studio-pulse 2.4s ease-in-out infinite; }
  @keyframes studio-pulse {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50%      { transform: scale(1.6); opacity: 1; }
  }
  /* Floating CTA fades in once user scrolls past the hero */
  .studio-floating-cta {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 320ms cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 320ms cubic-bezier(0.22, 0.61, 0.36, 1),
                background-color 300ms ease;
  }
  .studio-floating-cta.is-visible {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .studio-pulse { animation: none !important; }
  }
</style>

<script>
  // Reveal the floating CTA once the user scrolls roughly past the hero.
  // Stays visible for the rest of the page; hides again when a modal opens.
  const cta = document.querySelector<HTMLElement>('[data-studio-floating-cta]');
  if (cta) {
    const threshold = () => Math.max(window.innerHeight * 0.6, 400);
    const onScroll = () => {
      if (window.scrollY > threshold()) cta.classList.add('is-visible');
      else cta.classList.remove('is-visible');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
