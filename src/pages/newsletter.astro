---
import PageLayout from '@layouts/PageLayout.astro';
import { newsletter } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<PageLayout
  title="The newsletter"
  description="Slow writing in your inbox. No funnels."
  eyebrow={newsletter.eyebrow}
  heading={newsletter.heading.pre}
  italic={newsletter.heading.italic}
  lead={newsletter.body}
  byline="One entry every other Sunday · no funnels · unsubscribe in one click"
>
  <div class="mx-auto max-w-2xl px-6">
    <form action="https://allaia.beehiiv.com/subscribe" method="post" class="reveal flex flex-col sm:flex-row gap-3 mb-12">
      <label class="flex-1">
        <span class="sr-only">Email address</span>
        <input
          type="email"
          name="email"
          required
          placeholder="your email address"
          class="w-full px-5 py-4 rounded-full bg-cream border border-ink/12 text-ink placeholder:text-ink-mute focus:border-terracotta focus:outline-none transition-colors duration-300 ease-editorial font-serif text-[1.05rem]"
        />
      </label>
      <button type="submit" class="cta-dark whitespace-nowrap !py-4 !px-6">
        Subscribe <ArrowUpRight size={12} />
      </button>
    </form>

    <section class="reveal pt-12 border-t border-ink/10">
      <p class="eyebrow mb-5">What lands in your inbox</p>
      <ul class="space-y-5">
        {[
          { title: 'A new essay', body: 'One short entry every other Sunday. Written, not livestreamed.' },
          { title: 'Reading lists', body: 'Books, essays, and the occasional album that informed the work.' },
          { title: 'Quiet notes from the studio', body: 'When a new piece of The Rupture is finished, or when a chapter of the book is ready to share early.' },
          { title: 'Pre-launches', body: 'The Architecture cohort dates and Coven onboarding windows land in inbox first, never on Instagram first.' },
        ].map((s) => (
          <li class="flex flex-col sm:flex-row gap-4 pb-5 border-b border-ink/8 last:border-b-0">
            <span class="font-display italic text-xl text-terracotta sm:w-48 flex-none">{s.title}</span>
            <p class="serif-body text-ink-soft">{s.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </div>
</PageLayout>
