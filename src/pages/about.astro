---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import About from "../components/About.astro";
import Process from "../components/Process.astro";
import CTA from "../components/CTA.astro";
import { site } from "../data/site";
---

<Layout
  title="About - Allaia Media"
  description="One operator per account. Month-to-month, no contracts longer than three months. The reason we built Allaia the way we did."
>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-36 sm:pt-44 pb-12 sm:pb-20">
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <div
          class="absolute left-1/2 top-1/3 h-[70vh] w-[70vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-[100px]"
          style="background: radial-gradient(circle, rgba(167,139,250,0.4) 0%, transparent 60%);"
        ></div>
      </div>
      <div class="mx-auto max-w-4xl px-6">
        <p class="reveal mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500 text-center">
          About · why we exist
        </p>
        <h1 class="reveal display-tight mx-auto max-w-3xl text-center text-[clamp(2.75rem,9vw,7.5rem)] font-medium">
          <span class="text-gradient-ink">The opposite of</span><br />
          <span class="font-serif italic text-gradient-violet">a normal agency.</span>
        </h1>
        <p class="reveal mt-10 mx-auto max-w-2xl text-center text-base sm:text-lg text-ink-700 leading-relaxed">
          We started Allaia because we watched too many great founders pay too much money for accounts they could not justify - and get told they needed a longer contract to "see results." This is the opposite of that.
        </p>
      </div>
    </section>

    <!-- Pillars -->
    <section class="relative py-12 sm:py-16">
      <div class="mx-auto max-w-5xl px-6">
        <div class="grid sm:grid-cols-3 gap-4 sm:gap-5">
          {[
            {
              n: "01",
              title: "One operator",
              body: "Each account has a single point of contact, not a team you cycle through. Reply times in hours, not days.",
            },
            {
              n: "02",
              title: "AI for leverage, humans for taste",
              body: "We use AI for production - copy variants, audience research, content calendars. We keep humans on the strategy, judgement, and final calls.",
            },
            {
              n: "03",
              title: "Honest pricing",
              body: "Month-to-month on everything except Meta Ads (3-month minimum so data compounds). Cancel any time. No upsell pressure.",
            },
          ].map((p) => (
            <article class="reveal surface rounded-3xl p-7">
              <span class="font-mono text-xs text-ink-500 tracking-wider">{p.n}</span>
              <h3 class="mt-6 text-xl font-medium text-ink-900 tracking-tight">{p.title}</h3>
              <p class="mt-3 text-[15px] text-ink-700 leading-relaxed">{p.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Reuse About section narrative -->
    <About />

    <!-- Process detail -->
    <Process />

    <!-- Closing CTA -->
    <CTA />
  </main>
  <Footer />
</Layout>
