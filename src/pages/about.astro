---
import PageLayout from '@layouts/PageLayout.astro';
import YouTubeModal from '@components/YouTubeModal.astro';
import { getCollection } from 'astro:content';
import { site, identities } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const chapters = (await getCollection('biographyChapters')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<PageLayout
  title="About"
  description="Allaia — author of Become Her, COO at Blacklyne, artist at @allaia.art. The long letter."
  eyebrow="The long letter"
  heading="A short biography of"
  italic="a woman who didn't wait."
  lead="Five chapters. One thesis — what compounds is identity. Performance does not."
  byline="By Allaia"
>
  <div class="mx-auto max-w-6xl px-6">
    <!-- Opening editorial split -->
    <div class="grid lg:grid-cols-[1fr_1.15fr] gap-12 lg:gap-20 mb-20 sm:mb-28">
      <figure class="reveal lg:sticky lg:top-32">
        <div class="relative aspect-[4/5] rounded-[1.75rem] overflow-hidden bg-bone paper-grain shadow-photo">
          <img
            src="/img/allaia/avatar.jpg"
            alt="Allaia"
            class="w-full h-full object-cover photo-warm"
            loading="lazy"
            onerror="this.style.display='none'"
          />
          <div
            class="absolute inset-0 -z-10"
            style="background: linear-gradient(160deg, #B85542 0%, #6B4F3D 50%, #1A1A1A 100%);"
            aria-hidden="true"
          ></div>
        </div>
        <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
          <span class="uppercase tracking-[0.22em] text-[0.625rem]">Allaia</span>
          <span>FIG. 05</span>
        </figcaption>
      </figure>

      <div class="reveal">
        <p class="font-display italic text-[clamp(1.75rem,3.5vw,2.5rem)] text-ink leading-[1.18] mb-7">
          Author. Operator. Artist.
        </p>
        <p class="serif-lg text-ink-soft mb-6 max-w-prose">
          A book. A studio that ships at scale. A canvas practice that runs alongside the writing. A private practice kept curated — on purpose.
        </p>
        <p class="serif-body text-ink-soft mb-6 max-w-prose">
          The four are not separate expressions of a brand. They are the same thesis worn four different ways — what compounds is identity. Performance does not.
        </p>
        <p class="serif-body text-ink-soft max-w-prose">
          What follows is the long letter, in five chapters. The short version is on the cover. The full version is in the book.
        </p>
      </div>
    </div>

    <!-- Biographical chapters -->
    <ol class="relative space-y-16 sm:space-y-20 max-w-3xl mx-auto">
      <span
        class="pointer-events-none absolute left-[1.75rem] top-2 bottom-2 w-px hidden md:block"
        style="background: linear-gradient(180deg, transparent, var(--color-terracotta) 10%, var(--color-terracotta-deep) 50%, var(--color-brown) 90%, transparent);"
        aria-hidden="true"
      ></span>
      {chapters.map((c, i) => (
        <li class="reveal grid md:grid-cols-[3.5rem_1fr] gap-6 md:gap-10">
          <div>
            <span class="font-display italic text-4xl sm:text-5xl text-terracotta leading-none block" aria-hidden="true">
              {c.data.chapter}
            </span>
            <p class="hidden md:block mt-3 byline text-ink-mute">
              Ch. {String(i + 1).padStart(2, '0')}
            </p>
          </div>
          <div>
            <div class="flex items-baseline gap-3 mb-4">
              <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink">{c.data.year}</span>
              <span class="h-px flex-1 bg-ink/15"></span>
              <span class="byline text-ink-mute">{c.data.label}</span>
            </div>
            <h3 class="display-sm text-ink mb-4">
              {c.data.title}
            </h3>
            <p class="serif-body text-ink-soft max-w-prose">
              {c.data.body}
            </p>
          </div>
        </li>
      ))}
    </ol>

    <!-- Four identities mini grid -->
    <div class="mt-24 sm:mt-32 pt-16 sm:pt-20 border-t border-ink/10">
      <p class="reveal eyebrow mb-5">The four identities — at a glance</p>
      <h2 class="reveal display-md mb-12 sm:mb-16">
        One woman. <span class="italic-grad">Four expressions.</span>
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-7">
        {identities.map((id, i) => (
          <a href={id.href} target={id.href.startsWith('http') ? '_blank' : undefined} rel={id.href.startsWith('http') ? 'noopener' : undefined} class="reveal group" style={`transition-delay: ${i * 50}ms`}>
            <p class="micro tracking-[0.22em] uppercase text-ink-mute mb-3">{id.context}</p>
            <h3 class="font-display text-2xl text-ink mb-3 group-hover:text-terracotta-deep transition-colors duration-300 ease-editorial">
              {id.label}.
            </h3>
            <p class="serif-body text-ink-soft mb-4">{id.body}</p>
            <span class="inline-flex items-center gap-2 byline text-ink group-hover:gap-3 transition-all duration-300 ease-editorial">
              {id.cta} <ArrowUpRight size={11} />
            </span>
          </a>
        ))}
      </div>
    </div>

    <!-- Closing -->
    <aside class="reveal mt-24 sm:mt-32 max-w-3xl mx-auto text-center">
      <p class="pullquote italic-grad max-w-2xl mx-auto">
        "Five chapters in, the only thing I know for sure is that you keep the next page open."
      </p>
      <p class="byline text-ink-mute mt-6">— Allaia</p>
      <div class="mt-12 flex flex-col sm:flex-row gap-3 justify-center">
        <a href={site.stan.book} target="_blank" rel="noopener" class="cta-dark">
          Read Become Her <ArrowUpRight size={12} />
        </a>
        <a href={site.stan.application} class="cta-ghost">
          Apply for The Architecture <ArrowUpRight size={12} />
        </a>
      </div>
    </aside>
  </div>

  <YouTubeModal />
</PageLayout>
