---
import PageLayout from '@layouts/PageLayout.astro';
import PressFeatures from '@components/sections/PressFeatures.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import Instagram from '@components/icons/Instagram.astro';
---

<PageLayout
  title="Press"
  description="Press features, interviews and podcast appearances featuring Allaia — author, operator, and COO at Blacklyne. To invite her on, the contact details are below."
  eyebrow="Press · features and interviews"
  heading="On the"
  italic="record."
  lead="Features, interviews, and podcast appearances. If you write for a publication, host a podcast, are putting together a profile, or want me on a panel — the door is open below."
  byline="To invite Allaia on · DM @allaia.power or email allaiaj.luise@gmail.com"
>
  <PressFeatures />

  <section class="mx-auto max-w-3xl px-6 pt-8 pb-20 sm:pb-28">
    <div class="reveal pt-12 border-t border-ink/10">
      <p class="eyebrow mb-5">To invite me on</p>
      <h2 class="display-sm mb-6">
        Interviews. Podcasts. <span class="italic-grad">Profiles.</span>
      </h2>
      <p class="serif-lg text-ink-soft mb-5 max-w-prose">
        If you are a journalist, podcast host, editor, or producer — write to me directly. The fastest way is a DM on Instagram; email also works.
      </p>
      <p class="serif-body text-ink-soft mb-9 max-w-prose">
        A line about the publication or show, a sense of the angle, and a rough timeline is enough to start the conversation. I read every inquiry personally and reply within a day.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark">
          <Instagram size={13} /> DM @allaia.power <ArrowUpRight size={12} />
        </a>
        <a href={`mailto:${site.email}?subject=Press%20inquiry`} class="cta-ghost">
          Email allaiaj.luise@gmail.com <ArrowUpRight size={12} />
        </a>
      </div>
      <p class="byline text-ink-mute mt-7">
        Topics I'm happy to speak on — entrepreneurship and operating at scale, building a personal brand without performing, identity-led marketing, AI-era brand visibility, the woman-founder rooms, the work behind <em>Become Her</em>.
      </p>
    </div>
  </section>
</PageLayout>
