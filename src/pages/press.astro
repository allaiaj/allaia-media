---
import PageLayout from '@layouts/PageLayout.astro';
import PressFeatures from '@components/sections/PressFeatures.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import Instagram from '@components/icons/Instagram.astro';
---

<PageLayout
  title="Press"
  description="Selected press features and interviews on Allaia — the entrepreneur, author, and operator behind Allaia Media."
  eyebrow="Press · selected features"
  heading="On the"
  italic="record."
  lead="Selected pieces. The longer trail lives on email — write if you are writing."
  byline="For press inquiries · DM @allaia.power or email allaia@blacklyne.ai"
>
  <PressFeatures />

  <section class="mx-auto max-w-3xl px-6 pt-8 pb-16 sm:pb-20">
    <div class="reveal pt-12 border-t border-ink/10">
      <p class="eyebrow mb-5">For press</p>
      <h2 class="display-sm mb-6">
        Interviews + <span class="italic-grad">profiles.</span>
      </h2>
      <p class="serif-body text-ink-soft mb-7 max-w-prose">
        Profiles, podcasts, panels. A line about the publication, a sense of the angle, and a rough timeline is enough to start the conversation. I respond personally within a week.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark">
          <Instagram size={13} /> DM @allaia.power <ArrowUpRight size={12} />
        </a>
        <a href={`mailto:${site.email}?subject=Press%20inquiry`} class="cta-ghost">
          Or by email <ArrowUpRight size={12} />
        </a>
      </div>
    </div>
  </section>
</PageLayout>
