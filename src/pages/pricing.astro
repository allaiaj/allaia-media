---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import { site } from "../data/site";
---

<Layout
  title="Pricing - Allaia Media"
  description="Honest, month-to-month pricing. From $199. No long contracts. Bundle discount when you stack two or more."
>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-36 sm:pt-44 pb-8 sm:pb-12">
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <div
          class="absolute left-1/2 top-1/3 h-[70vh] w-[70vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-[100px]"
          style="background: radial-gradient(circle, rgba(167,139,250,0.4) 0%, transparent 60%);"
        ></div>
      </div>
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="reveal mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Pricing · honest by default
        </p>
        <h1 class="reveal display-tight mx-auto max-w-3xl text-[clamp(2.75rem,9vw,7.5rem)] font-medium">
          <span class="text-gradient-ink">No long contracts.</span><br />
          <span class="font-serif italic text-gradient-violet">Cancel any month.</span>
        </h1>
        <p class="reveal mt-10 mx-auto max-w-2xl text-base sm:text-lg text-ink-700 leading-relaxed">
          Starting rates below. Final pricing is tailored to your scope. Month-to-month on everything except Meta Ads (3-month minimum, because the data needs time to compound).
        </p>
      </div>
    </section>

    <Pricing />
    <FAQ />
  </main>
  <Footer />
</Layout>
