---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Work from "../components/Work.astro";
import CTA from "../components/CTA.astro";
import { site } from "../data/site";
---

<Layout
  title="Selected Work - Allaia Media"
  description="Founder-led brands we've built websites for - and the systems we put behind them."
>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-36 sm:pt-44 pb-12 sm:pb-20">
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <div
          class="absolute left-1/2 top-1/3 h-[70vh] w-[70vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-[100px]"
          style="background: radial-gradient(circle, rgba(167,139,250,0.4) 0%, transparent 60%);"
        ></div>
      </div>
      <div class="mx-auto max-w-5xl px-6 text-center">
        <p class="reveal mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Selected work · 500+ founder-led brands
        </p>
        <h1 class="reveal display-tight mx-auto max-w-4xl text-[clamp(2.75rem,9vw,7.5rem)] font-medium">
          <span class="text-gradient-ink">The receipts</span><br />
          <span class="font-serif italic text-gradient-violet">we ship every week.</span>
        </h1>
        <p class="reveal mt-10 mx-auto max-w-2xl text-base sm:text-lg text-ink-700 leading-relaxed">
          Curated builds from the last 12 months. Aesthetic clinics, florists, dentists, fitness studios - all founder-led, all measurably better than what they had before.
        </p>

        <!-- Stats inline -->
        <div class="reveal mt-14 grid grid-cols-2 sm:grid-cols-4 gap-px overflow-hidden rounded-2xl border border-ink-900/8" style="background: rgb(14 13 10 / 0.08);">
          {[
            { v: "500+", l: "brands shipped" },
            { v: "1 day", l: "average launch" },
            { v: "100%", l: "client retention" },
            { v: "5", l: "service categories" },
          ].map((m) => (
            <div class="px-4 py-5 sm:py-6 text-center" style="background: var(--color-paper);">
              <div class="font-serif italic text-2xl sm:text-3xl text-gradient-violet">
                {m.v}
              </div>
              <div class="mt-1.5 text-[10px] uppercase tracking-[0.16em] text-ink-500">
                {m.l}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Work bento (header suppressed since page hero serves that role) -->
    <Work showHeader={false} />

    <!-- Closing CTA -->
    <CTA />
  </main>
  <Footer />
</Layout>
