---
import PageLayout from '@layouts/PageLayout.astro';
import { site, closingTiles } from '@data/site';
import Instagram from '@components/icons/Instagram.astro';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<PageLayout
  title="Contact"
  description="The direct line — book, application, community, Instagram, or email. Allaia reads every one."
  eyebrow="Direct line"
  heading="The four doors —"
  italic="choose one."
  lead="The site is intentionally form-free. The four channels below all reach me. If you are unsure which is right, send the email."
  byline="allaiaj.luise@gmail.com · I respond within a week"
>
  <div class="mx-auto max-w-5xl px-6 space-y-10">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {closingTiles.map((tile, i) => (
        <a
          href={tile.href}
          target={tile.external ? '_blank' : undefined}
          rel={tile.external ? 'noopener' : undefined}
          class="reveal group block bg-bone rounded-[1.5rem] p-7 border border-ink/8 hover:border-ink/30 hover:-translate-y-1 transition-all duration-300 ease-editorial"
          style={`transition-delay: ${i * 60}ms`}
        >
          <p class="byline text-ink-mute mb-5">No. 0{i + 1}</p>
          <p class="micro tracking-[0.22em] uppercase text-ink-mute mb-3">{tile.eyebrow}</p>
          <h3 class="font-display text-2xl text-ink mb-3 leading-tight group-hover:text-terracotta-deep transition-colors duration-300 ease-editorial">
            {tile.title}
          </h3>
          <p class="serif-body text-ink-soft mb-7">{tile.sub}</p>
          <span class="inline-flex items-center gap-2 byline text-ink group-hover:gap-3 transition-all duration-300 ease-editorial">
            Open <ArrowUpRight size={11} />
          </span>
        </a>
      ))}
    </div>

    <div class="reveal grid sm:grid-cols-2 gap-5 pt-10 border-t border-ink/10">
      <a href={`mailto:${site.email}`} class="block bg-cream rounded-[1.5rem] p-7 border border-ink/8 hover:border-ink/30 transition-colors duration-300 ease-editorial">
        <p class="eyebrow mb-3">Email</p>
        <p class="font-display text-2xl text-ink hover:text-terracotta-deep transition-colors duration-300 ease-editorial">
          {site.email}
        </p>
        <p class="byline text-ink-mute mt-3">Press, partnerships, and everything else.</p>
      </a>
      <a href={site.instagram} target="_blank" rel="noopener" class="block bg-cream rounded-[1.5rem] p-7 border border-ink/8 hover:border-ink/30 transition-colors duration-300 ease-editorial">
        <p class="eyebrow mb-3 flex items-center gap-2"><Instagram size={12} /> Instagram</p>
        <p class="font-display text-2xl text-ink hover:text-terracotta-deep transition-colors duration-300 ease-editorial">@allaia.power</p>
        <p class="byline text-ink-mute mt-3">DMs read on Monday and Thursday mornings.</p>
      </a>
    </div>
  </div>
</PageLayout>
