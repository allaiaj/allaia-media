---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ScrollScrub from "../components/ScrollScrub.astro";
import Coaching from "../components/Coaching.astro";
import BrandCollabs from "../components/BrandCollabs.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import StatStrip from "../components/StatStrip.astro";
import CaseStudies from "../components/CaseStudies.astro";
import About from "../components/About.astro";
import TestimonialMarquee from "../components/TestimonialMarquee.astro";
import Services from "../components/Services.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Nav />
  <main>
    <!-- Founder-first narrative -->
    <Hero />
    <ScrollScrub />

    <!-- Headline offers -->
    <Coaching />
    <BrandCollabs />

    <!-- Proof + studio side -->
    <LogoMarquee />
    <StatStrip />
    <CaseStudies />
    <TestimonialMarquee />

    <!-- About + services lower in flow as supporting context -->
    <About />
    <Services />

    <!-- Close -->
    <FAQ />
    <CTA />
  </main>
  <Footer />
</Layout>
