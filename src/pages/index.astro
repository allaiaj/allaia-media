---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import ScrollScrub from "../components/ScrollScrub.astro";
import Manifesto from "../components/Manifesto.astro";
import Coaching from "../components/Coaching.astro";
import BrandCollabs from "../components/BrandCollabs.astro";
import BlacklyneBridge from "../components/BlacklyneBridge.astro";
import CaseStudies from "../components/CaseStudies.astro";
import TestimonialMarquee from "../components/TestimonialMarquee.astro";
import About from "../components/About.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Nav />
  <main>
    <!-- Founder-first, cinematic, aspirational -->
    <Hero />
    <ScrollScrub />

    <!-- Personal letter / diary entry -->
    <Manifesto />

    <!-- The two direct offers from her -->
    <Coaching />
    <BrandCollabs />

    <!-- Bridge to Blacklyne for execution work -->
    <BlacklyneBridge />

    <!-- Proof - quieter now, supporting -->
    <CaseStudies />
    <TestimonialMarquee />

    <!-- About + close -->
    <About />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</Layout>
