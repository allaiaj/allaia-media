---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { site } from '@data/site';
import Instagram from '@components/icons/Instagram.astro';

const works = (await getCollection('artworks')).sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="The Rupture — a body of work"
  description="Textured abstract mixed-media. The pieces hold what the writing cannot."
  eyebrow="@allaia.art · The Rupture · 2025—2026"
  heading="The"
  italic="Rupture."
  lead="Textured abstract mixed-media — pigment, plaster, oil stick. The pieces hold what the writing cannot."
  byline="A practice — not a shop"
>
  <div class="mx-auto max-w-6xl px-6 space-y-16 sm:space-y-24">
    {works.map((w, i) => (
      <article class={`reveal grid lg:grid-cols-2 gap-10 lg:gap-16 items-center ${i % 2 === 1 ? 'lg:[&>figure]:order-2' : ''}`}>
        <figure class="relative">
          <div class="relative aspect-[4/5] rounded-[1.5rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
            <!-- Fallback FIRST so img paints on top -->
            <div
              class="absolute inset-0"
              style={
                i % 4 === 0 ? 'background: radial-gradient(circle at 30% 30%, #8E3D2F 0%, #2A1A14 80%);' :
                i % 4 === 1 ? 'background: radial-gradient(circle at 70% 30%, #B85542 0%, #6B4F3D 100%);' :
                i % 4 === 2 ? 'background: radial-gradient(circle at 40% 70%, #F2EDE5 0%, #6B4F3D 100%);' :
                'background: radial-gradient(circle at 60% 60%, #8B9D7E 0%, #2A2722 100%);'
              }
              aria-hidden="true"
            ></div>
            <img
              src={w.data.image}
              alt={w.data.title}
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover"
            />
          </div>
        </figure>
        <div>
          <p class="byline text-ink-mute mb-4">No. {String(w.data.order).padStart(2, '0')} · {w.data.year}</p>
          <h2 class="display-md mb-5">{w.data.title}</h2>
          <p class="serif-lg text-ink-soft mb-4 max-w-prose">{w.data.description}</p>
          <dl class="space-y-3 byline text-ink-mute pt-5 border-t border-ink/10">
            <div class="flex gap-4"><dt class="w-24 text-ink">Medium</dt><dd>{w.data.medium}</dd></div>
            {w.data.dimensions && <div class="flex gap-4"><dt class="w-24 text-ink">Size</dt><dd>{w.data.dimensions}</dd></div>}
            <div class="flex gap-4"><dt class="w-24 text-ink">Collection</dt><dd>{w.data.collection}</dd></div>
          </dl>
        </div>
      </article>
    ))}

    <aside class="reveal pt-16 border-t border-ink/10 grid lg:grid-cols-[1fr_auto] gap-6 items-center">
      <div>
        <p class="font-display italic text-2xl text-brown leading-tight max-w-md mb-3">
          The work moves slowly. A piece every few months.
        </p>
        <p class="byline text-ink-mute">More on Instagram, where the studio sits.</p>
      </div>
      <a href={site.instagramArt} target="_blank" rel="noopener" class="cta-dark whitespace-nowrap">
        <Instagram size={14} /> @allaia.art
      </a>
    </aside>
  </div>
</PageLayout>
