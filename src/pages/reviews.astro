---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Testimonials from "../components/Testimonials.astro";
import CTA from "../components/CTA.astro";
import { testimonials } from "../data/site";
---

<Layout
  title="Reviews - Allaia Media"
  description="12 founders across 8 markets on what changed when they started working with Allaia."
>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="relative isolate overflow-hidden pt-36 sm:pt-44 pb-8 sm:pb-12">
      <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
        <div
          class="absolute left-1/2 top-1/3 h-[70vh] w-[70vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-[100px]"
          style="background: radial-gradient(circle, rgba(167,139,250,0.4) 0%, transparent 60%);"
        ></div>
      </div>
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="reveal mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Reviews · 100% retention · {testimonials.length} on record
        </p>
        <h1 class="reveal display-tight mx-auto max-w-3xl text-[clamp(2.75rem,9vw,7.5rem)] font-medium">
          <span class="text-gradient-ink">Founders</span><br />
          <span class="font-serif italic text-gradient-violet">don't lie.</span>
        </h1>
        <p class="reveal mt-10 mx-auto max-w-2xl text-base sm:text-lg text-ink-700 leading-relaxed">
          The receipts from the people we work for. We've kept every account we've ever opened. Not because we're lucky - because we built the system around what they actually need.
        </p>

        <!-- Stats inline -->
        <div class="reveal mt-12 grid grid-cols-3 gap-px overflow-hidden rounded-2xl border border-ink-900/8 max-w-xl mx-auto" style="background: rgb(14 13 10 / 0.08);">
          {[
            { v: "5.0", l: "average rating" },
            { v: "100%", l: "retention" },
            { v: "8", l: "markets" },
          ].map((m) => (
            <div class="px-4 py-5 text-center" style="background: var(--color-paper);">
              <div class="font-serif italic text-2xl sm:text-3xl text-gradient-violet">
                {m.v}
              </div>
              <div class="mt-1.5 text-[10px] uppercase tracking-[0.16em] text-ink-500">
                {m.l}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Testimonials />
    <CTA />
  </main>
  <Footer />
</Layout>
