    .stat-card, .stat-card:hover, .pkg-tab:hover { transform: none; }
    .pkg-panel { animation: none; }
  }
</style>

<script>
  // ── Compact number formatting shared by both widgets ──
  // Drops trailing zeros so we get "1.2M" not "1.20M", and keeps one
  // decimal below 10K so "6.8K saves" doesn't collapse into a blunt "7K".
  // "1.20" → "1.2", "1.00" → "1", "4.5" → "4.5"
  const trim = (s: string): string =>
    s.replace(/(\.\d*?)0+$/, '$1').replace(/\.$/, '');

  const fmtK = (n: number): string => {
    if (n >= 1_000_000) return trim((n / 1_000_000).toFixed(2)) + 'M';
    if (n >= 10_000) return Math.round(n / 1_000) + 'K';
    if (n >= 1_000) return trim((n / 1_000).toFixed(1)) + 'K';
    return String(Math.round(n));
  };

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── 1. Count-up stats ──────────────────────────────────────────────
  const counters = document.querySelectorAll<HTMLElement>('[data-countup]');
  if (counters.length) {
    const render = (el: HTMLElement, value: number) => {
      const display = el.dataset.display || '';
      const suffix = el.dataset.suffix || '';
      const decimals = Number(el.dataset.decimals || 0);
      // A fixed display string (e.g. "3M+") wins once we reach the end.
      if (display && value >= Number(el.dataset.value)) {
        el.textContent = display;
        return;
      }
      el.textContent = display
        ? fmtK(value)
        : value.toFixed(decimals) + suffix;
    };

    const run = (el: HTMLElement) => {
      const target = Number(el.dataset.value || 0);
      if (reduceMotion) { render(el, target); return; }
      const duration = 1400;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / duration, 1);
        // easeOutExpo — fast, then settles
        const eased = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
        render(el, target * eased);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          run(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });

    counters.forEach((c) => io.observe(c));
  }

  // ── 2. Package tabs ────────────────────────────────────────────────
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('[data-pkg-tab]'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-pkg-panel]'));
  if (tabs.length && panels.length) {
    const select = (key: string, focus = false) => {
      tabs.forEach((t) => {
        const on = t.dataset.pkgTab === key;
        t.setAttribute('aria-selected', String(on));
        t.setAttribute('tabindex', on ? '0' : '-1');
        if (on && focus) t.focus();
      });
      panels.forEach((p) => {
        p.hidden = p.dataset.pkgPanel !== key;
      });
    };

    tabs.forEach((t) => {
      t.addEventListener('click', () => select(t.dataset.pkgTab!));
    });

    // Roving arrow-key navigation across the tablist.
    tabs.forEach((t, i) => {
      t.addEventListener('keydown', (e: KeyboardEvent) => {
        let next = -1;
        if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
        if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
        if (e.key === 'Home') next = 0;
        if (e.key === 'End') next = tabs.length - 1;
        if (next >= 0) {
          e.preventDefault();
          select(tabs[next].dataset.pkgTab!, true);
        }
      });
    });
  }

  // ── 3. Reach estimator ─────────────────────────────────────────────
  const range = document.querySelector<HTMLInputElement>('[data-est-range]');
  if (range) {
    const PER_FILM = 150_000;
    const NEW_AUDIENCE = 0.868;
    const SAVE_RATE = 0.015;
    const CPM = 10;

    const elFilms = document.querySelector<HTMLElement>('[data-est-films]');
    const elFilmsLabel = document.querySelector<HTMLElement>('[data-est-films-label]');
    const elViews = document.querySelector<HTMLElement>('[data-est-views]');
    const elNew = document.querySelector<HTMLElement>('[data-est-new]');
    const elSaves = document.querySelector<HTMLElement>('[data-est-saves]');
    const elValue = document.querySelector<HTMLElement>('[data-est-value]');

    const update = () => {
      const films = Number(range.value);
      const views = films * PER_FILM;

      // Paint the filled portion of the track.
      const pct = ((films - Number(range.min)) / (Number(range.max) - Number(range.min))) * 100;
      range.style.setProperty('--fill', pct + '%');

      if (elFilms) elFilms.textContent = String(films);
      if (elFilmsLabel) elFilmsLabel.textContent = films === 1 ? 'film' : 'films';
      if (elViews) elViews.textContent = fmtK(views);
      if (elNew) elNew.textContent = fmtK(views * NEW_AUDIENCE);
      if (elSaves) elSaves.textContent = fmtK(views * SAVE_RATE);
      if (elValue) {
        const usd = (views / 1000) * CPM;
        elValue.textContent = '$' + (usd >= 1000 ? trim((usd / 1000).toFixed(1)) + 'K' : String(Math.round(usd)));
      }
    };

    range.addEventListener('input', update);
    update();
  }
</script>
