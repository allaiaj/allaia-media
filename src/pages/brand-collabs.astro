---
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import Instagram from '@components/icons/Instagram.astro';

// Top-performing films — from Instagram Insights, ranked by engagement.
const topVids = [
  { img: '/img/collabs/best1.jpg', views: '619K', title: 'Escape The Matrix', er: '11.1%', a: ['51.2K', 'Likes'], b: ['10.9K', 'Saves'], href: 'https://www.instagram.com/reel/DYe7mNNsztZ/' },
  { img: '/img/collabs/best2.jpg', views: '540K', title: 'Which one are you?', er: '5.7%', a: ['18.3K', 'Shares'], b: ['11K', 'Likes'], href: 'https://www.instagram.com/reel/DVk_FqaDKjT/' },
  { img: '/img/collabs/best3.jpg', views: '212K', title: 'She’s a dangerous breed', er: '9.5%', a: ['9.6K', 'Shares'], b: ['9.1K', 'Likes'], href: 'https://www.instagram.com/reel/DWk5dvejGdm/' },
];

const moreVids = [
  { img: '/img/collabs/DVWZkB9CNfh.jpg', views: '260K', title: 'Competency is the standard', href: 'https://www.instagram.com/reel/DVWZkB9CNfh/' },
  { img: '/img/collabs/DZTtOngsOBG.jpg', views: '221K', title: 'On high standards', href: 'https://www.instagram.com/reel/DZTtOngsOBG/' },
  { img: '/img/collabs/DVeBLwTD_Vs.jpg', views: '193K', title: 'Living in Dubai', href: 'https://www.instagram.com/reel/DVeBLwTD_Vs/' },
  { img: '/img/collabs/DZTyZlzMrJO.jpg', views: '151K', title: 'You are not your record', href: 'https://www.instagram.com/reel/DZTyZlzMrJO/' },
  { img: '/img/collabs/DXwOfqdM_N0.jpg', views: '144K', title: 'The most expensive thing you can wear', href: 'https://www.instagram.com/reel/DXwOfqdM_N0/' },
  { img: '/img/collabs/DY44G_Gs6rU.jpg', views: '133K', title: 'You’re THAT girl', href: 'https://www.instagram.com/reel/DY44G_Gs6rU/' },
  { img: '/img/collabs/DZuN-7BMM-v.jpg', views: '129K', title: 'Divine femininity', href: 'https://www.instagram.com/reel/DZuN-7BMM-v/' },
  { img: '/img/collabs/DVoRu4mD4x-.jpg', views: '128K', title: 'Say something positive', href: 'https://www.instagram.com/reel/DVoRu4mD4x-/' },
];

const libraryRow2 = [
  { img: '/img/collabs/DZ9eoxeMeEL.jpg', views: '93K', title: 'The power of keeping to yourself', href: 'https://www.instagram.com/reel/DZ9eoxeMeEL/' },
  { img: '/img/collabs/DZClhdhs7l7.jpg', views: '86K', title: 'Dinner at Ferro Ubud', href: 'https://www.instagram.com/reel/DZClhdhs7l7/' },
  { img: '/img/collabs/DVi81w7Euqt.jpg', views: '76K', title: 'On uncertainty', href: 'https://www.instagram.com/reel/DVi81w7Euqt/' },
  { img: '/img/collabs/DWdaXwVDP97.jpg', views: '73K', title: 'As long as you don’t try me', href: 'https://www.instagram.com/reel/DWdaXwVDP97/' },
  { img: '/img/collabs/DZheN1usVSX.jpg', views: '72K', title: 'Nothing casual in my world', href: 'https://www.instagram.com/reel/DZheN1usVSX/' },
  { img: '/img/collabs/DWWc7c4iBsO.jpg', views: '70K', title: 'Says who?', href: 'https://www.instagram.com/reel/DWWc7c4iBsO/' },
  { img: '/img/collabs/DWiLJd-jKed.jpg', views: '67K', title: 'My fiery women', href: 'https://www.instagram.com/reel/DWiLJd-jKed/' },
  { img: '/img/collabs/DZ2wUWgsrun.jpg', views: '57K', title: 'The right one', href: 'https://www.instagram.com/reel/DZ2wUWgsrun/' },
];

// Value props — spoken straight to the brand.
const valueProps = [
  { k: '86.8%', label: 'non-follower reach', body: 'Your product lands in front of women discovering it for the first time — new buyers, not just my regulars.' },
  { k: '11.1%', label: 'peak engagement', body: 'Most sponsored content sees 1–3%. My audience stops, saves and acts.' },
  { k: '619K', label: 'views, one film', body: 'Six-figure reach is the baseline you are buying into, not a fluke.' },
  { k: '100%', label: 'yours to keep', body: 'Run every frame as paid ads, on your grid, in your emails. You own it.' },
];

const steps = [
  { n: '1', t: 'You brief me', d: 'The product, the goal, a rough budget. One email is enough to know if we should talk.' },
  { n: '2', t: 'I build it', d: 'Concept, shoot and edit — woven into my world so it reads as a recommendation, never an ad drop.' },
  { n: '3', t: 'It goes live', d: 'Posted at peak time, then the files and the numbers land in your inbox. Yours from there.' },
];

const fits = [
  { img: '/img/collabs/DZMr2wxs_47.jpg', label: 'Wellness & supplements' },
  { img: '/img/collabs/DXjGCtWjGYk.jpg', label: 'Beauty & skincare' },
  { img: '/img/collabs/DYv4c-YMHFR.jpg', label: 'Activewear & movement' },
  { img: '/img/collabs/DZzFKFYM2wg.jpg', label: 'Travel, home & soft living' },
];

const marqueeA = [
  '/img/portraits/DV2vp-hiJzx.jpg', '/img/collabs/best1.jpg', '/img/portraits/DVEQKoVj4DN.jpg',
  '/img/collabs/DY44G_Gs6rU.jpg', '/img/portraits/DW5oFrOGIv_.jpg', '/img/collabs/DZTtOngsOBG.jpg',
];
const marqueeB = [
  '/img/portraits/DXdmLBNFHa8.jpg', '/img/collabs/DZuN-7BMM-v.jpg', '/img/portraits/DXv8snOlDS-.jpg',
  '/img/collabs/DWiLJd-jKed.jpg', '/img/portraits/DWlfa4-lOuC.jpg', '/img/collabs/best3.jpg',
];
const loopA = [...marqueeA, ...marqueeA];
const loopB = [...marqueeB, ...marqueeB];

const deliverables = [
  ['Concept & script', 'built around your product, not bolted on'],
  ['Editorial production', 'shot, lit and edited to the standard you see here'],
  ['Native posting', 'to my feed at peak time, caption included'],
  ['Full usage rights', 'paid ads, organic, email — all channels, no renewals'],
  ['Performance recap', 'the real numbers after it runs, straight to you'],
];
---

<PageLayout
  title="Brand collaborations"
  description="Selective, editorial brand partnerships — wellness, beauty and lifestyle. Real reach, real engagement, content you own. Paid only."
  eyebrow="Brand collaborations · 2026"
  heading="Let’s put your product"
  italic="in front of women who buy."
  lead="If you run a wellness, beauty or lifestyle brand, here is the short version: I make content that women save and send to their friends — and when your product lives inside it, it reads as a recommendation, not an ad. Selective, editorial, paid."
  byline="By personal inquiry · I read and reply to every one within a week"
>
  <!-- ── Collage intro — who you'd work with ── -->
  <div class="mx-auto max-w-6xl px-6">
    <section class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="collage">
        <div class="collage-main rounded-[1.75rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
          <img src="/img/portraits/DV2vp-hiJzx.jpg" alt="Allaia Power" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="collage-side rounded-[1.25rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
          <img src="/img/portraits/DXv8snOlDS-.jpg" alt="Allaia — in transit" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="collage-chip chip-views">
          <p class="font-display italic text-2xl text-terracotta leading-none">3.4M</p>
          <p class="byline text-ink-mute mt-1">views · 90 days</p>
        </div>
        <div class="collage-chip chip-er">
          <p class="font-display italic text-2xl text-terracotta leading-none">11.1%</p>
          <p class="byline text-ink-mute mt-1">peak engagement</p>
        </div>
      </div>
      <div>
        <p class="eyebrow mb-5">Who you’d be working with</p>
        <h2 class="display-sm mb-6">Not an influencer feed. <span class="italic-grad">A point of view.</span></h2>
        <p class="serif-lg text-ink-soft max-w-prose mb-5">
          I take on a few aligned partners a quarter, chosen the way essays are commissioned — so every collaboration actually lands. If your product belongs in a slow, intentional, feminine life, my audience is already primed to want it.
        </p>
        <p class="serif-body text-ink-mute max-w-prose mb-8">Dubai &amp; Bali · always in transit · every inquiry read personally.</p>
        <div class="flex flex-wrap gap-3">
          <span class="fit-pill">Wellness</span><span class="fit-pill">Beauty</span><span class="fit-pill">Soft life</span><span class="fit-pill">Movement</span><span class="fit-pill">Clean eating</span>
        </div>
      </div>
    </section>
  </div>

  <!-- ── Stat cards — why this works for you ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">Why this works for you</p>
      <h2 class="display-sm mb-10 max-w-2xl">You are not buying a post. You are borrowing <span class="italic-grad">trust I spent years earning.</span></h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {valueProps.map((v) => (
          <div class="stat-card rounded-[1.5rem] p-7">
            <p class="font-display italic text-5xl text-terracotta leading-none mb-3">{v.k}</p>
            <p class="text-micro uppercase tracking-[0.14em] text-ink font-medium mb-3">{v.label}</p>
            <p class="serif-body text-ink-soft">{v.body}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- ── Most-watched films ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">See it for yourself · most-watched</p>
      <h2 class="display-sm mb-4">This is what happens <span class="italic-grad">when I post.</span></h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        My three highest-engagement films. Picture your product in the middle of one. Tap any to watch the original.
      </p>
      <div class="grid sm:grid-cols-3 gap-5">
        {topVids.map((v, i) => (
          <a href={v.href} target="_blank" rel="noopener" class={`group block ${i === 1 ? 'sm:-mt-6' : ''}`}>
            <div class="relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
              <img src={v.img} alt={v.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.04]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-black/25"></div>
              <span class="absolute right-4 top-4 rounded-full bg-cream/90 px-2.5 py-1 text-micro font-medium text-ink">{v.er} ER</span>
              <p class="absolute left-4 top-3 font-display italic text-5xl text-white/95 drop-shadow-sm">{v.views}</p>
              <div class="play-dot" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
              </div>
              <div class="absolute inset-x-0 bottom-0 p-4">
                <p class="byline text-white/70 mb-1">Instagram · views</p>
                <p class="font-display text-white text-lg leading-tight">{v.title}</p>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <div class="rounded-xl bg-ink/[0.04] px-4 py-3"><p class="font-display text-2xl text-ink">{v.a[0]}</p><p class="byline text-ink-mute">{v.a[1]}</p></div>
              <div class="rounded-xl bg-ink/[0.04] px-4 py-3"><p class="font-display text-2xl text-ink">{v.b[0]}</p><p class="byline text-ink-mute">{v.b[1]}</p></div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>

  <!-- ── Oversized number moment ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal big-number-band rounded-[1.75rem] px-8 py-14 sm:px-14 sm:py-16 text-center">
      <p class="eyebrow mb-4">Unique people reached · last 90 days</p>
      <p class="big-number font-display italic text-terracotta leading-none">1.74M</p>
      <p class="serif-lg text-ink-soft max-w-xl mx-auto mt-6">
        — and 86.8% of them don’t follow me yet. That is your product being discovered, not just seen by the same crowd twice.
      </p>
    </section>
  </div>

  <!-- ── Case study spotlight ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal rounded-[1.75rem] overflow-hidden bg-ink text-cream">
      <div class="grid lg:grid-cols-[0.85fr_1.15fr] items-stretch">
        <div class="relative min-h-[380px]">
          <img src="/img/collabs/best1.jpg" alt="Escape The Matrix" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/80 to-transparent lg:bg-gradient-to-r"></div>
          <span class="absolute left-5 top-5 rounded-full bg-cream/90 px-3 py-1.5 text-micro font-medium text-ink">Case study · 01</span>
          <p class="absolute left-5 bottom-5 font-display italic text-6xl text-white/95">619K</p>
        </div>
        <div class="p-8 sm:p-12">
          <p class="eyebrow text-terracotta mb-5">One film · a closer look</p>
          <h2 class="display-sm text-cream mb-6">619K views. 10.9K saves. <span class="italic text-terracotta">And most of it strangers.</span></h2>
          <p class="serif-body text-cream/75 max-w-prose mb-9">
            Here is the part that matters for you: a film like this doesn’t preach to my choir — it carries your product to hundreds of thousands of new women who discover it, save it, and send it on. Top-of-funnel and trust, in the same post.
          </p>
          <div class="grid grid-cols-3 gap-4">
            <div class="rounded-xl bg-cream/[0.06] px-4 py-4 text-center"><p class="font-display italic text-3xl text-terracotta">619K</p><p class="byline text-cream/60 mt-1">Views</p></div>
            <div class="rounded-xl bg-cream/[0.06] px-4 py-4 text-center"><p class="font-display italic text-3xl text-terracotta">10.9K</p><p class="byline text-cream/60 mt-1">Saves</p></div>
            <div class="rounded-xl bg-cream/[0.06] px-4 py-4 text-center"><p class="font-display italic text-3xl text-terracotta">11.1%</p><p class="byline text-cream/60 mt-1">Engagement</p></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- ── The library ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">The library</p>
      <h2 class="display-sm mb-4">Not one lucky hit.</h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        A steady run of films landing six figures — you are betting on a pattern, not a fluke.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {moreVids.map((v) => (
          <a href={v.href} target="_blank" rel="noopener" class="group block">
            <div class="relative aspect-[9/16] rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
              <img src={v.img} alt={v.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.05]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent"></div>
              <span class="absolute left-3 top-3 rounded-full bg-cream/90 px-2.5 py-1 text-micro font-medium text-ink">{v.views}</span>
              <p class="absolute inset-x-0 bottom-0 p-3 font-display text-white text-sm leading-tight">{v.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-4">
        {libraryRow2.map((v) => (
          <a href={v.href} target="_blank" rel="noopener" class="group block">
            <div class="relative aspect-[9/16] rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
              <img src={v.img} alt={v.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.05]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent"></div>
              <span class="absolute left-3 top-3 rounded-full bg-cream/90 px-2.5 py-1 text-micro font-medium text-ink">{v.views}</span>
              <p class="absolute inset-x-0 bottom-0 p-3 font-display text-white text-sm leading-tight">{v.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-10">
        <a href={site.instagram} target="_blank" rel="noopener" class="cta-ghost">
          <Instagram size={13} /> <span>See it all on Instagram</span> <ArrowUpRight size={12} />
        </a>
      </div>
    </section>
  </div>

  <!-- ── Full-bleed world · two-row marquee ── -->
  <section class="reveal mt-20 sm:mt-28 overflow-hidden">
    <div class="mx-auto max-w-6xl px-6 mb-10">
      <p class="eyebrow mb-5">The world you’d step into</p>
      <h2 class="display-sm max-w-2xl">This is the room your product gets to live in.</h2>
    </div>
    <div class="collab-marquee-mask space-y-4">
      <div class="collab-marquee">
        {loopA.map((src) => (
          <div class="collab-tile rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
            <img src={src} alt="Allaia" class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
      <div class="collab-marquee collab-marquee-rev">
        {loopB.map((src) => (
          <div class="collab-tile rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
            <img src={src} alt="Allaia" class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Brand fit — image tiles ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">You’re a fit if you make</p>
      <h2 class="display-sm mb-10 max-w-2xl">Products that belong in a considered, feminine life.</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {fits.map((f) => (
          <div class="group relative aspect-[4/5] rounded-[1.25rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
            <img src={f.img} alt={f.label} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.05]" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
            <p class="absolute inset-x-0 bottom-0 p-5 font-display text-white text-xl leading-tight">{f.label}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- ── What you get + how it works ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20">
      <div>
        <p class="eyebrow mb-5">What you walk away with</p>
        <h2 class="display-sm mb-8">Everything, <span class="italic-grad">done properly.</span></h2>
        <ul class="space-y-3">
          {deliverables.map(([t, d], i) => (
            <li class="deliver-row rounded-2xl px-5 py-4 flex items-baseline gap-4">
              <span class="byline text-terracotta tabular-nums shrink-0">{String(i + 1).padStart(2, '0')}</span>
              <span class="serif-body text-ink-soft"><strong class="font-display text-ink text-lg font-normal">{t}</strong> — {d}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="eyebrow mb-5">How we’d work together</p>
        <h2 class="display-sm mb-8">Three steps. <span class="italic-grad">No friction.</span></h2>
        <div class="space-y-4">
          {steps.map((s) => (
            <div class="step-card rounded-2xl p-6 relative overflow-hidden">
              <span class="step-watermark font-display italic" aria-hidden="true">{s.n}</span>
              <h3 class="font-display text-xl text-ink mb-2 relative">{s.t}</h3>
              <p class="serif-body text-ink-soft relative max-w-md">{s.d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- ── CTA ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal cta-band rounded-[1.75rem] overflow-hidden relative">
      <img src="/img/portraits/DWlfa4-lOuC.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
      <div class="absolute inset-0 bg-gradient-to-r from-ink/85 via-ink/65 to-ink/30"></div>
      <div class="relative p-8 sm:p-14 max-w-2xl">
        <p class="eyebrow text-terracotta mb-5">To work together</p>
        <h2 class="display-sm text-cream mb-6">Tell me what you’re <span class="italic text-terracotta">launching.</span></h2>
        <p class="serif-body text-cream/80 max-w-prose mb-9">
          A line about you, why you reached out, a rough scope and budget range. That is enough for me to come back with a tailored quote. Press inquiries welcome.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark justify-center !py-4 !bg-cream !text-ink hover:!bg-cream/85">
            <Instagram size={13} /> <span>DM @allaia.power</span> <ArrowUpRight size={12} />
          </a>
          <a href={`mailto:${site.email}?subject=Brand%20partnership`} class="cta-ghost justify-center !py-4 !border-cream/40 !text-cream hover:!border-cream">
            <span>Or send an email</span> <ArrowUpRight size={12} />
          </a>
        </div>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  /* ── Collage ── */
  .collage {
    position: relative;
    aspect-ratio: 4 / 4.4;
  }
  .collage-main {
    position: absolute;
    inset: 0 14% 10% 0;
  }
  .collage-side {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 44%;
    aspect-ratio: 4 / 5;
    transform: rotate(2.5deg);
  }
  .collage-chip {
    position: absolute;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(28, 26, 23, 0.08);
    border-radius: 1rem;
    padding: 0.8rem 1.1rem;
