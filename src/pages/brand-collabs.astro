---
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import Instagram from '@components/icons/Instagram.astro';

// ── Planning numbers ────────────────────────────────────────────────
// Every figure below is derived from Allaia's real Instagram Insights.
// The estimator uses a DELIBERATELY CONSERVATIVE per-film number
// (150K) against a trailing average of ~175K across the last 19
// published films, so a brand's projection under-promises.
const PLANNING = {
  perFilm: 150000,      // conservative planning figure per film
  trailingAvg: 175000,  // actual trailing average, last 19 films
  newAudience: 0.868,   // 86.8% of reach are non-followers
  saveRate: 0.015,      // conservative vs 1.76% on the top film
  cpm: 10,              // industry-standard social CPM, USD
};

// Top-performing films — from Instagram Insights, ranked by engagement.
const topVids = [
  { img: '/img/collabs/best1.jpg', views: '619K', title: 'Escape The Matrix', er: '11.1%', a: ['51.2K', 'Likes'], b: ['10.9K', 'Saves'], href: 'https://www.instagram.com/reel/DYe7mNNsztZ/' },
  { img: '/img/collabs/best2.jpg', views: '540K', title: 'Which one are you?', er: '5.7%', a: ['18.3K', 'Shares'], b: ['11K', 'Likes'], href: 'https://www.instagram.com/reel/DVk_FqaDKjT/' },
  { img: '/img/collabs/best3.jpg', views: '212K', title: 'She’s a dangerous breed', er: '9.5%', a: ['9.6K', 'Shares'], b: ['9.1K', 'Likes'], href: 'https://www.instagram.com/reel/DWk5dvejGdm/' },
];

const moreVids = [
  { img: '/img/collabs/DVWZkB9CNfh.jpg', views: '260K', title: 'Competency is the standard', href: 'https://www.instagram.com/reel/DVWZkB9CNfh/' },
  { img: '/img/collabs/DZTtOngsOBG.jpg', views: '221K', title: 'On high standards', href: 'https://www.instagram.com/reel/DZTtOngsOBG/' },
  { img: '/img/collabs/DVeBLwTD_Vs.jpg', views: '193K', title: 'Living in Dubai', href: 'https://www.instagram.com/reel/DVeBLwTD_Vs/' },
  { img: '/img/collabs/DZTyZlzMrJO.jpg', views: '151K', title: 'You are not your record', href: 'https://www.instagram.com/reel/DZTyZlzMrJO/' },
  { img: '/img/collabs/DXwOfqdM_N0.jpg', views: '144K', title: 'The most expensive thing you can wear', href: 'https://www.instagram.com/reel/DXwOfqdM_N0/' },
  { img: '/img/collabs/DY44G_Gs6rU.jpg', views: '133K', title: 'You’re THAT girl', href: 'https://www.instagram.com/reel/DY44G_Gs6rU/' },
  { img: '/img/collabs/DZuN-7BMM-v.jpg', views: '129K', title: 'Divine femininity', href: 'https://www.instagram.com/reel/DZuN-7BMM-v/' },
  { img: '/img/collabs/DVoRu4mD4x-.jpg', views: '128K', title: 'Say something positive', href: 'https://www.instagram.com/reel/DVoRu4mD4x-/' },
];

const libraryRow2 = [
  { img: '/img/collabs/DZ9eoxeMeEL.jpg', views: '93K', title: 'The power of keeping to yourself', href: 'https://www.instagram.com/reel/DZ9eoxeMeEL/' },
  { img: '/img/collabs/DZClhdhs7l7.jpg', views: '86K', title: 'Dinner at Ferro Ubud', href: 'https://www.instagram.com/reel/DZClhdhs7l7/' },
  { img: '/img/collabs/DVi81w7Euqt.jpg', views: '76K', title: 'On uncertainty', href: 'https://www.instagram.com/reel/DVi81w7Euqt/' },
  { img: '/img/collabs/DWdaXwVDP97.jpg', views: '73K', title: 'As long as you don’t try me', href: 'https://www.instagram.com/reel/DWdaXwVDP97/' },
  { img: '/img/collabs/DZheN1usVSX.jpg', views: '72K', title: 'Nothing casual in my world', href: 'https://www.instagram.com/reel/DZheN1usVSX/' },
  { img: '/img/collabs/DWWc7c4iBsO.jpg', views: '70K', title: 'Says who?', href: 'https://www.instagram.com/reel/DWWc7c4iBsO/' },
  { img: '/img/collabs/DWiLJd-jKed.jpg', views: '67K', title: 'My fiery women', href: 'https://www.instagram.com/reel/DWiLJd-jKed/' },
  { img: '/img/collabs/DZ2wUWgsrun.jpg', views: '57K', title: 'The right one', href: 'https://www.instagram.com/reel/DZ2wUWgsrun/' },
];

// ── Proof band — each stat translated into what it BUYS the brand ──
const proofStats = [
  { value: 3500000, display: '3.5M', label: 'views · last 90 days', body: 'Six-figure reach is your baseline, not your best case.' },
  { value: 86.8, suffix: '%', decimals: 1, label: 'reach from non-followers', body: 'You are paying for discovery, not for the same crowd seeing you twice.' },
  { value: 11.1, suffix: '%', decimals: 1, label: 'peak engagement rate', body: 'Sponsored content averages 1–3%. Mine stops the scroll and gets saved.' },
  { value: 1740000, display: '1.74M', label: 'unique people reached', body: 'Real individual humans, not impressions counted twice.' },
];

// ── Packages — what a brand actually buys ──
const packages = [
  {
    key: 'single',
    name: 'The Single',
    tag: 'One film',
    films: 1,
    best: 'A launch moment, or testing the channel before you commit.',
    intro: 'One editorial film, built around your product and posted native to my feed.',
    includes: [
      'Concept and script written around your product',
      'Full production — shot, lit and edited to the standard on this page',
      'Native post to my feed at peak time, caption included',
      'Full usage rights, all channels, no renewal fees',
      'Performance recap with the real numbers after it runs',
    ],
  },
  {
    key: 'campaign',
    name: 'The Campaign',
    tag: 'Three films · 6 weeks',
    films: 3,
    best: 'A launch window where one post is not enough to move stock.',
    intro: 'Three films across six weeks, so your product is seen more than once by the same warm audience.',
    includes: [
      'Everything in The Single, three times over',
      'Story frames supporting each film, with link stickers',
      'A discount or affiliate code created for my audience',
      'Sequenced so the films build on each other, not repeat',
      'Mid-campaign and end-of-campaign reporting',
    ],
    featured: true,
  },
  {
    key: 'ambassador',
    name: 'The Ambassador',
    tag: 'Ongoing · quarterly',
    films: 6,
    best: 'Owning your category with my audience, rather than renting it.',
    intro: 'A standing partnership. You stop being a post and start being part of the life.',
    includes: [
      'Six or more films per quarter',
      'Category exclusivity — I will not take your competitor',
      'Always-on story presence and first look at new products',
      'A quarterly strategy call before we plan the slate',
      'Full rights across everything, in perpetuity',
    ],
  },
];

// Compact number formatting — whole thousands, nearest (233K, 56K, 12K).
const fmtViews = (n: number): string =>
  n >= 1_000_000
    ? (n / 1_000_000).toFixed(1).replace(/\.0$/, '') + 'M'
    : n >= 1000
      ? Math.round(n / 1000) + 'K'
      : String(n);

// Engagement numbers keep a decimal below 10K — "2.8K saves" is both more
// accurate and more persuasive than rounding it down to a flat "3K".
const fmtEng = (n: number): string =>
  n >= 10_000 ? Math.round(n / 1000) + 'K'
    : n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'K'
      : String(n);

// One card per film, each with the reel embedded and its own numbers.
// Every figure below is from Instagram Insights. Jason Derulo's engagement
// breakdown is still outstanding, so those cells stay empty.
const featuredFilms = [
  { brand: 'Alloura Villa', note: 'Villa · Bali', code: 'DZTtOngsOBG', views: 227293, saves: 2800, sends: 2200 },
  { brand: 'NU Human Bali', note: 'Wellness · Bali', code: 'DZTyZlzMrJO', views: 158899, saves: 2700, sends: 2100 },
  { brand: 'The Path Wellness Center', note: 'Wellness centre · Bali', code: 'DZuN-7BMM-v', views: 132606, saves: 1300, sends: 1800 },
  { brand: 'Ferro Restaurant Ubud', note: 'Restaurant · Ubud', code: 'DZClhdhs7l7', views: 116192, saves: 1700, sends: 1300 },
  { brand: 'NU Human Bali', note: 'Wellness · Bali', code: 'DZheN1usVSX', views: 74549, saves: 1200, sends: 947 },
  { brand: 'Boardwalk Dubai', note: 'Waterfront dining · Dubai', code: 'DXjGCtWjGYk', views: 56447, saves: 121, sends: 1100 },
  { brand: 'Jason Derulo', note: 'Sexy For You campaign', code: 'DYCE4YxsDzG', views: 25000, saves: null, sends: null },
  { brand: 'Ferro Restaurant Ubud', note: 'Restaurant · Ubud', code: 'DZPVsu_sGih', views: 24231, saves: 276, sends: 154 },
  { brand: 'Bubble Hotel Bali', note: 'Hotel · Bali', code: 'DXi-zLRDCJg', views: 20654, saves: 126, sends: 270 },
  { brand: 'Nude Bali', note: 'Restaurant · Berawa', code: 'DZ2Rxivs5dE', views: 11686, saves: 72, sends: 79 },
  { brand: 'Kinoa Bali', note: 'Café · Bali', code: 'DZgpQHusfMy', views: 8753, saves: 182, sends: 69 },
];

// ── Who the audience is ──
// Qualitative for now. If Allaia exports the age/gender/geo splits from
// Instagram Insights, these become hard percentages, which brands prefer.
const audience = [
  {
    k: '25–45',
    label: 'the age band',
    body: 'Established enough to buy the good version, still curious enough to try the new thing.',
  },
  {
    k: 'Travel-led',
    label: 'a life in motion',
    body: 'She follows the places as much as the person. Your product is seen somewhere she wants to be.',
  },
  {
    k: 'Experience-first',
    label: 'how she spends',
    body: 'She books the retreat, the treatment, the plunge. Wellness is a line in her budget, not an impulse buy.',
  },
  {
    k: 'Global',
    label: 'not local',
    body: 'Which matters if you ship internationally, run retreats, or sell a destination rather than a shelf.',
  },
];

// ── Content pillars — with the brand categories that belong in each ──
const pillars = [
  {
    n: '01',
    t: 'Recovery & contrast therapy',
    d: 'Sauna, ice bath, cold plunge. The swing between heat and cold, and why it is the part people actually stick to.',
    fits: 'Saunas · plunge tubs · recovery tech',
    wide: true,
  },
  {
    n: '02',
    t: 'Low-cortisol living',
    d: 'Nervous system first. Sleep, stress load, slow mornings and the unglamorous basics that move the needle.',
    fits: 'Adaptogens · sleep · magnesium',
  },
  {
    n: '03',
    t: 'Biohacking & longevity',
    d: 'Supplements, protocols and tracking. Tested on myself for weeks before it is ever mentioned out loud.',
    fits: 'Supplements · wearables · diagnostics',
  },
  {
    n: '04',
    t: 'Fitness & movement',
    d: 'Strength, pilates, mobility. Training framed as maintenance of a life, never as punishment for a body.',
    fits: 'Activewear · equipment · studios',
  },
  {
    n: '05',
    t: 'Holistic healing & bodywork',
    d: 'Massage, lymphatic drainage, the treatments that read as maintenance rather than indulgence.',
    fits: 'Clinics · spas · at-home tools',
  },
  {
    n: '06',
    t: 'Wellness travel',
    d: 'Retreats, spas and the destinations built around feeling well — filmed where the audience is already dreaming.',
    fits: 'Hotels · retreats · destinations',
  },
  {
    n: '07',
    t: 'Soft, feminine inspiration',
    d: 'The films on standards, self-respect and becoming her. My highest-reaching work by a distance, and the reason the audience trusts everything else I say.',
    fits: 'Beauty · fragrance · fashion · jewellery',
  },
];

// ── Paid ads vs. a film — the honest contrast ──
const contrast = [
  { them: 'Interrupts someone who did not ask for it.', me: 'Arrives inside content she chose to watch.' },
  { them: 'Skipped in three seconds, then forgotten.', me: 'Saved, sent to a friend, returned to later.' },
  { them: 'Trust borrowed from nothing.', me: 'Trust I spent four months earning, pointed at you.' },
  { them: 'Stops the moment the budget stops.', me: 'Lives on my grid permanently, and the file is yours forever.' },
  { them: 'You rent the creative.', me: 'You own it — run it as ads, on your grid, in email.' },
];

const fits = [
  { img: '/img/collabs/DZMr2wxs_47.jpg', label: 'Recovery & wellness tech' },
  { img: '/img/collabs/DXjGCtWjGYk.jpg', label: 'Supplements & longevity' },
  { img: '/img/collabs/DYv4c-YMHFR.jpg', label: 'Activewear & movement' },
  { img: '/img/collabs/DZzFKFYM2wg.jpg', label: 'Wellness travel & retreats' },
];

const marqueeA = [
  '/img/portraits/DV2vp-hiJzx.jpg', '/img/collabs/best1.jpg', '/img/portraits/DVEQKoVj4DN.jpg',
  '/img/collabs/DY44G_Gs6rU.jpg', '/img/portraits/DW5oFrOGIv_.jpg', '/img/collabs/DZTtOngsOBG.jpg',
];
const marqueeB = [
  '/img/portraits/DXdmLBNFHa8.jpg', '/img/collabs/DZuN-7BMM-v.jpg', '/img/portraits/DXv8snOlDS-.jpg',
  '/img/collabs/DWiLJd-jKed.jpg', '/img/portraits/DWlfa4-lOuC.jpg', '/img/collabs/best3.jpg',
];
const loopA = [...marqueeA, ...marqueeA];
const loopB = [...marqueeB, ...marqueeB];

const steps = [
  { n: '1', t: 'You brief me', d: 'The product, the goal, a rough budget. One email is enough to know if we should talk.' },
  { n: '2', t: 'I build it', d: 'Concept, shoot and edit — woven into my world so it reads as a recommendation, never an ad drop.' },
  { n: '3', t: 'It goes live', d: 'Posted at peak time, then the files and the numbers land in your inbox. Yours from there.' },
];

// ── The questions brands actually ask ──
const faqs = [
  {
    q: 'Do we own the content afterwards?',
    a: 'Yes. Full usage rights across every channel — paid ads, organic social, your website, email — with no renewal fees and no expiry. You get the clean master files, not just the posted version.',
  },
  {
    q: 'How long from brief to live?',
    a: 'Typically two to three weeks from the moment the product is in my hands. Rush timelines are possible for launches, but tell me early so I can hold the slot.',
  },
  {
    q: 'Will it be disclosed as an ad?',
    a: 'Always. Paid partnership label on every piece, without exception. My audience knows when something is paid, which is exactly why they still trust the recommendation.',
  },
  {
    q: 'Do you accept gifted collaborations?',
    a: 'Paid is the default, and it is what this page is for. The exception is a brand I already use and love before anyone reaches out — every so often I will feature something simply because I rate it. That is my call to make rather than a rate to negotiate down to, so if you are approaching me, plan for paid.',
  },
  {
    q: 'Can we get category exclusivity?',
    a: 'Yes, at Ambassador level. For the length of the partnership I will not take a direct competitor. For single films and campaigns, exclusivity can be added for a defined window.',
  },
  {
    q: 'What do you need from us?',
    a: 'The product, a one-page brief with your goal and key messages, and anything I must say or must avoid. I write the concept and script — that is the part you are hiring me for.',
  },
  {
    q: 'What if a film underperforms?',
    a: 'You get the real numbers either way. No vanity reporting, no screenshots cropped to the good bit. If something underperforms we look at why, and it informs the next one.',
  },
  {
    q: 'Where are you based, and can you shoot on location?',
    a: 'Between Dubai and Bali, and in transit often. Location shoots and hosted stays are possible — say where and when, and we will see if it lines up.',
  },
];
---

<PageLayout
  title="Brand collaborations"
  description="Editorial brand partnerships in wellness, recovery and travel. Reaching women 25–45 who travel and spend on feeling well. 3.5M views in 90 days, 86.8% non-follower reach, content you own outright. Selective, paid."
  eyebrow="Brand collaborations · 2026"
  heading="Let’s put your product"
  italic="in front of women who buy."
  lead="I make content about recovery, low-cortisol living, biohacking and wellness travel, alongside the soft, feminine, inspirational films my audience keeps coming back for. It is made for women aged 25 to 45 who travel often and spend on feeling well. When your product lives inside that world, it reads as a recommendation rather than an ad. Below is exactly who you reach, what you get, and what it is worth."
  byline="Built to this size in 4 months · by personal inquiry · I reply within a day"
  showNewsletter={false}
>
  <!-- ── Collage intro — who you'd work with ── -->
  <div class="mx-auto max-w-6xl px-6">
    <section class="reveal grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="collage">
        <div class="collage-main rounded-[1.75rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
          <img src="/img/portraits/DV2vp-hiJzx.jpg" alt="Allaia Power" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="collage-side rounded-[1.25rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
          <img src="/img/portraits/DXv8snOlDS-.jpg" alt="Allaia — in transit" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="collage-chip chip-views">
          <p class="font-display italic text-2xl text-terracotta leading-none">3.5M</p>
          <p class="byline text-ink-mute mt-1">views · last 90 days</p>
        </div>
        <div class="collage-chip chip-er">
          <p class="font-display italic text-2xl text-terracotta leading-none">4 months</p>
          <p class="byline text-ink-mute mt-1">to build all of this</p>
        </div>
      </div>
      <div>
        <p class="eyebrow mb-5">Who you’d be working with</p>
        <h2 class="display-sm mb-6">Not an influencer feed. <span class="italic-grad">A point of view.</span></h2>
        <p class="serif-lg text-ink-soft max-w-prose mb-5">
          I take on a few aligned partners a quarter, chosen the way essays are commissioned — so every collaboration actually lands. If your product belongs in a slow, intentional, feminine life, my audience is already primed to want it.
        </p>
        <p class="serif-body text-ink-mute max-w-prose mb-8">Dubai &amp; Bali · always in transit · every inquiry read personally.</p>
        <div class="flex flex-wrap gap-3">
          <span class="fit-pill">Recovery</span><span class="fit-pill">Contrast therapy</span><span class="fit-pill">Low cortisol</span><span class="fit-pill">Biohacking</span><span class="fit-pill">Movement</span><span class="fit-pill">Wellness travel</span>
        </div>
      </div>
    </section>
  </div>

  <!-- ── Proof band — animated counters, each translated for the brand ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">What the numbers buy you</p>
      <h2 class="display-sm mb-10 max-w-2xl">You are not buying a post. You are borrowing trust my audience gives me — <span class="italic-grad">earned one film at a time.</span></h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {proofStats.map((s) => (
          <div class="stat-card rounded-[1.5rem] p-7">
            <p
              class="font-display italic text-5xl text-terracotta leading-none mb-3 tabular-nums"
              data-countup
              data-value={s.value}
              data-display={s.display ?? ''}
              data-suffix={s.suffix ?? ''}
              data-decimals={s.decimals ?? 0}
            >0</p>
            <p class="text-micro uppercase tracking-[0.14em] text-ink font-medium mb-3">{s.label}</p>
            <p class="serif-body text-ink-soft">{s.body}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- ── Who you're reaching — the audience ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal grid lg:grid-cols-[1fr_1.15fr] gap-12 lg:gap-16 items-center">
      <div class="relative aspect-[4/5] rounded-[1.75rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
        <img src="/img/portraits/DVEQKoVj4DN.jpg" alt="Allaia — in transit" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/75 via-transparent to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-7">
          <p class="byline text-white/70 mb-2">Her, roughly</p>
          <p class="font-display italic text-3xl sm:text-4xl text-white leading-tight">
            Travels often. Books the treatment. Reads the label.
          </p>
        </div>
      </div>
      <div>
        <p class="eyebrow mb-5">Who you’re reaching</p>
        <h2 class="display-sm mb-6">Women 25 to 45 who travel — <span class="italic-grad">and spend on feeling well.</span></h2>
        <p class="serif-lg text-ink-soft max-w-prose mb-9">
          This is not a general lifestyle audience with a wellness hobby. She plans trips around retreats, pays for the sauna membership, and researches a supplement before she buys it. If that is who you are trying to reach, she is already here.
        </p>
        <div class="grid sm:grid-cols-2 gap-3">
          {audience.map((a) => (
            <div class="aud-card rounded-2xl p-5">
              <p class="font-display text-2xl text-ink leading-none mb-1">{a.k}</p>
              <p class="text-micro uppercase tracking-[0.16em] text-terracotta mb-3">{a.label}</p>
              <p class="serif-body text-ink-soft">{a.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- ── Content pillars — does your product belong here ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">What the content is about</p>
      <h2 class="display-sm mb-4 max-w-2xl">Seven pillars. <span class="italic-grad">Your product has to belong in one.</span></h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        I do not take products that need explaining to my audience. If yours sits inside one of these, it lands without friction — because she is already watching me for exactly this.
      </p>
      <div class="pillar-grid">
        {pillars.map((p) => (
          <article class={`pillar-card rounded-[1.5rem] p-7 ${p.wide ? 'pillar-wide' : ''}`}>
            <p class="byline text-terracotta tabular-nums mb-4">{p.n}</p>
            <h3 class="font-display text-2xl text-ink leading-tight mb-3">{p.t}</h3>
            <p class="serif-body text-ink-soft mb-6 max-w-prose">{p.d}</p>
            <p class="pillar-fits">{p.fits}</p>
          </article>
        ))}
      </div>
    </section>
  </div>

  <!-- ── Brands already featured ── -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">Brands I’ve featured</p>
      <h2 class="display-sm mb-4 max-w-2xl">Already trusted by <span class="italic-grad">hotels, villas and wellness houses.</span></h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        Across Bali, Ubud and Dubai — plus one campaign for Jason Derulo. Every film below is the real post, with the numbers it actually did.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {featuredFilms.map((f) => (
          <article class="film-card rounded-[1.5rem] overflow-hidden flex flex-col">
            <div class="film-embed">
              <iframe
                src={`https://www.instagram.com/reel/${f.code}/embed`}
                title={`${f.brand} — Instagram reel`}
                loading="lazy"
                scrolling="no"
                allowtransparency="true"
                frameborder="0"
              ></iframe>
            </div>

            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-display text-2xl text-ink leading-tight">{f.brand}</h3>
              <p class="byline text-ink-mute mt-1 mb-5">{f.note}</p>

              <div class="film-stats mt-auto">
                <div>
                  <p class="film-stat-n">{fmtViews(f.views)}</p>
