---
import PageLayout from '@layouts/PageLayout.astro';
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import Instagram from '@components/icons/Instagram.astro';

// Top-performing films — from Instagram Insights, ranked by engagement.
const topVids = [
  { img: '/img/collabs/best1.jpg', views: '619K', title: 'Escape The Matrix', er: '11.1%', a: ['51.2K', 'Likes'], b: ['10.9K', 'Saves'], href: 'https://www.instagram.com/reel/DYe7mNNsztZ/' },
  { img: '/img/collabs/best2.jpg', views: '540K', title: 'Which one are you?', er: '5.7%', a: ['18.3K', 'Shares'], b: ['11K', 'Likes'], href: 'https://www.instagram.com/reel/DVk_FqaDKjT/' },
  { img: '/img/collabs/best3.jpg', views: '212K', title: 'She’s a dangerous breed', er: '9.5%', a: ['9.6K', 'Shares'], b: ['9.1K', 'Likes'], href: 'https://www.instagram.com/reel/DWk5dvejGdm/' },
];

const moreVids = [
  { img: '/img/collabs/DVWZkB9CNfh.jpg', views: '260K', title: 'Competency is the standard', href: 'https://www.instagram.com/reel/DVWZkB9CNfh/' },
  { img: '/img/collabs/DZTtOngsOBG.jpg', views: '221K', title: 'On high standards', href: 'https://www.instagram.com/reel/DZTtOngsOBG/' },
  { img: '/img/collabs/DVeBLwTD_Vs.jpg', views: '193K', title: 'Living in Dubai', href: 'https://www.instagram.com/reel/DVeBLwTD_Vs/' },
  { img: '/img/collabs/DZTyZlzMrJO.jpg', views: '151K', title: 'You are not your record', href: 'https://www.instagram.com/reel/DZTyZlzMrJO/' },
  { img: '/img/collabs/DXwOfqdM_N0.jpg', views: '144K', title: 'The most expensive thing you can wear', href: 'https://www.instagram.com/reel/DXwOfqdM_N0/' },
  { img: '/img/collabs/DY44G_Gs6rU.jpg', views: '133K', title: 'You’re THAT girl', href: 'https://www.instagram.com/reel/DY44G_Gs6rU/' },
  { img: '/img/collabs/DZuN-7BMM-v.jpg', views: '129K', title: 'Divine femininity', href: 'https://www.instagram.com/reel/DZuN-7BMM-v/' },
  { img: '/img/collabs/DVoRu4mD4x-.jpg', views: '128K', title: 'Say something positive', href: 'https://www.instagram.com/reel/DVoRu4mD4x-/' },
  { img: '/img/collabs/DZ9eoxeMeEL.jpg', views: '93K', title: 'The power of keeping to yourself', href: 'https://www.instagram.com/reel/DZ9eoxeMeEL/' },
  { img: '/img/collabs/DZClhdhs7l7.jpg', views: '86K', title: 'Dinner at Ferro Ubud', href: 'https://www.instagram.com/reel/DZClhdhs7l7/' },
  { img: '/img/collabs/DVi81w7Euqt.jpg', views: '76K', title: 'On uncertainty', href: 'https://www.instagram.com/reel/DVi81w7Euqt/' },
  { img: '/img/collabs/DWdaXwVDP97.jpg', views: '73K', title: 'As long as you don’t try me', href: 'https://www.instagram.com/reel/DWdaXwVDP97/' },
  { img: '/img/collabs/DZheN1usVSX.jpg', views: '72K', title: 'Nothing casual in my world', href: 'https://www.instagram.com/reel/DZheN1usVSX/' },
  { img: '/img/collabs/DWWc7c4iBsO.jpg', views: '70K', title: 'Says who?', href: 'https://www.instagram.com/reel/DWWc7c4iBsO/' },
  { img: '/img/collabs/DWiLJd-jKed.jpg', views: '67K', title: 'My fiery women', href: 'https://www.instagram.com/reel/DWiLJd-jKed/' },
  { img: '/img/collabs/DZ2wUWgsrun.jpg', views: '57K', title: 'The right one', href: 'https://www.instagram.com/reel/DZ2wUWgsrun/' },
  { img: '/img/collabs/DXjGCtWjGYk.jpg', views: '56K', title: 'Elegance is a mindset', href: 'https://www.instagram.com/reel/DXjGCtWjGYk/' },
  { img: '/img/collabs/DZMr2wxs_47.jpg', views: '51K', title: 'She puts herself first', href: 'https://www.instagram.com/reel/DZMr2wxs_47/' },
  { img: '/img/collabs/DV5zoz6COoG.jpg', views: '42K', title: 'Only Dubai expats relate', href: 'https://www.instagram.com/reel/DV5zoz6COoG/' },
  { img: '/img/collabs/DYv4c-YMHFR.jpg', views: '40K', title: 'The love you give', href: 'https://www.instagram.com/reel/DYv4c-YMHFR/' },
  { img: '/img/collabs/DZzFKFYM2wg.jpg', views: '37K', title: 'For my fellow fairies', href: 'https://www.instagram.com/reel/DZzFKFYM2wg/' },
];

// Value props — spoken straight to the brand.
const valueProps = [
  { k: '86.8%', label: 'of my reach is non-followers', body: 'Your product lands in front of people discovering it for the first time — new buyers, not just my regulars.' },
  { k: '11.1%', label: 'peak engagement rate', body: 'Well above the 1–3% most sponsored content sees. My audience does not scroll past. They stop, save and act.' },
  { k: '619K', label: 'views on a single film', body: 'Six-figure reach is not a one-off here — it is the baseline you would be buying into.' },
  { k: '100%', label: 'yours to keep', body: 'You own every frame. Run it as paid ads, on your own grid, in your emails — wherever it works hardest for you.' },
];

const deliverables = [
  'A concept and script built around your product, not bolted onto it',
  'Shot, lit and edited to editorial standard — my aesthetic, your brand',
  'Posted natively to my feed at peak time',
  'Full usage rights for your paid and organic channels',
  'A performance recap once it has run, so you see exactly what you got',
];

const steps = [
  { n: '01', t: 'You brief me', d: 'Send the product, the goal and a rough budget. A line about you and why you reached out is enough to know if we should talk.' },
  { n: '02', t: 'I build it', d: 'I concept, shoot and edit it into my world — so it reads as something I genuinely reach for, never an ad drop.' },
  { n: '03', t: 'It goes live', d: 'It posts to my feed, then you get the files and the numbers. Simple, and entirely in your hands after.' },
];

const fits = [
  'Wellness, supplements & functional food',
  'Beauty, skincare & at-home devices',
  'Activewear, movement & recovery',
  'Slow living, travel, home & hospitality',
];

const marquee = [
  '/img/portraits/DV2vp-hiJzx.jpg', '/img/collabs/best1.jpg', '/img/portraits/DVEQKoVj4DN.jpg',
  '/img/collabs/DY44G_Gs6rU.jpg', '/img/portraits/DW5oFrOGIv_.jpg', '/img/collabs/DZTtOngsOBG.jpg',
  '/img/portraits/DXdmLBNFHa8.jpg', '/img/collabs/DZuN-7BMM-v.jpg', '/img/portraits/DXv8snOlDS-.jpg',
  '/img/collabs/DWiLJd-jKed.jpg',
];
const marqueeLoop = [...marquee, ...marquee];
---

<PageLayout
  title="Brand collaborations"
  description="Selective, editorial brand partnerships — wellness, beauty and lifestyle. Real reach, real engagement, content you own. Paid only."
  eyebrow="Brand collaborations · 2026"
  heading="Let’s put your product"
  italic="in front of women who buy."
  lead="If you run a wellness, beauty or lifestyle brand, here is the short version: I make content that women save and send to their friends — and when your product lives inside it, it reads as a recommendation, not an ad. Selective, editorial, paid."
  byline="By personal inquiry · I read and reply to every one within a week"
>
  <!-- Straight-talk value props -->
  <div class="mx-auto max-w-6xl px-6">
    <section class="reveal">
      <p class="eyebrow mb-5">Why this works for you</p>
      <h2 class="display-sm mb-10 max-w-2xl">You are not buying a post. You are borrowing <span class="italic-grad">trust I spent years earning.</span></h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10">
        {valueProps.map((v) => (
          <div class="border-t border-ink/10 pt-5">
            <p class="font-display italic text-4xl text-terracotta leading-none mb-2">{v.k}</p>
            <p class="byline text-ink-mute mb-3">{v.label}</p>
            <p class="serif-body text-ink-soft">{v.body}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Portrait + register -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <figure class="relative">
        <div class="relative aspect-[4/5] rounded-[1.5rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
          <img src="/img/portraits/DV2vp-hiJzx.jpg" alt="Allaia Power" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
        </div>
      </figure>
      <div>
        <p class="eyebrow mb-5">Who you’d be working with</p>
        <h2 class="display-sm mb-6">Not an influencer feed. <span class="italic-grad">A point of view.</span></h2>
        <p class="serif-lg text-ink-soft max-w-prose mb-5">
          I take on only a few aligned partners a quarter, chosen the way essays are commissioned — so every collaboration actually lands. If your product genuinely belongs in a slow, intentional, feminine life, my audience is already primed to want it.
        </p>
        <p class="serif-body text-ink-mute max-w-prose">Based between Dubai &amp; Bali · always in transit · every inquiry read personally.</p>
      </div>
    </section>
  </div>

  <!-- Most-watched -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">See it for yourself · most-watched</p>
      <h2 class="display-sm mb-4">This is what happens <span class="italic-grad">when I post.</span></h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        My three highest-engagement films. Picture your product in the middle of one of these. Tap any to watch the original.
      </p>
      <div class="grid sm:grid-cols-3 gap-5">
        {topVids.map((v) => (
          <a href={v.href} target="_blank" rel="noopener" class="group block">
            <div class="relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
              <img src={v.img} alt={v.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.04]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent"></div>
              <span class="absolute right-4 top-4 rounded-full bg-cream/90 px-2.5 py-1 text-micro font-medium text-ink">{v.er} ER</span>
              <p class="absolute left-4 top-4 font-display italic text-3xl text-white/95">{v.views}</p>
              <div class="absolute inset-x-0 bottom-0 p-4">
                <p class="byline text-white/70 mb-1">Instagram · views</p>
                <p class="font-display text-white text-lg leading-tight">{v.title}</p>
              </div>
            </div>
            <div class="mt-3 grid grid-cols-2 gap-3">
              <div><p class="font-display text-2xl text-ink">{v.a[0]}</p><p class="byline text-ink-mute">{v.a[1]}</p></div>
              <div><p class="font-display text-2xl text-ink">{v.b[0]}</p><p class="byline text-ink-mute">{v.b[1]}</p></div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>

  <!-- Case study spotlight -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal rounded-[1.75rem] overflow-hidden bg-ink text-cream">
      <div class="grid lg:grid-cols-[0.85fr_1.15fr] items-stretch">
        <div class="relative min-h-[360px]">
          <img src="/img/collabs/best1.jpg" alt="Escape The Matrix" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/70 to-transparent lg:bg-gradient-to-r"></div>
        </div>
        <div class="p-8 sm:p-12">
          <p class="eyebrow text-terracotta mb-5">One film · a closer look</p>
          <h2 class="display-sm text-cream mb-6">619K views. 10.9K saves. <span class="italic text-terracotta">And most of it strangers.</span></h2>
          <p class="serif-body text-cream/75 max-w-prose mb-8">
            Here is the part that matters for you: nearly 87% of my reach is people who don’t follow me yet. So a film like this doesn’t just preach to my choir — it carries your product to hundreds of thousands of new women who are discovering it, saving it, and sending it on. That is top-of-funnel and trust in the same post.
          </p>
          <div class="grid grid-cols-3 gap-6">
            <div><p class="font-display italic text-3xl text-terracotta">619K</p><p class="byline text-cream/60 mt-1">Views</p></div>
            <div><p class="font-display italic text-3xl text-terracotta">10.9K</p><p class="byline text-cream/60 mt-1">Saves</p></div>
            <div><p class="font-display italic text-3xl text-terracotta">11.1%</p><p class="byline text-cream/60 mt-1">Engagement</p></div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <!-- The library -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">The library</p>
      <h2 class="display-sm mb-4">Not one lucky hit.</h2>
      <p class="serif-body text-ink-soft max-w-prose mb-10">
        A steady run of films landing six figures — so you are betting on a pattern, not a fluke. A sample below; the rest lives on Instagram.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {moreVids.map((v) => (
          <a href={v.href} target="_blank" rel="noopener" class="group block">
            <div class="relative aspect-[9/16] rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
              <img src={v.img} alt={v.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-[1.05]" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent"></div>
              <span class="absolute left-3 top-3 rounded-full bg-cream/90 px-2.5 py-1 text-micro font-medium text-ink">{v.views}</span>
              <p class="absolute inset-x-0 bottom-0 p-3 font-display text-white text-sm leading-tight">{v.title}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-10">
        <a href={site.instagram} target="_blank" rel="noopener" class="cta-ghost">
          <Instagram size={13} /> <span>See it all on Instagram</span> <ArrowUpRight size={12} />
        </a>
      </div>
    </section>
  </div>

  <!-- Full-bleed world -->
  <section class="reveal mt-20 sm:mt-28 overflow-hidden">
    <div class="mx-auto max-w-6xl px-6 mb-10">
      <p class="eyebrow mb-5">The world you’d step into</p>
      <h2 class="display-sm max-w-2xl">This is the room your product gets to live in.</h2>
    </div>
    <div class="collab-marquee-mask">
      <div class="collab-marquee">
        {marqueeLoop.map((src) => (
          <div class="collab-tile rounded-[1.1rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
            <img src={src} alt="Allaia" class="w-full h-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Receipts -->
  <div class="mx-auto max-w-3xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">The numbers you’d be buying · last 90 days</p>
      <h2 class="display-sm mb-7">Real receipts. <span class="italic-grad">No vanity metrics.</span></h2>
      <div class="grid sm:grid-cols-3 gap-6 mb-6">
        <div>
          <p class="byline text-ink-mute mb-2">Views</p>
          <p class="font-display italic text-3xl text-terracotta">3.4M</p>
          <p class="byline text-ink-mute mt-2">Instagram</p>
        </div>
        <div>
          <p class="byline text-ink-mute mb-2">Unique reach</p>
          <p class="font-display italic text-3xl text-terracotta">1.74M</p>
          <p class="byline text-ink-mute mt-2">86.8% non-follower</p>
        </div>
        <div>
          <p class="byline text-ink-mute mb-2">Audience</p>
          <p class="font-display italic text-3xl text-terracotta">86%</p>
          <p class="byline text-ink-mute mt-2">women, 25–34 majority</p>
        </div>
      </div>
      <p class="byline text-ink-mute">Top cities — Delhi · Bangalore · Dubai · Mumbai · UK · SEA</p>
    </section>
  </div>

  <!-- What you get -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal grid lg:grid-cols-2 gap-10 lg:gap-16">
      <div>
        <p class="eyebrow mb-5">What you walk away with</p>
        <h2 class="display-sm mb-6">Everything, <span class="italic-grad">done properly.</span></h2>
        <p class="serif-body text-ink-soft max-w-prose">
          One partnership, handled end to end by me — no agency layers, no telephone game. Here is exactly what lands in your hands.
        </p>
      </div>
      <ul class="space-y-4">
        {deliverables.map((d) => (
          <li class="flex items-start gap-4 border-t border-ink/10 pt-4">
            <span class="text-terracotta mt-1 shrink-0"><ArrowUpRight size={14} /></span>
            <span class="serif-lg text-ink-soft">{d}</span>
          </li>
        ))}
      </ul>
    </section>
  </div>

  <!-- How it works -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">How we’d work together</p>
      <h2 class="display-sm mb-10">Three steps. <span class="italic-grad">No friction.</span></h2>
      <div class="grid md:grid-cols-3 gap-8">
        {steps.map((s) => (
          <div class="border-t border-ink/10 pt-5">
            <p class="font-display italic text-4xl text-terracotta leading-none mb-4">{s.n}</p>
            <h3 class="font-display text-xl text-ink mb-2">{s.t}</h3>
            <p class="serif-body text-ink-soft">{s.d}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Brand fit -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">You’re a fit if</p>
      <h2 class="display-sm mb-10 max-w-2xl">Your product belongs in a considered, feminine life.</h2>
      <div class="grid sm:grid-cols-2 gap-x-10 gap-y-6">
        {fits.map((f) => (
          <p class="flex items-center gap-4 border-t border-ink/10 pt-5 font-display text-2xl text-ink">
            <span class="text-terracotta text-base">✦</span> {f}
          </p>
        ))}
      </div>
    </section>
  </div>

  <!-- What I stand for -->
  <div class="mx-auto max-w-6xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">What I stand for</p>
      <h2 class="display-sm mb-4">And where your brand fits inside it.</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-9 mt-10">
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">Feminine power</h3><p class="serif-body text-ink-soft">A natural home for brands speaking to women’s strength and softness.</p></div>
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">Somatic healing</h3><p class="serif-body text-ink-soft">Nervous-system and body work that wellness and supplement partners slot into cleanly.</p></div>
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">Wellness &amp; movement</h3><p class="serif-body text-ink-soft">Fitness as devotion — the right fit for activewear, equipment and nutrition.</p></div>
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">The soft life</h3><p class="serif-body text-ink-soft">Slow mornings and intentional living — where lifestyle, travel and home brands belong.</p></div>
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">Clean eating</h3><p class="serif-body text-ink-soft">Nourishment that makes food and drink brands read as self-respect, not a sponsorship.</p></div>
        <div class="border-t border-ink/10 pt-5"><h3 class="font-display text-xl text-ink mb-2">Beautymaxxing</h3><p class="serif-body text-ink-soft">Skin, glow and daily ritual — a believable stage for beauty and skincare launches.</p></div>
      </div>
    </section>
  </div>

  <!-- CTA -->
  <div class="mx-auto max-w-3xl px-6 mt-20 sm:mt-28">
    <section class="reveal">
      <p class="eyebrow mb-5">To work together</p>
      <h2 class="display-sm mb-6">Tell me what you’re <span class="italic-grad">launching.</span></h2>
      <p class="serif-body text-ink-soft max-w-prose mb-8">
        A line about you, why you reached out, a rough scope and budget range. That is enough for me to know if we should talk — and to come back with a tailored quote. Press inquiries welcome.
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark justify-center !py-5">
          <Instagram size={13} /> <span>DM @allaia.power</span> <ArrowUpRight size={12} />
        </a>
        <a href={`mailto:${site.email}?subject=Brand%20partnership`} class="cta-ghost justify-center !py-5">
          <span>Or send an email</span> <ArrowUpRight size={12} />
        </a>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .collab-marquee-mask {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .collab-marquee {
    display: flex;
    gap: 1rem;
    width: max-content;
    padding-inline: 1rem;
    animation: collab-scroll 46s linear infinite;
  }
  .collab-tile {
    width: clamp(150px, 15vw, 230px);
    aspect-ratio: 4 / 5;
    flex: 0 0 auto;
  }
  .collab-tile img { display: block; }
  @keyframes collab-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .collab-marquee { animation: none; }
  }
</style>
