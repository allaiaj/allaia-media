---
// Bridge from Allaia's personal brand site to Blacklyne - the studio
// she runs as COO. Coaching + consulting stay here. Execution lives
// over there.

const studioOffer = [
  {
    n: "01",
    title: "Conversion-first websites",
    body: "Modern stack, mobile-first, SEO-ready. Live in a day, kept live by retainer.",
  },
  {
    n: "02",
    title: "Local SEO + Google Business",
    body: "Listing rebuild, weekly posts, citation cleanup. Top of the map pack as the default state.",
  },
  {
    n: "03",
    title: "Social production",
    body: "Reels, posts, captions, DMs - production team that ships weekly so your feed isn't a side project.",
  },
  {
    n: "04",
    title: "Meta Ads with real ROAS",
    body: "Creative + audience + funnel + weekly iteration. Honest reporting, no slide-deck theatre.",
  },
];
---

<section
  id="studio"
  class="relative scroll-mt-24 py-24 sm:py-32 isolate overflow-hidden"
>
  <!-- Dark inverse panel so the bridge feels intentional, not an afterthought -->
  <div class="mx-auto max-w-6xl px-6">
    <div
      class="reveal relative overflow-hidden rounded-3xl"
      style="background: linear-gradient(160deg, #0a0a0a 0%, #1a1814 60%, #2a2722 100%); box-shadow: 0 40px 120px -30px rgba(124,58,237,0.35);"
    >
      <!-- Accent washes inside the dark panel -->
      <div
        class="pointer-events-none absolute inset-0 opacity-55"
        style="background: radial-gradient(ellipse 50% 60% at 85% 10%, rgba(167,139,250,0.55), transparent 70%), radial-gradient(ellipse 50% 50% at 10% 90%, rgba(251,182,206,0.4), transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative grid lg:grid-cols-[1.05fr_1fr] gap-10 lg:gap-16 p-8 sm:p-12 lg:p-16">
        <!-- Left: the bridge story -->
        <div class="text-ink-50">
          <p class="text-[11px] uppercase tracking-[0.22em] text-accent-bright mb-4">
            The studio side · I'm COO
          </p>

          <h2 class="display text-4xl sm:text-5xl lg:text-6xl font-medium" style="letter-spacing: -0.03em; line-height: 1.02;">
            <span class="text-ink-50">If you need the build,</span><br />
            <span class="font-serif italic text-gradient-accent">that lives at Blacklyne.</span>
          </h2>

          <p class="mt-7 text-base sm:text-lg text-ink-200 leading-relaxed max-w-lg">
            This site is for the coaching and consulting work I do
            personally. For the execution - websites, social, ads, local
            SEO - the studio I run as COO handles that. Same eye for
            taste. Different team behind it.
          </p>

          <p class="mt-4 text-base text-ink-300 leading-relaxed max-w-lg">
            If you came here looking to hire a team to ship the work
            rather than coach you through it, send them across.
          </p>

          <!-- CTAs out to blacklyne -->
          <div class="mt-9 flex flex-col sm:flex-row gap-3">
            <a
              href="https://blacklyne.ai"
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center justify-center gap-2 rounded-lg bg-white px-5 py-3 text-sm font-medium text-ink-900 hover:scale-[1.02] transition-transform"
            >
              Visit blacklyne.ai
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a
              href="https://blacklyne.ai/#contact"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/25 bg-white/5 backdrop-blur-sm px-5 py-3 text-sm font-medium text-ink-50 hover:bg-white/10 transition-colors"
            >
              Brief the studio
            </a>
          </div>
        </div>

        <!-- Right: what they ship -->
        <div>
          <p class="text-[11px] uppercase tracking-[0.22em] text-accent-bright mb-5">
            What the studio ships
          </p>
          <ul class="space-y-5">
            {
              studioOffer.map((s) => (
                <li class="flex gap-4 pb-5 border-b border-white/10 last:border-b-0 last:pb-0">
                  <span class="font-mono text-[10px] text-ink-400 tracking-wider pt-1 flex-none w-6">
                    {s.n}
                  </span>
                  <div>
                    <h3 class="text-base sm:text-lg font-medium text-ink-50 tracking-tight">
                      {s.title}
                    </h3>
                    <p class="mt-1.5 text-[14px] text-ink-300 leading-relaxed">
                      {s.body}
                    </p>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p class="reveal mt-6 text-center text-xs text-ink-500">
      Two brands, one taste. Built so the work you need has the right home.
    </p>
  </div>
</section>
