---
import { site } from "../data/site";
---

<section class="relative isolate overflow-hidden pt-32 sm:pt-40 pb-20 sm:pb-28">
  <!-- Parallax accent blobs - drift with mouse for depth -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      data-parallax="35"
      class="absolute left-1/2 top-1/3 h-[70vh] w-[70vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-55 blur-[100px] will-change-transform"
      style="background: radial-gradient(circle, rgba(167,139,250,0.5) 0%, transparent 60%);"
    ></div>
    <div
      data-parallax="22"
      class="absolute left-[6%] top-[18%] h-44 w-44 rounded-full opacity-60 blur-[60px] will-change-transform hidden sm:block"
      style="background: radial-gradient(circle, rgba(251,182,206,0.75) 0%, transparent 70%);"
    ></div>
    <div
      data-parallax="-28"
      class="absolute right-[5%] top-[55%] h-56 w-56 rounded-full opacity-55 blur-[70px] will-change-transform hidden sm:block"
      style="background: radial-gradient(circle, rgba(254,205,170,0.7) 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <!-- Status pill -->
    <div class="reveal flex mb-8">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white/80 backdrop-blur-sm px-3 py-1.5 text-[12px] text-ink-700">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        </span>
        <span>Now booking · 1:1 coaching + brand partnerships for 2026</span>
      </div>
    </div>

    <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-10 lg:gap-14 items-end">
      <!-- Left: founder intro -->
      <div>
        <p class="reveal mb-5 text-[12px] uppercase tracking-[0.22em] text-ink-500">
          Founder · creator · personal brand coach
        </p>

        <h1
          class="reveal text-[clamp(2.75rem,8.5vw,7rem)] font-semibold text-ink-900"
          style="letter-spacing: -0.035em; line-height: 0.98;"
        >
          Hi, I'm
          <span class="font-serif italic font-normal text-gradient-violet ml-1">Allaia</span>.
        </h1>

        <p class="reveal mt-7 max-w-xl text-base sm:text-lg text-ink-700 leading-relaxed">
          I help founders, creators, and lifestyle brands build the
          systems and the <em class="font-serif not-italic text-ink-900 font-medium">name</em> that compound over time -
          1:1 coaching, hand-picked brand partnerships, and a small studio behind it all.
        </p>

        <!-- CTA row -->
        <div class="reveal mt-9 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <a
            href="#coaching"
            class="group inline-flex items-center justify-center gap-2 rounded-lg bg-ink-900 px-5 py-3 text-sm font-medium text-white hover:bg-ink-800 transition-colors"
          >
            <span>Coach me</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
              <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="#brand-collabs"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink-300 bg-white/70 backdrop-blur-sm px-5 py-3 text-sm font-medium text-ink-900 hover:bg-white transition-colors"
          >
            <span>Brand collabs</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <p class="reveal mt-6 text-xs text-ink-500">
          ★★★★★ &nbsp;5.0 from the founders I've coached &nbsp;·&nbsp; Reply within 4h on WhatsApp
        </p>
      </div>

      <!-- Right: founder portrait placeholder -->
      <div class="reveal relative">
        <!-- Portrait frame with violet ring + soft glow -->
        <div
          class="relative aspect-[4/5] w-full max-w-md mx-auto rounded-[2rem] overflow-hidden shimmer-border"
          style="box-shadow: 0 40px 120px -30px rgba(124,58,237,0.4), 0 1px 0 rgb(255 255 255 / 0.9) inset;"
        >
          <!-- Placeholder background: soft mesh gradient -->
          <div
            class="absolute inset-0"
            style="background:
              radial-gradient(circle at 30% 20%, rgba(251,207,232,0.9), transparent 55%),
              radial-gradient(circle at 75% 80%, rgba(167,139,250,0.85), transparent 60%),
              radial-gradient(circle at 50% 50%, rgba(254,215,170,0.7), transparent 70%),
              linear-gradient(135deg, #fdfaff, #faf6ff);"
          ></div>

          <!-- Placeholder text - swap this whole .placeholder block for an <img> when you have the portrait -->
          <div class="placeholder absolute inset-0 flex flex-col items-center justify-center text-center px-6">
            <span class="font-serif italic text-7xl sm:text-8xl text-ink-900/85 leading-none">a</span>
            <p class="mt-6 text-[10px] uppercase tracking-[0.24em] text-ink-700/80">
              Founder portrait
            </p>
            <p class="mt-2 text-[11px] text-ink-700/70 leading-snug max-w-[220px]">
              Drop your hero shot here - editorial, 4:5, natural light.
            </p>
          </div>

          <!-- Subtle grain overlay for depth -->
          <div
            class="pointer-events-none absolute inset-0 mix-blend-multiply opacity-15"
            style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
          ></div>
        </div>

        <!-- Floating tag chips around portrait -->
        <div class="hidden sm:block absolute -left-4 top-12 surface px-3 py-1.5 rounded-full text-[11px] text-ink-900 font-medium" style="transform: rotate(-6deg);">
          Coaching · 1:1
        </div>
        <div class="hidden sm:block absolute -right-3 top-1/3 surface px-3 py-1.5 rounded-full text-[11px] text-ink-900 font-medium" style="transform: rotate(5deg);">
          Brand partner
        </div>
        <div class="hidden sm:block absolute -left-2 bottom-20 surface px-3 py-1.5 rounded-full text-[11px] text-ink-900 font-medium" style="transform: rotate(-3deg);">
          Studio behind it
        </div>
      </div>
    </div>

    <!-- Trust strip / metrics -->
    <div class="reveal mt-16 sm:mt-20 grid grid-cols-2 md:grid-cols-4 gap-px overflow-hidden rounded-2xl border border-ink-200 bg-ink-200">
      {[
        { final: "500+", target: 500, suffix: "+", l: "brands I've helped" },
        { final: "1:1", target: 1, suffix: ":1", l: "every coaching call" },
        { final: "5", target: 5, suffix: "", l: "markets I work across" },
        { final: "4.8x", target: 4.8, suffix: "x", l: "average meta roas", decimals: 1 },
      ].map((m) => (
        <div class="relative px-5 py-6 sm:py-8 text-center sm:text-left bg-white">
          <div
            class="font-semibold text-3xl sm:text-4xl text-gradient-violet tracking-tight tabular-nums"
            data-counter
            data-target={m.target}
            data-suffix={m.suffix}
            data-decimals={m.decimals ?? 0}
            data-final={m.final}
          >
            0{m.suffix}
          </div>
          <div class="mt-1.5 text-[11px] uppercase tracking-[0.18em] text-ink-500">
            {m.l}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    function animateCounter(el: HTMLElement) {
      if (el.dataset.counted === "1") return;
      el.dataset.counted = "1";
      const target = parseFloat(el.dataset.target || "0");
      const decimals = parseInt(el.dataset.decimals || "0");
      const suffix = el.dataset.suffix || "";
      const finalText =
        el.dataset.final || target.toFixed(decimals) + suffix;
      const duration = 2400;
      const start = performance.now();
      const tick = (now: number) => {
        const elapsed = now - start;
        const ratio = Math.min(1, elapsed / duration);
        const current = target * easeOut(ratio);
        if (ratio >= 1) {
          el.textContent = finalText;
        } else {
          el.textContent = current.toFixed(decimals) + suffix;
        }
        if (ratio < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    function setupCounters() {
      const counters =
        document.querySelectorAll<HTMLElement>("[data-counter]");
      if (!counters.length) return;

      const triggerInView = () => {
        counters.forEach((el) => {
          if (el.dataset.counted === "1") return;
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            animateCounter(el);
          }
        });
      };

      setTimeout(triggerInView, 600);

      if ("IntersectionObserver" in window) {
        const obs = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                animateCounter(entry.target as HTMLElement);
                obs.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 }
        );
        counters.forEach((el) => obs.observe(el));
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupCounters);
    } else {
      setupCounters();
    }
  </script>
</section>
