---
import { site } from "../data/site";
---

<section class="relative isolate overflow-hidden pt-36 sm:pt-44 pb-20 sm:pb-28">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Status pill -->
    <div class="reveal flex justify-center mb-8">
      <div class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-3 py-1.5 text-[12px] text-ink-700">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        </span>
        <span>Now booking · 500+ founder-led brands trust us</span>
      </div>
    </div>

    <!-- Headline - bold solid, gradient italic accent on the closing phrase -->
    <h1 class="reveal display-tight mx-auto max-w-4xl text-center text-[clamp(2.5rem,8vw,6.5rem)] font-semibold text-ink-900">
      The systems behind brands <span class="font-serif italic font-normal text-gradient-violet">that grow.</span>
    </h1>

    <!-- Sub -->
    <p class="reveal mt-7 mx-auto max-w-2xl text-center text-base sm:text-lg text-ink-600 leading-relaxed">
      We build the unsexy infrastructure - web, ads, content, search - that turns founder-led brands into compounding revenue. No retainers. No theatre. One operator on WhatsApp.
    </p>

    <!-- CTA row -->
    <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href={site.cal}
        target="_blank"
        rel="noopener"
        class="group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg bg-ink-900 px-5 py-3 text-sm font-medium text-white hover:bg-ink-800 transition-colors"
      >
        <span>Book a 30-min discovery</span>
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
          <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a
        href="/services"
        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-lg border border-ink-200 bg-white px-5 py-3 text-sm font-medium text-ink-900 hover:bg-ink-50 transition-colors"
      >
        See what we build
      </a>
    </div>

    <!-- Tiny trust line -->
    <p class="reveal mt-6 text-center text-xs text-ink-500">
      ★★★★★ &nbsp;5.0 across all engagements &nbsp;·&nbsp; Reply within 4h on WhatsApp
    </p>

    <!-- Trust strip / metrics - cleaner SaaS feel, no gradient italic -->
    <div class="reveal mt-16 grid grid-cols-2 md:grid-cols-4 gap-px overflow-hidden rounded-2xl border border-ink-200 bg-ink-200">
      {[
        { final: "500+", target: 500, suffix: "+", l: "brands shipped" },
        { final: "100%", target: 100, suffix: "%", l: "client retention" },
        { final: "7", target: 7, suffix: " days", l: "to website launch" },
        { final: "4.8x", target: 4.8, suffix: "x", l: "average meta roas", decimals: 1 },
      ].map((m) => (
        <div class="relative px-5 py-6 sm:py-8 text-center sm:text-left bg-white">
          <div
            class="font-semibold text-3xl sm:text-4xl text-gradient-violet tracking-tight"
            data-counter
            data-target={m.target}
            data-suffix={m.suffix}
            data-decimals={m.decimals ?? 0}
          >
            {m.final}
          </div>
          <div class="mt-1.5 text-[11px] uppercase tracking-[0.18em] text-ink-500">
            {m.l}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    // Count-up animation for hero metrics
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    function animateCounter(el: HTMLElement) {
      if (el.dataset.counted === "1") return;
      el.dataset.counted = "1";
      const target = parseFloat(el.dataset.target || "0");
      const decimals = parseInt(el.dataset.decimals || "0");
      const suffix = el.dataset.suffix || "";
      const duration = 1800;
      const start = performance.now();
      const tick = (now: number) => {
        const elapsed = now - start;
        const ratio = Math.min(1, elapsed / duration);
        const current = target * easeOut(ratio);
        el.textContent = current.toFixed(decimals) + suffix;
        if (ratio < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    if ("IntersectionObserver" in window && counters.length) {
      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              animateCounter(entry.target as HTMLElement);
              obs.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.4 }
      );
      counters.forEach((el) => obs.observe(el));
    } else {
      counters.forEach(animateCounter);
    }
  </script>

</section>
