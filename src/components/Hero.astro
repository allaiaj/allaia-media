---
import { site } from "../data/site";

const issueDate = "Summer 2026";
const issueVol = "VOL. 26 · NO. 02";
const coverLines = [
  "Inside · The Q3 coaching cohort, by application only.",
  "Field notes · 500+ founder-led brands, four years in.",
  "Partnerships · Hotels, fashion, lifestyle - selectively open.",
];
---

<section class="relative isolate overflow-hidden pt-28 sm:pt-32 pb-16 sm:pb-24">
  <!-- Parallax accents -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      data-parallax="32"
      class="absolute left-1/2 top-1/3 h-[65vh] w-[65vh] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-55 blur-[110px] will-change-transform"
      style="background: radial-gradient(circle, rgba(167,139,250,0.55) 0%, transparent 60%);"
    ></div>
    <div
      data-parallax="-22"
      class="absolute right-[5%] top-[20%] h-44 w-44 rounded-full opacity-60 blur-[70px] will-change-transform hidden sm:block"
      style="background: radial-gradient(circle, rgba(251,182,206,0.8) 0%, transparent 70%);"
    ></div>
    <div
      data-parallax="26"
      class="absolute left-[8%] bottom-[15%] h-52 w-52 rounded-full opacity-55 blur-[80px] will-change-transform hidden sm:block"
      style="background: radial-gradient(circle, rgba(254,205,170,0.7) 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <!-- Masthead bar - publication style -->
    <div class="reveal flex items-baseline justify-between gap-4 pb-4 mb-12 sm:mb-16 border-b border-ink-900/20">
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-900 font-medium">
        Allaia · the diary
      </p>
      <p class="hidden sm:block text-[10px] uppercase tracking-[0.28em] text-ink-500">
        {issueVol} · {issueDate}
      </p>
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-500">
        Founder, on the record
      </p>
    </div>

    <!-- Cover spread -->
    <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-16 items-start">
      <!-- Left: cover photo + cover lines -->
      <div>
        <!-- Portrait placeholder framed like an editorial photo -->
        <figure class="reveal relative">
          <div
            class="relative aspect-[4/5] w-full rounded-[2rem] overflow-hidden"
            style="box-shadow: 0 40px 120px -30px rgba(124,58,237,0.4), 0 1px 0 rgb(255 255 255 / 0.9) inset;"
          >
            <div
              class="absolute inset-0"
              style="background:
                radial-gradient(circle at 30% 20%, rgba(251,207,232,0.95), transparent 55%),
                radial-gradient(circle at 75% 80%, rgba(167,139,250,0.9), transparent 60%),
                radial-gradient(circle at 50% 50%, rgba(254,215,170,0.7), transparent 70%),
                linear-gradient(135deg, #fdfaff, #faf6ff);"
            ></div>

            <div class="placeholder absolute inset-0 flex flex-col items-center justify-center text-center px-6">
              <span class="font-serif italic text-7xl sm:text-8xl text-ink-900/85 leading-none">a</span>
              <p class="mt-6 text-[10px] uppercase tracking-[0.28em] text-ink-700/80">
                Cover · portrait
              </p>
              <p class="mt-2 text-[11px] text-ink-700/70 leading-snug max-w-[220px]">
                Editorial. 4:5. Natural light. Drop your image here.
              </p>
            </div>

            <div
              class="pointer-events-none absolute inset-0 mix-blend-multiply opacity-15"
              style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
            ></div>
          </div>
          <figcaption class="mt-3 text-[10px] uppercase tracking-[0.24em] text-ink-500 flex items-baseline justify-between">
            <span>Photograph · self-portrait</span>
            <span class="hidden sm:inline">FIG. 01</span>
          </figcaption>
        </figure>

        <!-- Cover-line teasers in left margin under the photo -->
        <ul class="reveal mt-7 space-y-3 border-t border-ink-900/15 pt-5">
          {
            coverLines.map((line) => (
              <li class="flex gap-3 text-[12px] sm:text-[13px] text-ink-700 leading-snug">
                <span class="text-ink-400 select-none">→</span>
                <span>{line}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: cover headline + body + CTAs -->
      <div>
        <!-- Status pill -->
        <div class="reveal mb-7">
          <div class="inline-flex items-center gap-2 rounded-full border border-ink-300 bg-white/70 backdrop-blur-sm px-3 py-1.5 text-[11px] text-ink-700">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            </span>
            <span>Reviewing applications · Q3 coaching cohort</span>
          </div>
        </div>

        <!-- Eyebrow / dek -->
        <p class="reveal text-[11px] uppercase tracking-[0.28em] text-ink-500 mb-5">
          The cover story
        </p>

        <!-- Big editorial headline -->
        <h1
          class="reveal font-medium text-ink-900"
          style="font-size: clamp(3rem, 9.5vw, 7.5rem); letter-spacing: -0.04em; line-height: 0.94;"
        >
          <span class="font-serif italic font-normal text-gradient-violet">Allaia</span>,<br />
          on building it
          <span class="font-serif italic font-normal text-gradient-violet">out loud.</span>
        </h1>

        <!-- Dek paragraph with drop-cap on the first letter -->
        <p class="reveal mt-8 text-base sm:text-lg text-ink-800 leading-[1.7] max-w-xl" style="font-feature-settings: 'ss01';">
          <span
            class="float-left font-serif italic text-7xl leading-[0.85] mr-3 mt-1 text-gradient-violet"
            aria-hidden="true"
          >F</span>
          ounder. Coach. Brand consultant. I run a coaching practice for
          women founders and an editorial-style consultancy for brands
          who care about how they're positioned. This page is the cover
          of the diary - the rest of the issue is below.
        </p>

        <!-- Byline + date -->
        <p class="reveal mt-7 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          By <span class="text-ink-900">Allaia</span> &nbsp;·&nbsp;
          London &nbsp;·&nbsp;
          {issueDate}
        </p>

        <!-- CTA row - editorial chips -->
        <div class="reveal mt-9 flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          <a
            href="#coaching"
            class="group inline-flex items-center justify-center gap-2 rounded-lg bg-ink-900 px-5 py-3 text-sm font-medium text-white hover:bg-ink-800 transition-colors"
          >
            <span>Read the coaching offer</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
              <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="#brand-collabs"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-ink-300 bg-white/70 backdrop-blur-sm px-5 py-3 text-sm font-medium text-ink-900 hover:bg-white transition-colors"
          >
            <span>Brand partnerships</span>
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
