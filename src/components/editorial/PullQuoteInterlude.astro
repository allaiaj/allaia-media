---
// Full-bleed italic-gradient pull quote used as dramatic interlude
// between major sections. Adds the magazine-cover punctuation that
// makes the scroll feel cinematic.
interface Props {
  quote: string;
  attribution?: string;
  tone?: 'cream' | 'bone' | 'dark';
}
const { quote, attribution, tone = 'cream' } = Astro.props;

const bg =
  tone === 'dark' ? 'bg-anthracite' :
  tone === 'bone' ? 'bg-bone' :
  'bg-cream';

const isDark = tone === 'dark';
---

<section class={`relative py-28 sm:py-36 lg:py-48 overflow-hidden ${bg}`}>
  <!-- Atmospheric washes -->
  <div class="pointer-events-none absolute inset-0 opacity-50" aria-hidden="true">
    {isDark ? (
      <>
        <div
          class="absolute top-1/3 left-1/4 -translate-x-1/2 -translate-y-1/2 h-[60vh] w-[60vh] rounded-full blur-[140px]"
          style="background: radial-gradient(circle, rgba(184,85,66,0.55), transparent 70%);"
        ></div>
        <div
          class="absolute bottom-0 right-0 h-[50vh] w-[50vh] rounded-full blur-[120px]"
          style="background: radial-gradient(circle, rgba(139,157,126,0.35), transparent 70%);"
        ></div>
      </>
    ) : (
      <>
        <div
          class="absolute top-1/2 left-1/3 -translate-x-1/2 -translate-y-1/2 h-[60vh] w-[60vh] rounded-full blur-[130px]"
          style="background: radial-gradient(circle, rgba(184,85,66,0.25), transparent 70%);"
        ></div>
        <div
          class="absolute bottom-0 right-1/4 h-[40vh] w-[40vh] rounded-full blur-[110px]"
          style="background: radial-gradient(circle, rgba(139,157,126,0.22), transparent 70%);"
        ></div>
      </>
    )}
  </div>

  <!-- Grain overlay -->
  <div
    class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-[0.06]"
    style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <!-- Opening quote glyph -->
    <span
      class="reveal block mb-7 font-display italic font-medium leading-none italic-grad mx-auto"
      style="font-size: clamp(4rem, 9vw, 9rem); letter-spacing: -0.05em;"
      aria-hidden="true"
    >
      "
    </span>

    <blockquote class={`reveal`}>
      <p
        class={`font-display italic font-medium leading-[1.18] ${isDark ? 'text-cream' : 'text-ink'}`}
        style="font-size: clamp(1.875rem, 4.5vw, 3.75rem); letter-spacing: -0.02em;"
      >
        {quote}
      </p>
      {attribution && (
        <p class={`mt-10 byline ${isDark ? 'text-cream/55' : 'text-ink-mute'}`}>
          — {attribution}
        </p>
      )}
    </blockquote>
  </div>
</section>
