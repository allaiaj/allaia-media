---
// Visibility / capture gap calculator - what local-search demand are
// you NOT capturing right now because you're under-ranked, under-
// converting, or both. No automation/reply-bot assumptions - this is
// purely the revenue arithmetic of being more findable + more
// persuasive online.
---

<section id="calculator" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="reveal max-w-3xl mb-12 sm:mb-16">
      <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        The visibility gap · honest math
      </p>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
        <span class="text-ink-900">The demand you're</span><br />
        <span class="font-serif italic text-gradient-violet">not capturing yet.</span>
      </h2>
      <p class="mt-6 text-base text-ink-700 leading-relaxed max-w-2xl">
        People are searching for what you sell. Most of them never land on your site. Most of those who do, bounce. Drag the sliders and see what that gap is worth a year.
      </p>
    </div>

    <div
      class="reveal surface-warm rounded-3xl overflow-hidden"
      data-calc
    >
      <div class="grid lg:grid-cols-[1.05fr_1fr]">
        <!-- Inputs -->
        <div class="p-7 sm:p-10 lg:p-12 border-b lg:border-b-0 lg:border-r border-ink-900/10 bg-white/60">
          <p class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-8">
            Your local market
          </p>

          <!-- Monthly local search demand -->
          <div class="space-y-3">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-sm font-medium text-ink-900" for="calc-demand">
                Monthly local searches for your service
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-demand-out
              >
                1,200
              </output>
            </div>
            <input
              id="calc-demand"
              type="range"
              min="100"
              max="20000"
              step="100"
              value="1200"
              class="calc-slider w-full"
              data-calc-demand
              aria-label="Monthly local searches"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>100</span><span>20,000</span>
            </div>
          </div>

          <!-- Current visibility share -->
          <div class="space-y-3 mt-8 pt-8 border-t border-ink-900/8">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-sm font-medium text-ink-900" for="calc-visibility">
                Of those, % who actually click YOUR listing today
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-visibility-out
              >
                3%
              </output>
            </div>
            <input
              id="calc-visibility"
              type="range"
              min="0.5"
              max="40"
              step="0.5"
              value="3"
              class="calc-slider w-full"
              data-calc-visibility
              aria-label="Click-through share"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>0.5%</span><span>40%</span>
            </div>
            <p class="text-[11px] text-ink-500 leading-snug">
              Below 5% usually means you're stuck on page 2 of Google or don't show up in the local map pack at all.
            </p>
          </div>

          <!-- Site conversion -->
          <div class="space-y-3 mt-8 pt-8 border-t border-ink-900/8">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-sm font-medium text-ink-900" for="calc-conv">
                Site visitor → paying customer
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-conv-out
              >
                2.5%
              </output>
            </div>
            <input
              id="calc-conv"
              type="range"
              min="0.5"
              max="20"
              step="0.1"
              value="2.5"
              class="calc-slider w-full"
              data-calc-conv
              aria-label="Visitor to customer rate"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>0.5%</span><span>20%</span>
            </div>
            <p class="text-[11px] text-ink-500 leading-snug">
              Local service sites typically sit at 1-3%. A conversion-first rebuild lands 6-10%.
            </p>
          </div>

          <!-- Customer value -->
          <div class="space-y-3 mt-8 pt-8 border-t border-ink-900/8">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-sm font-medium text-ink-900" for="calc-value">
                Average customer value (lifetime)
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-value-out
              >
                $400
              </output>
            </div>
            <input
              id="calc-value"
              type="range"
              min="50"
              max="5000"
              step="25"
              value="400"
              class="calc-slider w-full"
              data-calc-value
              aria-label="Average customer value"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>$50</span><span>$5,000</span>
            </div>
          </div>
        </div>

        <!-- Output -->
        <div
          class="relative p-7 sm:p-10 lg:p-12 flex flex-col text-ink-50"
          style="background: linear-gradient(160deg, #0e0d0a 0%, #1a1814 70%, #2a2722 100%);"
        >
          <div
            class="pointer-events-none absolute inset-0 opacity-40"
            style="background: radial-gradient(ellipse 80% 60% at 80% 0%, rgba(167,139,250,0.45), transparent 70%), radial-gradient(ellipse 60% 40% at 20% 100%, rgba(251,182,206,0.35), transparent 70%);"
            aria-hidden="true"
          ></div>

          <div class="relative">
            <p class="text-[11px] uppercase tracking-[0.22em] text-accent-bright mb-3">
              Where you sit today
            </p>
            <div class="grid grid-cols-2 gap-3 mb-7">
              <div class="rounded-xl bg-white/5 px-4 py-3 border border-white/10">
                <p class="text-[10px] uppercase tracking-wider text-ink-400">
                  Customers / yr
                </p>
                <p class="mt-1 font-serif italic text-2xl text-ink-50 tabular-nums">
                  <span data-calc-current-customers>11</span>
                </p>
              </div>
              <div class="rounded-xl bg-white/5 px-4 py-3 border border-white/10">
                <p class="text-[10px] uppercase tracking-wider text-ink-400">
                  Annual revenue
                </p>
                <p class="mt-1 font-serif italic text-2xl text-ink-50 tabular-nums">
                  $<span data-calc-current-rev>4,320</span>
                </p>
              </div>
            </div>

            <p class="text-[11px] uppercase tracking-[0.22em] text-accent-bright mb-3">
              Where Allaia builds you toward
            </p>
            <p class="text-[11px] text-ink-400 mb-2 leading-snug">
              ~12% click share + 7% site conversion. Realistic with full stack live.
            </p>
            <div class="font-serif italic text-5xl sm:text-6xl text-gradient-accent tabular-nums leading-none">
              $<span data-calc-projected-rev>48,384</span>
            </div>
            <p class="mt-2 text-sm text-ink-300">
              projected annual revenue
            </p>

            <div
              class="mt-7 rounded-2xl px-5 py-5"
              style="background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.25);"
            >
              <div class="flex items-start gap-3">
                <span class="mt-1 flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--color-accent);">
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M3 6.2l2 2 4-4.5" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                <div>
                  <p class="text-sm text-ink-50 leading-snug">
                    Annual upside if we close the gap:
                    <span class="font-serif italic text-gradient-accent text-lg">
                      +$<span data-calc-upside>44,064</span>
                    </span>
                  </p>
                  <p class="mt-1 text-xs text-ink-400">
                    Higher click share comes from GBP + local SEO. Higher site conversion comes from a real rebuild. We can address either alone, or both together for compounding effect.
                  </p>
                </div>
              </div>
            </div>

            <a
              href="/contact"
              class="group mt-7 inline-flex items-center justify-center gap-1.5 rounded-lg bg-white px-5 py-3 text-sm font-medium text-ink-900 hover:scale-[1.02] transition-transform"
            >
              Show me the real model
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>

            <p class="mt-4 text-[11px] text-ink-400 leading-relaxed">
              Estimate based on your inputs. Real lift varies by industry, geography, and starting baseline - we model your actuals on the discovery call.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: pointer;
    padding: 4px 0;
  }
  .calc-slider:focus {
    outline: none;
  }
  .calc-slider::-webkit-slider-runnable-track {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent-deep), var(--color-accent), var(--color-accent-glow));
    border-radius: 9999px;
  }
  .calc-slider::-moz-range-track {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent-deep), var(--color-accent), var(--color-accent-glow));
    border-radius: 9999px;
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 9999px;
    background: #ffffff;
    border: 2px solid var(--color-accent);
    margin-top: -9px;
    box-shadow: 0 4px 14px -2px rgb(124 58 237 / 0.5);
    transition: transform 0.15s ease;
  }
  .calc-slider::-webkit-slider-thumb:hover,
  .calc-slider:active::-webkit-slider-thumb {
    transform: scale(1.15);
  }
  .calc-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 9999px;
    background: #ffffff;
    border: 2px solid var(--color-accent);
    box-shadow: 0 4px 14px -2px rgb(124 58 237 / 0.5);
    cursor: pointer;
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-calc]");
  if (root) {
    const demandIn = root.querySelector<HTMLInputElement>("[data-calc-demand]")!;
    const visIn = root.querySelector<HTMLInputElement>("[data-calc-visibility]")!;
    const convIn = root.querySelector<HTMLInputElement>("[data-calc-conv]")!;
    const valueIn = root.querySelector<HTMLInputElement>("[data-calc-value]")!;

    const demandOut = root.querySelector<HTMLElement>(
      "[data-calc-demand-out]"
    )!;
    const visOut = root.querySelector<HTMLElement>(
      "[data-calc-visibility-out]"
    )!;
    const convOut = root.querySelector<HTMLElement>("[data-calc-conv-out]")!;
    const valueOut = root.querySelector<HTMLElement>("[data-calc-value-out]")!;

    const curCust = root.querySelector<HTMLElement>(
      "[data-calc-current-customers]"
    )!;
    const curRev = root.querySelector<HTMLElement>(
      "[data-calc-current-rev]"
    )!;
    const projRev = root.querySelector<HTMLElement>(
      "[data-calc-projected-rev]"
    )!;
    const upside = root.querySelector<HTMLElement>("[data-calc-upside]")!;

    const fmt = (n: number) => Math.round(n).toLocaleString("en-US");

    // Projection targets - realistic upper bounds with full stack live
    const TARGET_VISIBILITY = 12; // 12% click share (GBP top + page-1 organic)
    const TARGET_CONV = 7; // 7% site conversion (good conversion-first build)

    const update = () => {
      const demand = parseFloat(demandIn.value);
      const vis = parseFloat(visIn.value);
      const conv = parseFloat(convIn.value);
      const value = parseFloat(valueIn.value);

      demandOut.textContent = demand.toLocaleString("en-US");
      visOut.textContent = vis + "%";
      convOut.textContent = conv + "%";
      valueOut.textContent = "$" + value.toLocaleString("en-US");

      // Current: demand × your click share × your site conversion × value
      const currentMonthly = demand * (vis / 100) * (conv / 100);
      const currentYearlyCust = currentMonthly * 12;
      const currentRev = currentYearlyCust * value;

      // Projected: same demand × target click share × target conversion × value
      // Use the higher of current vs. target so the calculator never goes
      // backwards if user is already above one threshold.
      const projVis = Math.max(vis, TARGET_VISIBILITY);
      const projConv = Math.max(conv, TARGET_CONV);
      const projMonthly = demand * (projVis / 100) * (projConv / 100);
      const projYearlyCust = projMonthly * 12;
      const projRevenue = projYearlyCust * value;

      curCust.textContent = fmt(currentYearlyCust);
      curRev.textContent = fmt(currentRev);
      projRev.textContent = fmt(projRevenue);
      upside.textContent = fmt(projRevenue - currentRev);
    };

    [demandIn, visIn, convIn, valueIn].forEach((el) =>
      el.addEventListener("input", update)
    );
    update();
  }
</script>
