---
// Interactive revenue/lead-loss calculator inspired by Blacklyne's
// transparency tool. Two sliders + live readout.
---

<section id="calculator" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl px-6">
    <div class="reveal text-center max-w-3xl mx-auto mb-12 sm:mb-16">
      <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        The honest calculator
      </p>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
        <span class="text-ink-900">What you're</span><br />
        <span class="font-serif italic text-gradient-violet">leaving on the table.</span>
      </h2>
      <p class="mt-6 text-base text-ink-700 leading-relaxed">
        Drag the sliders to match your business. Honest math, no fairy-tale conversions - the kind of numbers we can actually move for you.
      </p>
    </div>

    <div
      class="reveal surface-warm rounded-3xl overflow-hidden"
      data-calc
    >
      <div class="grid lg:grid-cols-[1.1fr_1fr]">
        <!-- Inputs -->
        <div class="p-7 sm:p-10 lg:p-12 border-b lg:border-b-0 lg:border-r border-ink-900/8">
          <!-- Monthly leads -->
          <div class="space-y-3">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-xs uppercase tracking-[0.18em] text-ink-500" for="calc-leads">
                Monthly leads / enquiries
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-leads-out
              >
                40
              </output>
            </div>
            <input
              id="calc-leads"
              type="range"
              min="5"
              max="200"
              step="5"
              value="40"
              class="calc-slider w-full"
              data-calc-leads
              aria-label="Monthly leads"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>5</span><span>200</span>
            </div>
          </div>

          <!-- Avg customer value -->
          <div class="space-y-3 mt-8 pt-8 border-t border-ink-900/8">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-xs uppercase tracking-[0.18em] text-ink-500" for="calc-value">
                Average customer value
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-value-out
              >
                $250
              </output>
            </div>
            <input
              id="calc-value"
              type="range"
              min="50"
              max="3000"
              step="25"
              value="250"
              class="calc-slider w-full"
              data-calc-value
              aria-label="Average customer value"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>$50</span><span>$3,000</span>
            </div>
          </div>

          <!-- Current conversion -->
          <div class="space-y-3 mt-8 pt-8 border-t border-ink-900/8">
            <div class="flex items-baseline justify-between gap-4">
              <label class="text-xs uppercase tracking-[0.18em] text-ink-500" for="calc-conv">
                Current close rate
              </label>
              <output
                class="font-serif italic text-3xl text-gradient-violet tabular-nums"
                data-calc-conv-out
              >
                15%
              </output>
            </div>
            <input
              id="calc-conv"
              type="range"
              min="2"
              max="60"
              step="1"
              value="15"
              class="calc-slider w-full"
              data-calc-conv
              aria-label="Current close rate"
            />
            <div class="flex justify-between text-[10px] uppercase tracking-[0.16em] text-ink-400">
              <span>2%</span><span>60%</span>
            </div>
          </div>
        </div>

        <!-- Output -->
        <div class="relative p-7 sm:p-10 lg:p-12 flex flex-col justify-center">
          <div
            class="pointer-events-none absolute inset-0 opacity-50"
            style="background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(167,139,250,0.18), transparent 70%);"
            aria-hidden="true"
          ></div>

          <div class="relative">
            <p class="text-[11px] uppercase tracking-[0.18em] text-ink-500">
              Current annual revenue from leads
            </p>
            <div class="mt-2 font-serif italic text-4xl sm:text-5xl text-ink-900 tabular-nums">
              <span data-calc-current>$18,000</span>
            </div>

            <div class="mt-8 pt-7 border-t border-ink-900/10">
              <p class="text-[11px] uppercase tracking-[0.18em] text-ink-500">
                With Allaia · 2.5x close-rate lift
              </p>
              <div class="mt-2 font-serif italic text-5xl sm:text-6xl text-gradient-violet tabular-nums">
                <span data-calc-projected>$45,000</span>
              </div>
            </div>

            <div class="mt-8 pt-7 border-t border-ink-900/10">
              <p class="text-[11px] uppercase tracking-[0.18em] text-ink-500">
                Annual upside
              </p>
              <div class="mt-2 flex items-baseline gap-2">
                <span class="font-serif italic text-3xl sm:text-4xl text-ink-900 tabular-nums">
                  +<span data-calc-upside>$27,000</span>
                </span>
                <span class="text-sm text-ink-500">per year</span>
              </div>
              <p class="mt-3 text-xs text-ink-600 leading-relaxed">
                Numbers assume we raise your close rate from current to a typical 37.5% (2.5x). Real lift varies by industry - on the discovery call we model your actuals.
              </p>
            </div>

            <a
              href="/contact"
              class="mt-8 inline-flex items-center gap-1.5 rounded-lg bg-ink-900 px-5 py-3 text-sm font-medium text-white hover:bg-ink-800 transition-colors"
            >
              Get the real model
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <p class="reveal mt-8 text-center text-xs text-ink-500">
      Average across our roster: 2.1-2.8x close-rate lift in the first 90 days.
    </p>
  </div>
</section>

<style>
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: pointer;
    padding: 4px 0;
  }
  .calc-slider:focus {
    outline: none;
  }
  /* Track */
  .calc-slider::-webkit-slider-runnable-track {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent-deep), var(--color-accent), var(--color-accent-glow));
    border-radius: 9999px;
  }
  .calc-slider::-moz-range-track {
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent-deep), var(--color-accent), var(--color-accent-glow));
    border-radius: 9999px;
  }
  /* Thumb */
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background: #ffffff;
    border: 2px solid var(--color-accent);
    margin-top: -8px;
    box-shadow: 0 4px 12px -2px rgb(124 58 237 / 0.4);
    transition: transform 0.15s ease;
  }
  .calc-slider::-webkit-slider-thumb:hover,
  .calc-slider:active::-webkit-slider-thumb {
    transform: scale(1.15);
  }
  .calc-slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background: #ffffff;
    border: 2px solid var(--color-accent);
    box-shadow: 0 4px 12px -2px rgb(124 58 237 / 0.4);
    cursor: pointer;
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-calc]");
  if (root) {
    const leadsIn = root.querySelector<HTMLInputElement>("[data-calc-leads]")!;
    const valueIn = root.querySelector<HTMLInputElement>("[data-calc-value]")!;
    const convIn = root.querySelector<HTMLInputElement>("[data-calc-conv]")!;

    const leadsOut = root.querySelector<HTMLElement>("[data-calc-leads-out]")!;
    const valueOut = root.querySelector<HTMLElement>("[data-calc-value-out]")!;
    const convOut = root.querySelector<HTMLElement>("[data-calc-conv-out]")!;

    const current = root.querySelector<HTMLElement>("[data-calc-current]")!;
    const projected = root.querySelector<HTMLElement>(
      "[data-calc-projected]"
    )!;
    const upside = root.querySelector<HTMLElement>("[data-calc-upside]")!;

    const fmt = (n: number) =>
      "$" + Math.round(n).toLocaleString("en-US");

    const update = () => {
      const leads = parseFloat(leadsIn.value);
      const value = parseFloat(valueIn.value);
      const conv = parseFloat(convIn.value);

      leadsOut.textContent = leads.toString();
      valueOut.textContent = "$" + value.toLocaleString("en-US");
      convOut.textContent = conv + "%";

      const currentAnnual = leads * 12 * (conv / 100) * value;
      // Cap projected conversion at 60% (realistic ceiling)
      const projConv = Math.min(60, conv * 2.5);
      const projectedAnnual = leads * 12 * (projConv / 100) * value;
      const delta = projectedAnnual - currentAnnual;

      current.textContent = fmt(currentAnnual);
      projected.textContent = fmt(projectedAnnual);
      upside.textContent = fmt(delta).replace("$", "$");
    };

    [leadsIn, valueIn, convIn].forEach((el) =>
      el.addEventListener("input", update)
    );
    update();
  }
</script>
