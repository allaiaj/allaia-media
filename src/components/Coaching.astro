---
import { site } from "../data/site";

// "What you walk into" - the work itself, in arc form
const arc = [
  {
    n: "01",
    chapter: "Position",
    body: "Who you are. Who you serve. What you stand for. We get the sentence right - the one a stranger could repeat back to a friend and have it land.",
  },
  {
    n: "02",
    chapter: "Voice",
    body: "How you sound on the page, on camera, in the DMs. Not a brand voice doc - your actual voice, dialed up.",
  },
  {
    n: "03",
    chapter: "Rhythm",
    body: "A weekly cadence that ships content without draining you. Hooks, scripts, the diary entries you've been afraid to publish.",
  },
  {
    n: "04",
    chapter: "Receipts",
    body: "Six months in: the audience that's actually paying attention, the inbound that's actually qualified, the name that's actually being googled.",
  },
];

// What you take away
const outcomes = [
  "A positioning sentence you'd put on your front door",
  "A voice that's recognisably yours - no agency house style",
  "A content rhythm you don't dread Sunday night",
  "Hook + script library so on-camera stops freezing you",
  "An audience growth plan tied to your real goals",
  "A coach in your WhatsApp between calls (that's me)",
];

const waitlistHref = `${site.cal}?intake=coaching-waitlist`;
---

<section
  id="coaching"
  class="relative scroll-mt-24 py-24 sm:py-32 isolate overflow-hidden"
>
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute -top-40 right-1/4 h-[60vh] w-[60vh] rounded-full opacity-70 blur-[110px]"
      style="background: radial-gradient(circle, rgba(167,139,250,0.7), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 -left-32 h-[55vh] w-[55vh] rounded-full opacity-55 blur-[110px]"
      style="background: radial-gradient(circle, rgba(251,182,206,0.7), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="reveal max-w-3xl mb-14 sm:mb-16">
      <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        1:1 Coaching · by application · Q3 cohort
      </p>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium" style="letter-spacing: -0.035em; line-height: 1.02;">
        <span class="text-ink-900">For the women</span><br />
        <span class="font-serif italic text-gradient-violet">building it anyway.</span>
      </h2>
      <p class="mt-7 text-base sm:text-lg text-ink-700 leading-relaxed max-w-2xl">
        Six months of 1:1 work with me. Not a course. Not a community.
        Not a Sunday-night Loom drop. A weekly call, a private thread,
        and the slow, deliberate craft of becoming someone people google
        by name.
      </p>
      <p class="mt-4 text-base text-ink-700 leading-relaxed max-w-2xl">
        I take four founders per cohort. By application, because the
        room only works if everyone in it belongs there.
      </p>
    </div>

    <!-- Featured panel -->
    <div class="reveal surface-warm rounded-3xl overflow-hidden">
      <div class="grid lg:grid-cols-[1.1fr_1fr]">
        <!-- Left: 4-chapter arc -->
        <div class="p-8 sm:p-10 lg:p-12 border-b lg:border-b-0 lg:border-r border-ink-900/8">
          <p class="text-[11px] uppercase tracking-[0.22em] text-ink-500 mb-8">
            What you walk into
          </p>
          <ol class="space-y-7 relative">
            <div
              class="pointer-events-none absolute left-[15px] top-7 bottom-7 w-px"
              style="background: linear-gradient(180deg, transparent, var(--color-accent-bright) 15%, var(--color-accent) 50%, var(--color-accent-deep) 85%, transparent);"
              aria-hidden="true"
            ></div>
            {
              arc.map((j) => (
                <li class="relative flex gap-5">
                  <span
                    class="flex-none flex h-8 w-8 items-center justify-center rounded-full font-mono text-[11px] text-white relative z-10"
                    style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-deep)); box-shadow: 0 0 0 4px rgb(255 255 255 / 0.85), 0 6px 16px -4px rgba(124,58,237,0.5);"
                  >
                    {j.n}
                  </span>
                  <div>
                    <p class="text-[10px] uppercase tracking-[0.22em] text-ink-500 mb-1">
                      Chapter {j.n}
                    </p>
                    <h3 class="font-serif italic text-2xl text-gradient-violet tracking-tight">
                      {j.chapter}
                    </h3>
                    <p class="mt-2 text-[14px] text-ink-700 leading-relaxed">
                      {j.body}
                    </p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <!-- Right: outcomes + waitlist CTA -->
        <div class="relative p-8 sm:p-10 lg:p-12 flex flex-col text-ink-50 overflow-hidden">
          <div
            class="absolute inset-0"
            style="background: linear-gradient(160deg, #0e0d0a 0%, #1a1814 65%, #2a2722 100%);"
            aria-hidden="true"
          ></div>
          <div
            class="pointer-events-none absolute inset-0 opacity-55"
            style="background: radial-gradient(ellipse 70% 60% at 80% 10%, rgba(167,139,250,0.6), transparent 70%), radial-gradient(ellipse 60% 50% at 10% 90%, rgba(251,182,206,0.5), transparent 70%);"
            aria-hidden="true"
          ></div>

          <div class="relative">
            <p class="text-[11px] uppercase tracking-[0.22em] text-accent-bright mb-3">
              What you walk away with
            </p>
            <h3 class="font-serif italic text-3xl sm:text-4xl text-ink-50 leading-tight mb-7">
              A name. A voice.<br />A roomful of receipts.
            </h3>

            <ul class="space-y-3.5 mb-9">
              {
                outcomes.map((o) => (
                  <li class="flex items-start gap-3 text-[14px] sm:text-[15px] text-ink-100 leading-snug">
                    <span class="mt-1 flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--color-accent);">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M3 6.2l2 2 4-4.5" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <span>{o}</span>
                  </li>
                ))
              }
            </ul>

            <!-- Stats row -->
            <div class="grid grid-cols-3 gap-3 mb-7 pb-7 border-b border-white/10">
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-400">Format</p>
                <p class="mt-1.5 font-serif italic text-xl text-gradient-accent">Weekly 1:1</p>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-400">Length</p>
                <p class="mt-1.5 font-serif italic text-xl text-gradient-accent">6 months</p>
              </div>
              <div>
                <p class="text-[10px] uppercase tracking-[0.16em] text-ink-400">Seats</p>
                <p class="mt-1.5 font-serif italic text-xl text-gradient-accent">4 / cohort</p>
              </div>
            </div>

            <a
              href={waitlistHref}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center justify-center gap-2 rounded-lg bg-white px-5 py-3.5 text-sm font-medium text-ink-900 hover:scale-[1.02] transition-transform"
            >
              Apply for the Q3 cohort
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
                <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <p class="mt-4 text-[11px] text-ink-400 leading-relaxed">
              15-minute intake call before any commitment. I read every
              application personally. If we're not a fit, I'll point you to
              someone who is.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Personal note from founder -->
    <div class="reveal mt-12 sm:mt-16 max-w-3xl mx-auto text-center">
      <p class="font-serif italic text-xl sm:text-2xl text-ink-900 leading-snug">
        "I keep the room curated so the work can be deep. If we end up
        sitting across from each other for six months, I want to know
        I've earned every minute."
      </p>
      <p class="mt-4 text-xs uppercase tracking-[0.24em] text-ink-500">
        — Allaia
      </p>
    </div>
  </div>
</section>
