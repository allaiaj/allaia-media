---
import { site } from "../data/site";
---

<a
  href={site.whatsapp}
  target="_blank"
  rel="noopener"
  class="whatsapp-fab fixed bottom-5 right-5 sm:bottom-7 sm:right-7 z-40 group inline-flex items-center gap-3 rounded-full pl-2.5 pr-4 sm:pr-5 py-2.5 sm:py-3 text-sm font-medium text-white shadow-[0_18px_50px_-12px_rgba(37,211,102,0.55),0_0_0_1px_rgba(255,255,255,0.15)_inset] transition-all duration-500 hover:scale-[1.03] active:scale-[0.97]"
  style="background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);"
  aria-label="Chat with us on WhatsApp"
  data-whatsapp-fab
>
  <!-- Pulse ring -->
  <span class="pointer-events-none absolute inset-0 rounded-full" style="box-shadow: 0 0 0 0 rgba(37,211,102,0.55); animation: whatsapp-pulse 2.2s ease-out infinite;"></span>

  <!-- Icon -->
  <span class="relative flex h-8 w-8 sm:h-9 sm:w-9 items-center justify-center rounded-full bg-white/15 backdrop-blur-sm">
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      class="text-white sm:scale-110"
    >
      <path d="M17.6 6.32A7.85 7.85 0 0012.05 4 7.94 7.94 0 005.32 16.05L4 21l5.05-1.32a7.92 7.92 0 003.78.96h.01a7.94 7.94 0 005.5-13.32m-5.5 12.21h-.01a6.6 6.6 0 01-3.36-.92l-.24-.14-2.99.78.8-2.92-.16-.25a6.59 6.59 0 1112.33-3.34 6.59 6.59 0 01-6.38 6.79m3.62-4.93c-.2-.1-1.17-.58-1.35-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.63.79-.12.13-.23.15-.43.05-.2-.1-.84-.31-1.6-.99-.59-.53-.99-1.18-1.1-1.38-.12-.2-.01-.31.09-.41.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34-.12 0-.25-.02-.39-.02-.13 0-.35.05-.53.25-.18.2-.7.68-.7 1.67 0 .99.71 1.94.81 2.07.1.13 1.4 2.14 3.38 3 .47.2.84.32 1.13.41.48.15.91.13 1.25.08.38-.06 1.17-.48 1.34-.94.16-.46.16-.86.11-.94-.05-.08-.18-.13-.38-.23"/>
    </svg>
  </span>

  <!-- Label -->
  <span class="relative whitespace-nowrap">
    <span class="block sm:hidden">WhatsApp</span>
    <span class="hidden sm:block">Chat on WhatsApp</span>
  </span>

  <!-- Arrow -->
  <svg
    width="12"
    height="12"
    viewBox="0 0 12 12"
    fill="none"
    class="relative transition-transform duration-300 group-hover:translate-x-0.5 -ml-1"
    aria-hidden="true"
  >
    <path d="M3 9L9 3M9 3H4M9 3v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>

<style>
  @keyframes whatsapp-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.55);
    }
    70% {
      box-shadow: 0 0 0 18px rgba(37, 211, 102, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
    }
  }

  .whatsapp-fab {
    transform: translateY(20px);
    opacity: 0;
  }
  .whatsapp-fab.is-visible {
    transform: translateY(0);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-fab {
      opacity: 1;
      transform: none;
    }
    .whatsapp-fab span[style*="animation"] {
      animation: none !important;
    }
  }
</style>

<script>
  // Reveal the FAB once the user has scrolled past the top
  const fab = document.querySelector<HTMLElement>("[data-whatsapp-fab]");
  if (fab) {
    const reveal = () => {
      if (window.scrollY > 200) {
        fab.classList.add("is-visible");
      } else {
        fab.classList.remove("is-visible");
      }
    };
    reveal();
    window.addEventListener("scroll", reveal, { passive: true });
  }
</script>
