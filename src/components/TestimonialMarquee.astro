---
import { testimonials } from "../data/site";

// Two rows scrolling opposite directions, each with its own duplicated set
const rowA = [...testimonials.slice(0, 6), ...testimonials.slice(0, 6)];
const rowB = [
  ...testimonials.slice(6, 12),
  ...testimonials.slice(6, 12),
];
---

<section aria-label="Client snippets" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 mb-12">
    <p class="reveal text-center text-[11px] uppercase tracking-[0.22em] text-ink-500 mb-4">
      What founders are saying · 12 on record
    </p>
    <h2 class="reveal display text-center text-5xl sm:text-6xl lg:text-7xl font-medium">
      <span class="text-gradient-ink">Quietly relentless.</span><br />
      <span class="font-serif italic text-gradient-violet">Loudly endorsed.</span>
    </h2>
  </div>

  <!-- Row 1 (scrolls left) -->
  <div class="marquee-row relative" data-direction="left">
    <div class="marquee-track flex gap-4 sm:gap-5 w-max">
      {
        rowA.map((t, i) => (
          <article class="surface relative w-[320px] sm:w-[380px] flex-none rounded-2xl p-6">
            <svg width="22" height="22" viewBox="0 0 28 28" class="mb-3" fill="currentColor" aria-hidden="true" style="color: var(--color-accent-bright);">
              <path d="M11 8c-3 0-5 2.5-5 6v6h6v-6H8c0-2 1.2-3 3-3V8zm11 0c-3 0-5 2.5-5 6v6h6v-6h-4c0-2 1.2-3 3-3V8z" />
            </svg>
            <p class="font-serif text-[16px] sm:text-[17px] leading-snug text-ink-900 line-clamp-4">
              "{t.quote}"
            </p>
            <div class="mt-4 pt-3 border-t border-ink-900/8 flex items-center justify-between text-xs">
              <div class="min-w-0">
                <div class="text-ink-900 font-medium truncate">{t.name}</div>
                <div class="text-ink-500 text-[11px] truncate">{t.role}</div>
              </div>
              <span class="flex-none rounded-full bg-ink-900/5 px-2 py-0.5 text-[10px] uppercase tracking-wider text-ink-600">
                {t.market}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- Row 2 (scrolls right) -->
  <div class="marquee-row relative mt-4 sm:mt-5" data-direction="right">
    <div class="marquee-track flex gap-4 sm:gap-5 w-max">
      {
        rowB.map((t, i) => (
          <article class="surface relative w-[320px] sm:w-[380px] flex-none rounded-2xl p-6">
            <svg width="22" height="22" viewBox="0 0 28 28" class="mb-3" fill="currentColor" aria-hidden="true" style="color: var(--color-accent-bright);">
              <path d="M11 8c-3 0-5 2.5-5 6v6h6v-6H8c0-2 1.2-3 3-3V8zm11 0c-3 0-5 2.5-5 6v6h6v-6h-4c0-2 1.2-3 3-3V8z" />
            </svg>
            <p class="font-serif text-[16px] sm:text-[17px] leading-snug text-ink-900 line-clamp-4">
              "{t.quote}"
            </p>
            <div class="mt-4 pt-3 border-t border-ink-900/8 flex items-center justify-between text-xs">
              <div class="min-w-0">
                <div class="text-ink-900 font-medium truncate">{t.name}</div>
                <div class="text-ink-500 text-[11px] truncate">{t.role}</div>
              </div>
              <span class="flex-none rounded-full bg-ink-900/5 px-2 py-0.5 text-[10px] uppercase tracking-wider text-ink-600">
                {t.market}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <!-- Fade edges -->
  <div class="pointer-events-none absolute inset-y-0 left-0 w-24 sm:w-40 z-10" style={`background: linear-gradient(to right, var(--color-cream), transparent);`}></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-24 sm:w-40 z-10" style={`background: linear-gradient(to left, var(--color-cream), transparent);`}></div>
</section>

<style>
  .marquee-row {
    overflow: hidden;
  }
  .marquee-track {
    animation: marquee 60s linear infinite;
  }
  .marquee-row[data-direction="right"] .marquee-track {
    animation-direction: reverse;
  }
  .marquee-row:hover .marquee-track {
    animation-play-state: paused;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
