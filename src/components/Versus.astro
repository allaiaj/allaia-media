---
const rows = [
  {
    label: "Account team",
    allaia: "One operator. Same person you brief, build, report.",
    them: "Account exec + strategist + planner + 3 freelancers.",
  },
  {
    label: "Starting cost",
    allaia: "From $199/month.",
    them: "$3,000-$10,000/month retainers.",
  },
  {
    label: "Reply time",
    allaia: "Under 4 hours, WhatsApp.",
    them: "48-72 hours via support ticket.",
  },
  {
    label: "Lock-in",
    allaia: "Cancel any month (3-mo min on ads only).",
    them: "6-12 month contracts.",
  },
  {
    label: "Production",
    allaia: "AI for leverage, humans for taste.",
    them: "Junior team in another timezone.",
  },
  {
    label: "Reporting",
    allaia: "Real numbers in real dashboards.",
    them: "Monthly slide deck with vanity metrics.",
  },
  {
    label: "Strategy call",
    allaia: "Founder personally on the call.",
    them: "Account exec reading from a script.",
  },
];
---

<section id="versus" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal text-center max-w-3xl mx-auto mb-16">
      <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        The difference · old vs. new
      </p>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
        <span class="text-gradient-ink">Old agency.</span><br />
        <span class="font-serif italic text-gradient-violet">New approach.</span>
      </h2>
      <p class="mt-6 text-base text-ink-700 leading-relaxed">
        Side by side. Same outcome you'd expect from a five-figure agency, minus the pageantry that makes them five-figure agencies.
      </p>
    </div>

    <div class="reveal relative overflow-hidden rounded-3xl surface">
      {/* Header row */}
      <div class="grid grid-cols-[1fr_1.5fr_1.5fr] gap-px border-b border-ink-900/8" style="background: rgb(14 13 10 / 0.06);">
        <div class="px-4 sm:px-6 py-4 sm:py-5" style="background: var(--color-paper);">
          <p class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-ink-500">
            What you get
          </p>
        </div>
        <div class="px-4 sm:px-6 py-4 sm:py-5 text-ink-50 relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-accent-deep) 0%, var(--color-accent) 100%);">
          <p class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] opacity-80 mb-1">
            Allaia Media
          </p>
          <p class="font-serif italic text-lg sm:text-xl">The shift</p>
        </div>
        <div class="px-4 sm:px-6 py-4 sm:py-5" style="background: var(--color-paper);">
          <p class="text-[10px] sm:text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-1">
            Traditional agency
          </p>
          <p class="font-serif italic text-lg sm:text-xl text-ink-700">The old way</p>
        </div>
      </div>

      {/* Rows */}
      {
        rows.map((row, i) => (
          <div
            class="grid grid-cols-[1fr_1.5fr_1.5fr] gap-px"
            style={`background: rgb(14 13 10 / 0.06); ${i === rows.length - 1 ? "" : "border-bottom: 1px solid rgb(14 13 10 / 0.04);"}`}
          >
            <div class="px-4 sm:px-6 py-4 sm:py-5 flex items-center" style="background: var(--color-paper);">
              <p class="text-xs sm:text-sm font-medium text-ink-900">{row.label}</p>
            </div>
            <div class="px-4 sm:px-6 py-4 sm:py-5 flex items-start gap-2" style="background: linear-gradient(135deg, rgba(167,139,250,0.08), rgba(167,139,250,0.03));">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="mt-0.5 flex-none" style="color: var(--color-accent-deep);">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M5 8.2l2 2 4-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <p class="text-xs sm:text-sm text-ink-900 leading-snug">{row.allaia}</p>
            </div>
            <div class="px-4 sm:px-6 py-4 sm:py-5 flex items-start gap-2" style="background: var(--color-paper);">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="mt-0.5 flex-none text-ink-400">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <p class="text-xs sm:text-sm text-ink-500 leading-snug">{row.them}</p>
            </div>
          </div>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Not a knock - some founders want the slide decks. We built Allaia for the ones who don't.
    </p>
  </div>
</section>
