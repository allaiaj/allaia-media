---
// Quantum-leap popup. Appears a few seconds after the About page opens
// with the featured YouTube video on autoplay. Closes via X / backdrop /
// ESC / opening on YouTube. localStorage suppresses for 7 days after a
// dismissal so it doesn't keep popping up.
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const f = site.youtubeFeatured;
---

<div
  class="yt-modal fixed inset-0 z-[85] hidden items-center justify-center px-4 sm:px-6"
  data-yt-modal
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="yt-modal-title"
>
  <!-- Backdrop -->
  <button
    type="button"
    class="absolute inset-0 w-full h-full bg-anthracite/65 backdrop-blur-md cursor-pointer"
    aria-label="Close"
    data-yt-modal-close
  ></button>

  <!-- Modal card -->
  <div
    class="yt-modal-card relative w-full max-w-[920px] max-h-[92vh] overflow-y-auto rounded-[1.5rem] shadow-anthracite"
    style="background: linear-gradient(160deg, #0A0A0C 0%, #18181A 60%, #2A2722 100%);"
    data-yt-modal-card
  >
    <!-- Warm wash -->
    <div
      class="pointer-events-none absolute inset-0 opacity-50"
      style="background: radial-gradient(ellipse 60% 60% at 80% 10%, rgba(184,85,66,0.45), transparent 70%), radial-gradient(ellipse 55% 55% at 10% 95%, rgba(139,157,126,0.3), transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Close button -->
    <button
      type="button"
      aria-label="Close"
      data-yt-modal-close
      class="absolute top-4 right-4 sm:top-5 sm:right-5 z-10 grid place-items-center h-10 w-10 rounded-full bg-cream/12 backdrop-blur-md border border-cream/20 text-cream hover:bg-cream/25 hover:scale-110 transition-all duration-300 ease-editorial"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 3l8 8M11 3 3 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="relative p-5 sm:p-7 lg:p-8 text-cream">
      <p class="text-[0.625rem] uppercase tracking-[0.28em] text-cream/55 font-medium mb-3 sm:mb-4">
        From the channel · {f.duration}
      </p>
      <h2
        id="yt-modal-title"
        class="font-display font-medium italic leading-[1.04] mb-4 sm:mb-6"
        style="font-size: clamp(1.625rem, 3.6vw, 2.5rem); letter-spacing: -0.02em;"
      >
        <span class="italic-grad">{f.title}</span>
      </h2>

      <!-- Video player — IntersectionObserver-style ensure: iframe injected on open -->
      <div
        class="relative aspect-video rounded-[1rem] overflow-hidden bg-anthracite"
        data-yt-player
        data-yt-id={f.video_id}
        style="box-shadow: 0 28px 80px -16px rgba(184,85,66,0.4), 0 0 0 1px rgba(242,237,229,0.08) inset;"
      >
        <img
          src={f.thumbnail}
          alt={f.title}
          loading="eager"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>

      <p class="font-serif text-cream/75 leading-[1.6] mt-5 sm:mt-6 max-w-prose text-[0.9375rem] sm:text-base">
        {f.description}
      </p>

      <div class="mt-5 sm:mt-6 flex flex-col sm:flex-row gap-3">
        <a
          href={`https://www.youtube.com/watch?v=${f.video_id}`}
          target="_blank"
          rel="noopener"
          class="cta-cream group inline-flex items-center justify-center"
          data-yt-modal-open
        >
          <span>Watch on YouTube</span>
          <ArrowUpRight size={12} class="ml-1.5 transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href={site.youtube}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-1.5 px-5 py-3 text-[0.8125rem] text-cream/70 hover:text-cream transition-colors duration-300 ease-editorial"
        >
          <span>More on {site.youtubeHandle}</span>
          <ArrowUpRight size={11} />
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .yt-modal {
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .yt-modal[data-state="open"] {
    display: flex;
    opacity: 1;
  }
  .yt-modal-card {
    transform: translateY(20px) scale(0.97);
    opacity: 0;
    transition:
      transform 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 380ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .yt-modal[data-state="open"] .yt-modal-card {
    transform: none;
    opacity: 1;
    transition-delay: 80ms;
  }
  @media (prefers-reduced-motion: reduce) {
    .yt-modal, .yt-modal-card { transition: none !important; }
  }
</style>

<script>
  const KEY = 'allaia_yt_modal_dismissed_at';
  const EXPIRY_MS = 7 * 86400000;
  const DELAY_MS = 2200;

  const modal = document.querySelector<HTMLElement>('[data-yt-modal]');
  if (modal) {
    let dismissedAt: number | null = null;
    try {
      const v = localStorage.getItem(KEY);
      dismissedAt = v ? parseInt(v, 10) : null;
    } catch { /* localStorage blocked — show anyway */ }
    const recentlyDismissed = dismissedAt && (Date.now() - dismissedAt) < EXPIRY_MS;

    const player = modal.querySelector<HTMLElement>('[data-yt-player]');
    let iframe: HTMLIFrameElement | null = null;

    const ensureIframe = () => {
      if (iframe || !player) return;
      const id = player.getAttribute('data-yt-id');
      if (!id) return;
      iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full';
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1&playsinline=1&color=white&enablejsapi=1`;
      iframe.title = 'Quantum leap — featured video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      iframe.style.border = '0';
      player.appendChild(iframe);
    };

    const open = () => {
      modal.style.display = '';
      modal.setAttribute('data-state', 'open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      ensureIframe();
    };
    const close = () => {
      modal.removeAttribute('data-state');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      try { localStorage.setItem(KEY, String(Date.now())); } catch { /* ignore */ }
      // Tear down iframe so the video actually stops
      if (iframe) {
        iframe.remove();
        iframe = null;
      }
      setTimeout(() => { modal.style.display = 'none'; }, 360);
    };

    modal.querySelectorAll<HTMLElement>('[data-yt-modal-close]').forEach((b) => {
      b.addEventListener('click', close);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.getAttribute('data-state') === 'open') close();
    });
    modal.querySelector<HTMLElement>('[data-yt-modal-open]')?.addEventListener('click', () => {
      try { localStorage.setItem(KEY, String(Date.now())); } catch { /* ignore */ }
    });

    if (!recentlyDismissed) {
      setTimeout(open, DELAY_MS);
    }
  }
</script>
