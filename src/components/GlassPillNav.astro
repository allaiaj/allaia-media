---
import { site, navItems } from '@data/site';
import ArrowUpRight from './icons/ArrowUpRight.astro';
---

<header class="fixed top-4 left-0 right-0 z-50 pointer-events-none">
  <div class="mx-auto max-w-[1100px] px-4">
    <nav
      class="pointer-events-auto glass-pill rounded-full px-2.5 py-2 flex items-center justify-between gap-2 shadow-pill"
      aria-label="Primary"
    >
      <a href="/" class="flex items-center gap-2 pl-3 pr-3 py-1.5 rounded-full hover:bg-ink/5 transition-colors duration-300 ease-editorial">
        <span class="font-display italic text-[1.15rem] leading-none text-ink tracking-tight">Allaia</span>
      </a>

      <ul class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              target={('external' in item && item.external) ? '_blank' : undefined}
              rel={('external' in item && item.external) ? 'noopener' : undefined}
              class="block px-3 py-2 rounded-full text-nav text-ink/80 hover:text-ink hover:bg-ink/5 transition-colors duration-300 ease-editorial"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="hidden lg:flex items-center gap-2 pr-1">
        <span class="hidden xl:inline text-micro text-ink-mute pr-2 border-r border-ink/10 mr-1">
          Become Her — out 2026
        </span>
        <a
          href={site.stan.application}
          target="_blank"
          rel="noopener"
          class="cta-dark !py-2 !px-4 !text-[0.75rem]"
        >
          <span>Apply</span>
          <ArrowUpRight size={11} />
        </a>
      </div>

      <button
        type="button"
        aria-label="Open menu"
        aria-controls="mobile-overlay"
        aria-expanded="false"
        data-nav-toggle
        class="lg:hidden flex items-center gap-2 px-4 py-2 rounded-full text-nav text-ink hover:bg-ink/5 transition-colors duration-300 ease-editorial"
      >
        <span class="font-medium">Menu</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 4h10M2 10h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile overlay -->
<div
  id="mobile-overlay"
  class="fixed inset-0 z-[60] hidden"
  aria-hidden="true"
  data-nav-overlay
>
  <button
    type="button"
    class="absolute inset-0 bg-ink/40 backdrop-blur-sm"
    aria-label="Close menu"
    data-nav-close
  ></button>

  <aside
    class="absolute right-0 top-0 bottom-0 w-full max-w-[420px] bg-cream paper-grain shadow-anthracite flex flex-col"
    role="dialog"
    aria-modal="true"
    aria-label="Site navigation"
  >
    <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-ink/10">
      <span class="font-display italic text-2xl text-ink">Allaia</span>
      <button
        type="button"
        aria-label="Close menu"
        data-nav-close
        class="w-10 h-10 grid place-items-center rounded-full bg-ink/5 hover:bg-ink/10 transition-colors duration-300 ease-editorial"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 3l10 10M13 3 3 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <ul class="flex-1 overflow-y-auto px-6 py-8 space-y-1">
      {navItems.map((item, i) => (
        <li>
          <a
            href={item.href}
            target={('external' in item && item.external) ? '_blank' : undefined}
            rel={('external' in item && item.external) ? 'noopener' : undefined}
            class="group flex items-baseline gap-5 py-4 border-b border-ink/8 hover:pl-2 transition-all duration-300 ease-editorial"
          >
            <span class="text-micro text-ink-mute font-medium tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="font-display text-3xl text-ink group-hover:text-terracotta transition-colors duration-300 ease-editorial">
              {item.label}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="px-6 pt-6 pb-8 border-t border-ink/10 space-y-3">
      <a
        href={site.stan.book}
        target="_blank"
        rel="noopener"
        class="cta-dark w-full justify-center"
      >
        Read the book
        <ArrowUpRight size={12} />
      </a>
      <a
        href={site.stan.application}
        target="_blank"
        rel="noopener"
        class="cta-ghost w-full justify-center"
      >
        Apply for The Architecture
        <ArrowUpRight size={12} />
      </a>
      <p class="byline text-center pt-3 text-ink-mute">
        Become Her — out 2026
      </p>
    </div>
  </aside>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const overlay = document.querySelector<HTMLDivElement>('[data-nav-overlay]');
  const closeBtns = document.querySelectorAll<HTMLElement>('[data-nav-close]');

  const open = () => {
    if (!overlay || !toggle) return;
    overlay.classList.remove('hidden');
    overlay.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    if (!overlay || !toggle) return;
    overlay.classList.add('hidden');
    overlay.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', open);
  closeBtns.forEach((b) => b.addEventListener('click', close));
  overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
