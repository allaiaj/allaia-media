---
import { site } from "../data/site";
---

<section class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div
      class="reveal relative overflow-hidden rounded-[2.5rem] p-10 sm:p-16 lg:p-24 text-center"
      style="background: linear-gradient(180deg, #ffffff 0%, #faf9f6 100%); border: 1px solid rgb(14 13 10 / 0.06); box-shadow: 0 30px 80px -30px rgba(124,58,237,0.2), 0 1px 0 rgb(255 255 255 / 0.9) inset;"
    >
      <!-- pastel gradient blobs -->
      <div
        class="pointer-events-none absolute -top-32 -left-32 h-96 w-96 rounded-full opacity-50 blur-3xl"
        style="background: radial-gradient(circle, rgba(167,139,250,0.6), transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -bottom-32 -right-32 h-96 w-96 rounded-full opacity-45 blur-3xl"
        style="background: radial-gradient(circle, rgba(251,207,232,0.7), transparent 70%);"
        aria-hidden="true"
      ></div>

      <p class="relative mb-5 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        Last spot for Q3 · {site.markets.join(" · ")}
      </p>
      <h2 class="relative display-tight mx-auto max-w-4xl text-5xl sm:text-7xl lg:text-8xl font-medium">
        <span class="text-gradient-ink">If your offer is good,</span><br />
        <span class="font-serif italic text-gradient-violet">we'll prove it pays.</span>
      </h2>
      <p class="relative mt-8 mx-auto max-w-xl text-base sm:text-lg text-ink-700 leading-relaxed">
        Book a 30-minute discovery call. We'll map your numbers, your offer, your bottleneck - and tell you honestly whether we can move them.
      </p>

      <div class="relative mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={site.cal}
          target="_blank"
          rel="noopener"
          class="group relative inline-flex w-full sm:w-auto items-center justify-center gap-2 overflow-hidden rounded-full bg-ink-900 px-7 py-4 text-[15px] font-medium text-ink-50"
          style="box-shadow: 0 16px 50px -15px rgba(14,13,10,0.4);"
        >
          <span class="relative">Book a discovery call</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="relative transition-transform group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/15 to-transparent transition-transform duration-700 group-hover:translate-x-full"></span>
        </a>
        <a
          href={site.whatsapp}
          target="_blank"
          rel="noopener"
          class="surface inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-full px-7 py-4 text-[15px] font-medium text-ink-900 hover:bg-ink-900/5 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-emerald-500">
            <path d="M17.6 6.32A7.85 7.85 0 0012.05 4 7.94 7.94 0 005.32 16.05L4 21l5.05-1.32a7.92 7.92 0 003.78.96h.01a7.94 7.94 0 005.5-13.32m-5.5 12.21h-.01a6.6 6.6 0 01-3.36-.92l-.24-.14-2.99.78.8-2.92-.16-.25a6.59 6.59 0 1112.33-3.34 6.59 6.59 0 01-6.38 6.79"/>
          </svg>
          Or message on WhatsApp
        </a>
      </div>

      <p class="relative mt-10 text-xs text-ink-500">
        Reply within 4 hours. No pitch deck. No pressure.
      </p>
    </div>
  </div>
</section>
