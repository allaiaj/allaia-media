---
const wins = [
  {
    metric: "+34",
    label: "new patients",
    timeframe: "in 6 weeks",
    client: "Smile Studio",
    market: "Dubai",
    body: "Cold inbound to a fully-booked diary. Funnel + GBP rebuild.",
    accent: "violet",
  },
  {
    metric: "4.8x",
    label: "Meta ROAS",
    timeframe: "8 weeks",
    client: "Glow Skin Lab",
    market: "Manila",
    body: "From 1.2x ROAS to 4.8x. Creative-led iteration.",
    accent: "pink",
  },
  {
    metric: "11 days",
    label: "pre-launch sold out",
    timeframe: "Q1 launch",
    client: "Maven Skincare",
    market: "Tel Aviv",
    body: "Waitlist build + paid drip. Sold every unit pre-shipping.",
    accent: "peach",
  },
  {
    metric: "12k",
    label: "engaged followers",
    timeframe: "4 months",
    client: "Forge Athletic",
    market: "Sydney",
    body: "Dead account to community. Reels-first content engine.",
    accent: "mint",
  },
];

const accentMap = {
  violet: "linear-gradient(135deg, rgba(167,139,250,0.85), rgba(124,58,237,0.85))",
  pink: "linear-gradient(135deg, rgba(251,182,206,0.95), rgba(236,72,153,0.85))",
  peach: "linear-gradient(135deg, rgba(254,205,170,0.95), rgba(251,146,60,0.85))",
  mint: "linear-gradient(135deg, rgba(167,243,208,0.95), rgba(16,185,129,0.85))",
};
---

<section id="recent-wins" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Recent wins · last 90 days
        </p>
        <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
          <span class="text-gradient-ink">Numbers,</span><br />
          <span class="font-serif italic text-gradient-violet">not adjectives.</span>
        </h2>
      </div>
      <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
        Real outcomes from the last quarter. The kind we put in writing before we start, so you can hold us to them.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5">
      {
        wins.map((w) => (
          <article
            data-tilt
            data-tilt-max="5"
            data-tilt-lift="4"
            class="reveal group relative overflow-hidden rounded-3xl surface flex flex-col transition-all duration-500 hover:shadow-[0_30px_80px_-30px_rgba(124,58,237,0.28)]"
          >
            {/* Top color band */}
            <div class="relative h-32 sm:h-36 overflow-hidden" style={`background: ${accentMap[w.accent as keyof typeof accentMap]};`}>
              <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.6), transparent 50%), radial-gradient(circle at 80% 70%, rgba(255,255,255,0.4), transparent 50%);"></div>
              <div class="relative flex flex-col h-full px-5 py-4 justify-end text-white">
                <div class="flex items-baseline gap-2">
                  <span class="font-serif italic text-4xl sm:text-5xl leading-none drop-shadow-sm">
                    {w.metric}
                  </span>
                </div>
                <p class="mt-1 text-[12px] uppercase tracking-[0.16em] opacity-90">
                  {w.label}
                </p>
              </div>
              <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-white/25 backdrop-blur-sm px-2 py-0.5 text-[9px] uppercase tracking-wider text-white font-medium">
                {w.timeframe}
              </span>
            </div>

            {/* Body */}
            <div class="flex-1 flex flex-col p-5">
              <p class="text-[14px] text-ink-700 leading-relaxed flex-1">
                {w.body}
              </p>
              <div class="mt-5 pt-4 border-t border-ink-900/8 flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-ink-900">{w.client}</p>
                  <p class="text-[11px] text-ink-500">{w.market}</p>
                </div>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="text-ink-400 group-hover:text-accent-deep group-hover:translate-x-0.5 transition-all" aria-hidden="true">
                  <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Outcomes vary - ours are confidence-built, not guaranteed. Read the FAQ on why.
    </p>
  </div>
</section>
