---
// Asymmetric magazine-spread identities. Cards 01 + 03 are dominant
// (col-span-2), 02 + 04 are accent — gives the section a Vogue-cover
// rhythm instead of a flat 4-up grid. Each card has overlay text on
// the photo + subtle 3D tilt on hover.
import { identities } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<section id="identities" class="relative scroll-mt-28 py-28 sm:py-36 lg:py-44 overflow-hidden">
  <!-- Atmospheric layers -->
  <div class="pointer-events-none absolute inset-0 opacity-60" aria-hidden="true">
    <div
      class="absolute top-0 right-1/4 h-[55vh] w-[55vh] rounded-full blur-[140px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.32), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[50vh] w-[50vh] rounded-full blur-[130px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.28), transparent 70%);"
    ></div>
  </div>

  <div class="relative mx-auto max-w-[1320px] px-6 lg:px-10">
    <!-- Section header -->
    <div class="reveal mb-20 sm:mb-28 grid lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-20 items-end pb-10 border-b border-ink/10">
      <div>
        <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink-mute mb-6">Issue · 026 / Chapter II</p>
        <h2
          class="font-display font-medium leading-[1.0] text-ink"
          style="font-size: clamp(2.75rem, 7.5vw, 6rem); letter-spacing: -0.045em;"
        >
          <span class="block">Author.</span>
          <span class="block">Operator.</span>
          <span class="block italic-grad">Artist.</span>
          <span class="block">Creator.</span>
        </h2>
      </div>
      <div class="lg:pb-3">
        <p class="font-display italic text-2xl sm:text-3xl text-brown leading-[1.18] max-w-md">
          Four expressions of the same thesis.
        </p>
        <p class="serif-lg text-ink-soft mt-7 max-w-md">
          What compounds is identity. Performance does not.
        </p>
      </div>
    </div>

    <!-- Magazine-spread asymmetric layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8" data-identity-grid>
      {identities.map((id, i) => {
        const isExternal = id.href.startsWith('http');
        // 01 + 03 = dominant (col-span-2). 02 + 04 = accent
        // Per Allaia: Operator (i=1) and Creator (i=3) are the
        // dominant cards. Author + Artist sit in the accent slots.
        const dominant = i === 1 || i === 3;
        const col = dominant ? 'lg:col-span-2' : 'lg:col-span-1';
        // Mobile-first aspect: dominants are TALL (read as bigger when
        // every card is full-width). Accents are square (read smaller).
        // Desktop flips back to the magazine spread — dominants get the
        // landscape 5:3 across 2 columns, accents take the 4:5 single col.
        const aspect = dominant
          ? 'aspect-[4/5] lg:aspect-[5/3]'
          : 'aspect-square lg:aspect-[4/5]';
        const overlayJustify = dominant ? 'justify-between' : 'justify-end';
        return (
          <a
            href={id.href}
            target={isExternal ? '_blank' : undefined}
            rel={isExternal ? 'noopener' : undefined}
            class={`identity-card reveal group block ${col}`}
            data-identity-card
            style={`transition-delay: ${i * 80}ms`}
          >
            <figure
              class={`relative ${aspect} rounded-[1.5rem] overflow-hidden shadow-photo bg-anthracite-warm paper-grain transition-transform duration-700 ease-editorial`}
              data-identity-figure
            >
              <!-- Tonal fallback FIRST in DOM so it sits behind the img -->
              <div
                class="absolute inset-0"
                style={
                  id.key === 'author' ? 'background: linear-gradient(160deg, #2A2722 0%, #6B4F3D 100%);' :
                  id.key === 'operator' ? 'background: linear-gradient(160deg, #0E0D0B 0%, #2F2A22 100%);' :
                  id.key === 'artist' ? 'background: linear-gradient(160deg, #B85542 0%, #6B4F3D 100%);' :
                  'background: linear-gradient(160deg, #8B9D7E 0%, #6B4F3D 100%);'
                }
                aria-hidden="true"
              ></div>
              <!-- Real photo painted on top of the fallback -->
              <img
                src={id.image}
                alt={id.alt}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover photo-warm transition-transform duration-[1600ms] ease-editorial group-hover:scale-[1.06]"
              />

              <!-- Dark gradient overlay for text legibility -->
              <div
                class="absolute inset-0 pointer-events-none"
                style="background: linear-gradient(180deg, rgba(14,13,11,0.25) 0%, transparent 30%, transparent 55%, rgba(14,13,11,0.78) 100%);"
                aria-hidden="true"
              ></div>

              <!-- TOP-LEFT: huge italic numeral + figure ID -->
              <div class="absolute top-5 left-6 right-6 flex items-baseline justify-between text-cream">
                <span
                  class="font-display italic font-medium leading-none drop-shadow-[0_4px_24px_rgba(0,0,0,0.4)]"
                  style="font-size: clamp(2.75rem, 5vw, 4.5rem); letter-spacing: -0.04em; padding-bottom: 0.1em;"
                >
                  {String(i + 1).padStart(2, '0')}.
                </span>
                <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-cream/75 mt-2">
                  {id.figure}
                </span>
              </div>

              <!-- BOTTOM: identity text overlay -->
              <div class={`absolute inset-x-0 bottom-0 p-6 sm:p-8 lg:p-10 flex flex-col ${overlayJustify} text-cream`}>
                <p class="text-[0.6875rem] uppercase tracking-[0.28em] text-cream/75 font-medium mb-3">
                  {id.context}
                </p>
                <h3
                  class="font-display leading-[1.0] mb-4 text-cream group-hover:text-terracotta transition-colors duration-500 ease-editorial"
                  style={`font-size: clamp(${dominant ? '2.75rem' : '1.75rem'}, ${dominant ? '5vw' : '3vw'}, ${dominant ? '4.5rem' : '2.75rem'}); letter-spacing: -0.035em;`}
                >
                  {id.label}.
                </h3>
                <p class={`font-serif text-cream/85 leading-[1.5] mb-5 max-w-prose ${dominant ? 'text-[1.0625rem] sm:text-[1.125rem]' : 'text-[0.9375rem]'}`}>
                  {id.body}
                </p>
                <span class="inline-flex items-center gap-2 text-[0.75rem] tracking-[0.1em] text-cream font-medium group-hover:gap-3 transition-all duration-300 ease-editorial">
                  {id.cta}
                  <span class="grid place-items-center h-6 w-6 rounded-full bg-cream/15 backdrop-blur-md border border-cream/20">
                    <ArrowUpRight size={10} class="text-cream" />
                  </span>
                </span>
              </div>
            </figure>
          </a>
        );
      })}
    </div>
  </div>
</section>

<script>
  // Subtle 3D tilt on identity-card hover — gives the cards real depth.
  if (matchMedia('(prefers-reduced-motion: no-preference)').matches && matchMedia('(pointer: fine)').matches) {
    const cards = document.querySelectorAll<HTMLElement>('[data-identity-card]');
    cards.forEach((card) => {
      const figure = card.querySelector<HTMLElement>('[data-identity-figure]');
      if (!figure) return;
      const maxTilt = 4;
      card.addEventListener('pointermove', (e) => {
        const rect = card.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width - 0.5;
        const py = (e.clientY - rect.top) / rect.height - 0.5;
        figure.style.transform = `perspective(1500px) rotateY(${px * maxTilt}deg) rotateX(${-py * maxTilt}deg) translateZ(0)`;
      });
      card.addEventListener('pointerleave', () => {
        figure.style.transform = '';
      });
    });
  }
</script>
