---
// Become Her — Stan Store ambient embed.
// Designed as a premium product card that LOOKS embedded. Wraps the
// book cover + product details + Stan-branded "Get it on Stan" CTA.
// Tap-through opens stan.store/allaia in a new tab.
import { book, site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<section id="stan" class="relative scroll-mt-28 py-24 sm:py-32 lg:py-40 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-1/3 left-1/4 h-[55vh] w-[55vh] rounded-full opacity-30 blur-[140px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.5), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal max-w-3xl mb-12 sm:mb-16">
      <p class="eyebrow mb-5">Available · Stan Store</p>
      <h2 class="display-md">
        Become her, <span class="italic-grad">in your hands.</span>
      </h2>
    </div>

    <!-- The embedded card — designed to feel like a Stan product surface -->
    <article class="reveal relative bg-bone rounded-[2rem] overflow-hidden border border-ink/8 shadow-anthracite">
      <div class="grid lg:grid-cols-[1.05fr_1fr] gap-0">
        <!-- LEFT: the cover, dramatic anthracite stage -->
        <div class="relative aspect-[4/5] lg:aspect-auto lg:min-h-[520px] flex items-center justify-center p-10 sm:p-14 overflow-hidden"
             style="background: linear-gradient(160deg, #0E0D0B 0%, #1F1B16 60%, #2A2722 100%);">
          <!-- Warm wash behind the cover -->
          <div
            class="absolute inset-0 opacity-60 pointer-events-none"
            style="background: radial-gradient(ellipse 70% 70% at 50% 40%, rgba(184,85,66,0.45), transparent 70%);"
            aria-hidden="true"
          ></div>
          <figure class="relative w-full max-w-[280px] sm:max-w-[320px]">
            <div class="relative aspect-[2/3] rounded-[1rem] overflow-hidden shadow-[0_40px_120px_-20px_rgba(184,85,66,0.55),0_0_0_1px_rgba(242,237,229,0.08)_inset] bg-anthracite">
              <img
                src={book.cover}
                alt={`${book.title} — book cover`}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
                decoding="async"
                onerror="this.style.display='none'"
              />
              <!-- CSS book-cover fallback if image missing -->
              <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center"
                   style="background: linear-gradient(160deg, #1A1A1A 0%, #2A2722 100%);">
                <span class="text-[0.5625rem] tracking-[0.32em] uppercase text-cream/55 mb-8 font-medium">a debut</span>
                <h3 class="font-display font-black text-cream text-4xl sm:text-5xl leading-[0.95] mb-3">
                  Become<br/><span class="italic font-medium text-terracotta">her.</span>
                </h3>
                <span class="text-[0.5625rem] tracking-[0.28em] uppercase text-cream/45 mt-8">Allaia</span>
              </div>
            </div>
            <figcaption class="sr-only">{book.title} cover</figcaption>
          </figure>
        </div>

        <!-- RIGHT: product details + Stan CTA -->
        <div class="p-8 sm:p-12 flex flex-col justify-center">
          <!-- Stan Store identity strip -->
          <div class="flex items-center gap-3 mb-7">
            <span class="grid place-items-center h-8 w-8 rounded-full bg-ink text-cream font-display italic font-black text-base leading-none">s</span>
            <div>
              <p class="text-[0.625rem] uppercase tracking-[0.22em] text-ink-mute font-medium">Sold on</p>
              <p class="font-display italic text-base text-ink leading-tight">Stan Store</p>
            </div>
            <span class="ml-auto h-2 w-2 rounded-full bg-sage" aria-hidden="true"></span>
            <span class="text-[0.625rem] uppercase tracking-[0.18em] text-ink-mute">Live</span>
          </div>

          <p class="byline text-ink-mute mb-4">{book.meta}</p>
          <h3 class="font-display text-ink text-[clamp(2rem,3.5vw,2.75rem)] leading-[1.06] mb-3">
            {book.title}.
          </h3>
          <p class="font-display italic text-brown text-lg sm:text-xl leading-tight mb-7">
            {book.subtitle}
          </p>

          <p class="serif-body text-ink-soft mb-8 max-w-prose">
            {book.blurb}
          </p>

          <ul class="space-y-2.5 byline text-ink-mute mb-9">
            <li class="flex items-baseline gap-3 pb-2.5 border-b border-ink/8">
              <span class="text-ink w-32">Format</span>
              <span>First edition · print</span>
            </li>
            <li class="flex items-baseline gap-3 pb-2.5 border-b border-ink/8">
              <span class="text-ink w-32">Length</span>
              <span>91,294 words</span>
            </li>
            <li class="flex items-baseline gap-3 pb-2.5 border-b border-ink/8">
              <span class="text-ink w-32">Parts</span>
              <span>Five — twenty-two chapters</span>
            </li>
            <li class="flex items-baseline gap-3">
              <span class="text-ink w-32">Sold on</span>
              <span>{site.stan.book.replace('https://', '')}</span>
            </li>
          </ul>

          <a
            href={site.stan.book}
            target="_blank"
            rel="noopener"
            class="group inline-flex items-center justify-center gap-2.5 py-4 px-7 rounded-full bg-ink text-cream font-medium tracking-tight transition-all duration-300 ease-editorial hover:bg-anthracite hover:-translate-y-0.5"
          >
            <span class="grid place-items-center h-5 w-5 rounded-full bg-cream text-ink font-display italic font-black text-xs leading-none">s</span>
            <span>Get it on Stan</span>
            <ArrowUpRight size={12} class="transition-transform group-hover:translate-x-0.5" />
          </a>

          <p class="byline text-ink-mute mt-4">
            Opens at <a href={site.stan.book} target="_blank" rel="noopener" class="text-ink hover:text-terracotta transition-colors duration-300 ease-editorial">{site.stan.book.replace('https://', '')}</a>
          </p>
        </div>
      </div>
    </article>
  </div>
</section>
