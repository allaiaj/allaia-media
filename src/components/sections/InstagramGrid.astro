---
// Editorial Instagram masonry — uses real photos from @allaia.power.
// Hover-reveal caption layer, tap-out to her IG.
import Instagram from '@components/icons/Instagram.astro';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
import { site } from '@data/site';

const posts = [
  { id: 1, image: '/img/portraits/DV2vp-hiJzx.jpg', caption: 'On letting yourself be seen.' },
  { id: 2, image: '/img/portraits/DVEQKoVj4DN.jpg', caption: 'A free spirit, in transit.' },
  { id: 3, image: '/img/portraits/DW5oFrOGIv_.jpg', caption: 'The dream life — slow and on purpose.' },
  { id: 4, image: '/img/portraits/DWlfa4-lOuC.jpg', caption: 'Between Dubai and Bali, between the rooms.' },
  { id: 5, image: '/img/portraits/DXdmLBNFHa8.jpg', caption: 'A life that moves on its own terms.' },
  { id: 6, image: '/img/portraits/DXv8snOlDS-.jpg', caption: 'The work is the woman you are becoming.' },
  { id: 7, image: '/img/instagram/reel-DZTyZlzMrJO.jpg', caption: 'Architecture of a quietly compounding life.' },
  { id: 8, image: '/img/instagram/reel-DZTtOngsOBG.jpg', caption: 'Sundays — for the slow things.' },
];
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Atmospheric layer -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-1/4 right-0 h-[50vh] w-[50vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.5), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[55vh] w-[55vh] rounded-full opacity-30 blur-[140px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal flex items-baseline justify-between gap-6 mb-14 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">Recent · @allaia.power</p>
        <h2 class="display-md max-w-2xl">
          The <span class="italic-grad">feed</span>, lightly curated.
        </h2>
      </div>
      <a href={site.instagram} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial inline-flex items-center gap-2">
        <Instagram size={13} /> Follow
      </a>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
      {posts.map((p, i) => (
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener"
          class="reveal group block"
          style={`transition-delay: ${(i % 4) * 60}ms`}
        >
          <figure class="relative aspect-square rounded-[1rem] overflow-hidden bg-bone shadow-photo">
            <img
              src={p.image}
              alt={p.caption}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover photo-warm transition-transform duration-[1000ms] ease-editorial group-hover:scale-[1.05]"
            />

            <!-- Hover caption layer -->
            <div class="absolute inset-x-0 bottom-0 p-4 text-cream opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-editorial">
              <p class="font-display italic text-sm leading-snug line-clamp-3">{p.caption}</p>
            </div>
            <div
              class="absolute inset-0 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 ease-editorial"
              style="background: linear-gradient(to top, rgba(14,13,11,0.75), transparent 50%);"
              aria-hidden="true"
            ></div>
          </figure>
        </a>
      ))}
    </div>

    <div class="reveal mt-14 flex items-center justify-center">
      <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark">
        <Instagram size={14} /> @allaia.power <ArrowUpRight size={12} />
      </a>
    </div>
  </div>
</section>
