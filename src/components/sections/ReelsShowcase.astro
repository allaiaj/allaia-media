---
// "The diary, in motion" — Allaia's vertical content, now using
// YouTube Shorts embeds for TRUE inline playback. IG embeds only
// show a poster + "View on Instagram" link (they intentionally
// don't autoplay from external sites). YT Shorts embed plays
// inline like any normal YouTube video.
import { site, youtubeShorts } from '@data/site';
import Youtube from '@components/icons/Youtube.astro';
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Atmospheric layer -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-1/4 h-[50vh] w-[50vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[45vh] w-[45vh] rounded-full opacity-32 blur-[120px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 mb-12 sm:mb-16">
    <div class="reveal flex items-baseline justify-between gap-6 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">In motion</p>
        <h2 class="display-md max-w-2xl">
          The <span class="italic-grad">diary</span>, in motion.
        </h2>
      </div>
      <a href={site.youtube} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial whitespace-nowrap inline-flex items-center gap-2">
        <Youtube size={13} /> {site.youtubeHandle}
      </a>
    </div>
    <p class="reveal serif-body text-ink-soft max-w-prose mt-6">
      Tap any short to play it right here — no jumping out to YouTube.
    </p>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {youtubeShorts.map((short, i) => (
        <li class="reveal" style={`transition-delay: ${(i % 3) * 70}ms`}>
          <div
            class="relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm shadow-photo group"
            data-yt-shell
            data-yt-id={short.video_id}
          >
            <!-- Poster — visible until tap -->
            <button
              type="button"
              class="absolute inset-0 w-full h-full cursor-pointer"
              aria-label={`Play short: ${short.caption}`}
              data-yt-play
            >
              <img
                src={short.thumbnail}
                alt={short.caption}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-editorial group-hover:scale-[1.04]"
              />
              <div
                class="absolute inset-0 pointer-events-none"
                style="background: radial-gradient(ellipse at 50% 100%, rgba(14,13,11,0.55) 0%, transparent 60%);"
                aria-hidden="true"
              ></div>
              <!-- Play affordance -->
              <span class="absolute inset-0 grid place-items-center">
                <span class="h-16 w-16 sm:h-20 sm:w-20 rounded-full bg-cream/20 backdrop-blur-md border border-cream/35 grid place-items-center group-hover:bg-cream/35 group-hover:scale-110 transition-all duration-500 ease-editorial">
                  <svg width="20" height="20" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M4 2.5L11 7l-7 4.5v-9Z" fill="#F2EDE5"/>
                  </svg>
                </span>
              </span>
              <!-- Caption -->
              <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 text-cream pointer-events-none">
                <p class="font-display italic text-base sm:text-lg leading-snug drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]">
                  {short.caption}
                </p>
              </div>
            </button>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  // Click-to-play — true inline YouTube playback. The YouTube
  // embed (unlike Instagram's) actually plays the video right
  // there with autoplay=1 instead of redirecting out.
  document.querySelectorAll<HTMLElement>('[data-yt-shell]').forEach((shell) => {
    const btn = shell.querySelector<HTMLButtonElement>('[data-yt-play]');
    const id = shell.getAttribute('data-yt-id');
    if (!btn || !id) return;
    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full';
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1&playsinline=1&color=white&loop=1&playlist=${id}`;
      iframe.title = btn.getAttribute('aria-label') ?? 'YouTube short';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      shell.replaceChildren(iframe);
    }, { once: true });
  });
</script>
