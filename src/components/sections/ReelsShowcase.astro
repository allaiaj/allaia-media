---
// Reels — Allaia's actual IG reels (the ones she sent). The cover
// frame is shown as a poster; on tap, the IG embed iframe swaps in.
// The IG embed iframe plays the video right there once you tap the
// play button inside it.
import { site, instagramReels } from '@data/site';
import Instagram from '@components/icons/Instagram.astro';

const shortcodeOf = (permalink: string) => {
  const m = permalink.match(/\/reel\/([A-Za-z0-9_-]+)/);
  return m ? m[1] : '';
};
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Atmospheric layer -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-1/4 h-[50vh] w-[50vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[45vh] w-[45vh] rounded-full opacity-32 blur-[120px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 mb-12 sm:mb-16">
    <div class="reveal flex items-baseline justify-between gap-6 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">Reels · @allaia.power</p>
        <h2 class="display-md max-w-2xl">
          The <span class="italic-grad">diary</span>, in motion.
        </h2>
      </div>
      <a href={site.instagram} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial whitespace-nowrap inline-flex items-center gap-2">
        <Instagram size={13} /> Follow
      </a>
    </div>
    <p class="reveal serif-body text-ink-soft max-w-prose mt-6">
      Tap any reel to play it here.
    </p>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <ul class="reels-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6" data-reels-grid>
      {instagramReels.map((reel, i) => {
        const sc = shortcodeOf(reel.permalink);
        return (
          <li class="reveal reel-item" style={`transition-delay: ${(i % 3) * 70}ms`} data-reel-index={i}>
            <div
              class="reel-shell relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm shadow-photo group"
              data-reel-shell
              data-reel-shortcode={sc}
            >
              <!-- Poster — visible until tap -->
              <button
                type="button"
                class="absolute inset-0 w-full h-full cursor-pointer"
                aria-label="Play reel"
                data-reel-play
              >
                <img
                  src={reel.poster}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="reel-poster absolute inset-0 w-full h-full object-cover"
                />
                <!-- Bottom vignette -->
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: radial-gradient(ellipse at 50% 100%, rgba(14,13,11,0.5) 0%, transparent 60%);"
                  aria-hidden="true"
                ></div>
                <!-- LIVE chip — pulses to signal "playing now" feel -->
                <div class="reel-live absolute top-3 left-3 sm:top-4 sm:left-4 flex items-center gap-1.5 px-2 py-1 rounded-full bg-anthracite/55 backdrop-blur-md">
                  <span class="relative flex h-1.5 w-1.5">
                    <span class="absolute inline-flex h-full w-full rounded-full bg-terracotta opacity-75 animate-ping"></span>
                    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-terracotta"></span>
                  </span>
                  <span class="text-[0.5625rem] uppercase tracking-[0.18em] text-cream/90 font-medium">Reel</span>
                </div>
                <!-- Now-playing progress bar at bottom (animated) -->
                <span class="reel-progress absolute inset-x-0 bottom-0 h-[3px] bg-cream/15 overflow-hidden" aria-hidden="true">
                  <span class="reel-progress-fill block h-full w-full origin-left bg-cream/85"></span>
                </span>
                <!-- Play affordance -->
                <span class="absolute inset-0 grid place-items-center">
                  <span class="reel-play-btn h-16 w-16 sm:h-20 sm:w-20 rounded-full bg-cream/20 backdrop-blur-md border border-cream/35 grid place-items-center transition-all duration-500 ease-editorial">
                    <svg width="20" height="20" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M4 2.5L11 7l-7 4.5v-9Z" fill="#F2EDE5"/>
                    </svg>
                  </span>
                </span>
              </button>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  /* Slow ken-burns so every poster feels like a paused video */
  .reel-poster {
    transform-origin: 50% 50%;
    animation: reel-kenburns 16s ease-in-out infinite alternate;
    will-change: transform;
  }
  .reel-item[data-reel-index="1"] .reel-poster { animation-delay: -3s; }
  .reel-item[data-reel-index="2"] .reel-poster { animation-delay: -6s; }
  .reel-item[data-reel-index="3"] .reel-poster { animation-delay: -9s; }
  .reel-item[data-reel-index="4"] .reel-poster { animation-delay: -12s; }
  @keyframes reel-kenburns {
    0%   { transform: scale(1.02) translate3d(0, 0, 0); }
    50%  { transform: scale(1.07) translate3d(-1.5%, -1%, 0); }
    100% { transform: scale(1.04) translate3d(1.5%, 1%, 0); }
  }

  /* Spotlight cycle — one card lifts + glows in turn so the row feels
     like it's playing through reel after reel. Driven by .is-playing
     toggled by the script. */
  .reel-shell {
    transition:
      transform 700ms cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 700ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .reel-item.is-playing .reel-shell {
    transform: translateY(-6px) scale(1.012);
    box-shadow:
      0 30px 80px -20px rgba(184,85,66,0.55),
      0 0 0 1px rgba(242,237,229,0.18) inset,
      0 0 60px -10px rgba(184,85,66,0.45);
  }
  .reel-item.is-playing .reel-poster {
    animation-play-state: running;
  }
  .reel-item:not(.is-playing) .reel-poster {
    filter: brightness(0.88) saturate(0.92);
    transition: filter 700ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .reel-item.is-playing .reel-poster {
    filter: brightness(1.04) saturate(1);
  }

  /* Animated bottom progress bar — fills left-to-right while is-playing */
  .reel-progress-fill { transform: scaleX(0); }
  .reel-item.is-playing .reel-progress-fill {
    animation: reel-progress 4s linear forwards;
  }
  @keyframes reel-progress {
    0%   { transform: scaleX(0); }
    100% { transform: scaleX(1); }
  }

  /* Play button gentle pulse — feels like the next thing about to fire */
  .reel-item.is-playing .reel-play-btn {
    background-color: rgba(242, 237, 229, 0.4);
    transform: scale(1.08);
  }
  .reel-play-btn {
    animation: reel-pulse 2.6s ease-in-out infinite;
  }
  @keyframes reel-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(242, 237, 229, 0.25); }
    50%      { box-shadow: 0 0 0 14px rgba(242, 237, 229, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reel-poster, .reel-play-btn, .reel-progress-fill { animation: none !important; }
    .reel-item.is-playing .reel-shell { transform: none; }
  }
</style>

<script>
  // Click-to-play swaps the poster button for IG's embed iframe.
  document.querySelectorAll<HTMLElement>('[data-reel-shell]').forEach((shell) => {
    const btn = shell.querySelector<HTMLButtonElement>('[data-reel-play]');
    const sc = shell.getAttribute('data-reel-shortcode');
    if (!btn || !sc) return;
    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full';
      iframe.src = `https://www.instagram.com/reel/${sc}/embed/`;
      iframe.title = 'Instagram reel';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture; web-share; fullscreen';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.style.border = '0';
      // Stop the spotlight cycle for this card once it's a live iframe
      shell.closest<HTMLElement>('.reel-item')?.classList.add('is-active-iframe');
      shell.replaceChildren(iframe);
    }, { once: true });
  });

  // Auto-spotlight cycle — every 4s, advance the "playing" card so the
  // row feels like it's stepping through reels in sequence. Stops on
  // hover so the user can tap; pauses when the section is off-screen.
  if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const grid = document.querySelector<HTMLElement>('[data-reels-grid]');
    if (grid) {
      const items = Array.from(grid.querySelectorAll<HTMLElement>('.reel-item'));
      let idx = 0;
      let timer: ReturnType<typeof setInterval> | null = null;
      let hovering = false;
      let visible = false;

      const step = () => {
        // Skip items that have already become live iframes
        let safety = 0;
        while (items[idx]?.classList.contains('is-active-iframe') && safety < items.length) {
          idx = (idx + 1) % items.length;
          safety++;
        }
        items.forEach((el, k) => el.classList.toggle('is-playing', k === idx));
        idx = (idx + 1) % items.length;
      };
      const start = () => {
        if (timer || !visible || hovering) return;
        step();
        timer = setInterval(step, 4000);
      };
      const stop = () => {
        if (timer) { clearInterval(timer); timer = null; }
      };

      grid.addEventListener('pointerenter', () => { hovering = true; stop(); });
      grid.addEventListener('pointerleave', () => { hovering = false; start(); });

      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          visible = e.isIntersecting;
          if (visible) start(); else { stop(); items.forEach((el) => el.classList.remove('is-playing')); }
        });
      }, { threshold: 0.2 });
      io.observe(grid);
    }
  }
</script>
