---
// Instagram Reels — the real ones, with real view counts.
// Uses Instagram's official embed: each reel renders as the full
// IG card (video player, caption, like + view count, account link).
// The IG embed.js script is loaded once on the page and processes
// every blockquote.instagram-media element.
//
// To swap in real reels, edit src/data/site.ts → instagramReels.
import { site, instagramReels } from '@data/site';
import Instagram from '@components/icons/Instagram.astro';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<section class="relative py-24 sm:py-32 lg:py-40 bg-cream overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 mb-12 sm:mb-16">
    <div class="reveal flex items-baseline justify-between gap-6 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">Reels · @allaia.power</p>
        <h2 class="display-md max-w-2xl">
          The diary, <span class="italic-grad">in motion.</span>
        </h2>
      </div>
      <a href={site.instagram} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial inline-flex items-center gap-2 whitespace-nowrap">
        <Instagram size={13} /> Follow
      </a>
    </div>
    <p class="reveal serif-body text-ink-soft max-w-prose mt-7">
      Live from Instagram — the embed below pulls each reel directly from <a href={site.instagram} target="_blank" rel="noopener" class="text-ink hover:text-terracotta transition-colors duration-300 ease-editorial underline decoration-ink/20 underline-offset-4">@allaia.power</a>, with the real view + like counts on the card.
    </p>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {instagramReels.map((reel, i) => {
        const isPending = reel.permalink.includes('REPLACE_WITH');
        return (
          <li class="reveal" style={`transition-delay: ${(i % 3) * 80}ms`}>
            {isPending ? (
              <div class="aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-bone border border-dashed border-ink/15 grid place-items-center p-6 text-center">
                <div>
                  <p class="byline text-ink-mute mb-3">Slot 0{i + 1}</p>
                  <p class="font-display italic text-xl text-brown leading-snug mb-2">Pending reel URL.</p>
                  <p class="serif-body text-ink-mute">{reel.caption}</p>
                </div>
              </div>
            ) : (
              <div class="relative bg-bone rounded-[1.25rem] overflow-hidden shadow-photo">
                <blockquote
                  class="instagram-media w-full !min-w-0 !my-0"
                  data-instgrm-permalink={reel.permalink}
                  data-instgrm-version="14"
                  style="background:#FFF; border:0; margin:0; padding:0; width:100%;"
                >
                  <div class="p-6">
                    <p class="micro tracking-[0.22em] uppercase text-ink-mute mb-3">Loading reel · 0{i + 1}</p>
                    <p class="font-display italic text-lg text-ink leading-snug mb-4">{reel.caption}</p>
                    <a
                      href={reel.permalink}
                      target="_blank"
                      rel="noopener"
                      class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial inline-flex items-center gap-2"
                    >
                      Open on Instagram <ArrowUpRight size={11} />
                    </a>
                  </div>
                </blockquote>
              </div>
            )}
          </li>
        );
      })}
    </ul>

    <div class="reveal mt-12 sm:mt-16 pt-10 border-t border-ink/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <p class="font-display italic text-xl text-brown leading-tight max-w-md">
        Posted weekly. Reach numbers are the receipts.
      </p>
      <a href={site.instagram} target="_blank" rel="noopener" class="cta-dark">
        <Instagram size={14} /> Follow @allaia.power <ArrowUpRight size={12} />
      </a>
    </div>
  </div>
</section>

<script is:inline async src="//www.instagram.com/embed.js"></script>
