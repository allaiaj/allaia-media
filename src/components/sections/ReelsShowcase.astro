---
// The diary, in motion — six of Allaia's vertical shorts that
// actually autoplay (muted + looped) when they scroll into view.
// Uses YouTube Shorts embeds because IG iframe doesn't permit
// autoplay from external sites. Same vertical content she
// cross-posts on @allaia.power.
//
// Performance:
// - Iframes only load when the section enters the viewport
//   (IntersectionObserver below the fold).
// - When the section scrolls out, iframes pause via postMessage
//   so we don't keep video pipelines active.
// - Posters are shown until the iframe is ready, so the layout
//   never reflows.
import { site, youtubeShorts } from '@data/site';
import Youtube from '@components/icons/Youtube.astro';
import Instagram from '@components/icons/Instagram.astro';
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Atmospheric layer -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-1/4 h-[50vh] w-[50vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[45vh] w-[45vh] rounded-full opacity-32 blur-[120px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 mb-12 sm:mb-16">
    <div class="reveal flex items-baseline justify-between gap-6 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">In motion · {site.youtubeHandle}</p>
        <h2 class="display-md max-w-2xl">
          The <span class="italic-grad">diary</span>, in motion.
        </h2>
      </div>
      <a href={site.instagram} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial whitespace-nowrap inline-flex items-center gap-2">
        <Instagram size={13} /> Follow
      </a>
    </div>
    <p class="reveal serif-body text-ink-soft max-w-prose mt-6">
      Playing silently. Tap any short to unmute.
    </p>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6" data-shorts-grid>
      {youtubeShorts.slice(0, 6).map((short, i) => (
        <li class="reveal" style={`transition-delay: ${(i % 3) * 70}ms`}>
          <div
            class="short-shell relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm shadow-photo group"
            data-short-shell
            data-short-id={short.video_id}
          >
            <!-- Poster — visible until iframe loads -->
            <img
              src={short.thumbnail}
              alt={short.caption}
              loading="lazy"
              decoding="async"
              class="short-poster absolute inset-0 w-full h-full object-cover"
            />
            <!-- Bottom vignette + caption -->
            <div
              class="absolute inset-x-0 bottom-0 p-4 sm:p-5 z-[2] pointer-events-none text-cream"
              style="background: linear-gradient(to top, rgba(14,13,11,0.75) 0%, transparent 80%);"
            >
              <p class="font-display italic text-base sm:text-lg leading-snug drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]">
                {short.caption}
              </p>
            </div>
            <!-- LIVE chip -->
            <div class="absolute top-3 left-3 sm:top-4 sm:left-4 z-[2] flex items-center gap-1.5 px-2 py-1 rounded-full bg-anthracite/55 backdrop-blur-md pointer-events-none">
              <span class="relative flex h-1.5 w-1.5">
                <span class="absolute inline-flex h-full w-full rounded-full bg-terracotta opacity-75 animate-ping"></span>
                <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-terracotta"></span>
              </span>
              <span class="text-[0.5625rem] uppercase tracking-[0.18em] text-cream/90 font-medium">Live</span>
            </div>
            <!-- Tap-to-unmute hint, hidden once iframe is interactive -->
            <button
              type="button"
              class="short-unmute absolute top-3 right-3 sm:top-4 sm:right-4 z-[3] flex items-center gap-1.5 px-2 py-1 rounded-full bg-cream/20 backdrop-blur-md border border-cream/30 text-cream text-[0.5625rem] uppercase tracking-[0.18em] font-medium hover:bg-cream/35 transition-colors duration-300 ease-editorial"
              data-short-unmute
              aria-label="Tap to unmute and open"
            >
              <svg width="11" height="11" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5h2l3-2.5v9L5 9H3V5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M10 5l3 4M13 5l-3 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              Unmute
            </button>
          </div>
        </li>
      ))}
    </ul>

    <div class="reveal mt-10 flex items-center justify-center">
      <a href={site.youtube} target="_blank" rel="noopener" class="cta-dark">
        <Youtube size={14} /> {site.youtubeHandle}
      </a>
    </div>
  </div>
</section>

<style>
  /* Slow ken-burns on the poster until the iframe paints */
  .short-poster {
    transform-origin: 50% 50%;
    animation: short-kenburns 18s ease-in-out infinite alternate;
    transition: opacity 600ms ease;
  }
  @keyframes short-kenburns {
    0%   { transform: scale(1.02) translate3d(0, 0, 0); }
    100% { transform: scale(1.07) translate3d(-1.5%, -1%, 0); }
  }
  .short-shell.is-playing .short-poster { opacity: 0; }

  /* Hide the unmute pill once iframe is live and user opens YT */
  .short-shell.has-iframe .short-unmute {
    background-color: rgba(242, 237, 229, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .short-poster { animation: none !important; }
  }
</style>

<script>
  // In-viewport autoplay. Only inject the YouTube iframe once the
  // card is intersected (saves a ton of bandwidth + main-thread
  // work above the fold). Pause iframes that scroll out so we don't
  // keep multiple video pipelines hot.
  const shells = Array.from(document.querySelectorAll<HTMLElement>('[data-short-shell]'));
  if (shells.length) {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    const ensureIframe = (shell: HTMLElement) => {
      if (shell.classList.contains('has-iframe')) return;
      const id = shell.getAttribute('data-short-id');
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full z-[1]';
      // mute=1 + playsinline=1 = browser-allowed autoplay
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&mute=1&loop=1&playlist=${id}&controls=0&rel=0&modestbranding=1&playsinline=1&color=white&enablejsapi=1`;
      iframe.title = shell.querySelector('img')?.alt ?? 'Short';
      iframe.setAttribute('frameborder', '0');
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      iframe.style.border = '0';
      // Insert iframe BEHIND the caption/chip/unmute layers (z-[1])
      shell.insertBefore(iframe, shell.firstChild);
      shell.classList.add('has-iframe', 'is-playing');
    };

    const postCommand = (shell: HTMLElement, func: 'pauseVideo' | 'playVideo' | 'unMute') => {
      const iframe = shell.querySelector<HTMLIFrameElement>('iframe');
      iframe?.contentWindow?.postMessage(
        JSON.stringify({ event: 'command', func, args: [] }),
        '*'
      );
    };

    // Tap-to-unmute (and pop to YouTube proper for full-volume control)
    shells.forEach((shell) => {
      const id = shell.getAttribute('data-short-id');
      const btn = shell.querySelector<HTMLButtonElement>('[data-short-unmute]');
      btn?.addEventListener('click', () => {
        if (shell.classList.contains('has-iframe')) {
          postCommand(shell, 'unMute');
        }
        // Open the short on YouTube in a new tab so volume is interactive
        if (id) window.open(`https://www.youtube.com/shorts/${id}`, '_blank', 'noopener');
      });
    });

    if (!reduced && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const shell = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            ensureIframe(shell);
            postCommand(shell, 'playVideo');
          } else if (shell.classList.contains('has-iframe')) {
            postCommand(shell, 'pauseVideo');
          }
        });
      }, { threshold: 0.35 });
      shells.forEach((s) => io.observe(s));
    } else {
      // No IO or reduced motion: leave posters as-is, no autoplay
    }
  }
</script>
