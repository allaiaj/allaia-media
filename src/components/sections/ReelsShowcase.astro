---
// Reels — clean editorial cards, NOW inline-playable. Click a card →
// the cover frame swaps in the Instagram embed iframe and the reel
// plays without leaving the page.
// Mute by default (browser autoplay rules) — user can unmute inside
// the IG embed. Each card has a small "Open on Instagram" footnote
// for the audience that wants to leave a comment / like.
import { site, instagramReels } from '@data/site';

// Each permalink ends in /reel/SHORTCODE/. Pull the shortcode out so
// we can build the embed iframe src directly.
const shortcodeOf = (permalink: string) => {
  const m = permalink.match(/\/reel\/([A-Za-z0-9_-]+)/);
  return m ? m[1] : '';
};
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Atmospheric layer -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-1/4 h-[50vh] w-[50vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-1/4 h-[45vh] w-[45vh] rounded-full opacity-32 blur-[120px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 mb-12 sm:mb-16">
    <div class="reveal flex items-baseline justify-between gap-6 pb-6 border-b border-ink/10">
      <div>
        <p class="eyebrow mb-4">In motion</p>
        <h2 class="display-md max-w-2xl">
          The <span class="italic-grad">diary</span>, in motion.
        </h2>
      </div>
      <a href={site.instagram} target="_blank" rel="noopener" class="byline text-ink-mute hover:text-terracotta transition-colors duration-300 ease-editorial whitespace-nowrap">
        @allaia.power
      </a>
    </div>
    <p class="reveal serif-body text-ink-soft max-w-prose mt-6">
      Tap a reel to play it here — no jumping out to Instagram.
    </p>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {instagramReels.map((reel, i) => {
        const sc = shortcodeOf(reel.permalink);
        return (
          <li class="reveal" style={`transition-delay: ${(i % 3) * 70}ms`}>
            <div
              class="relative aspect-[9/16] rounded-[1.25rem] overflow-hidden bg-anthracite-warm shadow-photo group"
              data-reel-shell
              data-reel-shortcode={sc}
            >
              <!-- Poster (cover frame) — visible until tap -->
              <button
                type="button"
                class="absolute inset-0 w-full h-full group cursor-pointer"
                aria-label="Play reel"
                data-reel-play
              >
                <img
                  src={reel.poster}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-editorial group-hover:scale-[1.04]"
                />
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: radial-gradient(ellipse at 50% 100%, rgba(14,13,11,0.45) 0%, transparent 60%);"
                  aria-hidden="true"
                ></div>
                <!-- Play affordance — scales with the card -->
                <span class="absolute inset-0 grid place-items-center">
                  <span class="h-16 w-16 sm:h-20 sm:w-20 rounded-full bg-cream/20 backdrop-blur-md border border-cream/35 grid place-items-center group-hover:bg-cream/35 group-hover:scale-110 transition-all duration-500 ease-editorial">
                    <svg width="20" height="20" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M4 2.5L11 7l-7 4.5v-9Z" fill="#F2EDE5"/>
                    </svg>
                  </span>
                </span>
              </button>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<script>
  // Click-to-play: swap the poster button for the IG embed iframe.
  document.querySelectorAll<HTMLElement>('[data-reel-shell]').forEach((shell) => {
    const btn = shell.querySelector<HTMLButtonElement>('[data-reel-play]');
    const sc = shell.getAttribute('data-reel-shortcode');
    if (!btn || !sc) return;
    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.className = 'absolute inset-0 w-full h-full';
      iframe.src = `https://www.instagram.com/reel/${sc}/embed/`;
      iframe.title = 'Instagram reel';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture; web-share; fullscreen';
      iframe.allowFullscreen = true;
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.style.border = '0';
      shell.replaceChildren(iframe);
    }, { once: true });
  });
</script>
