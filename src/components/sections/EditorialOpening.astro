---
import { editorialOpening } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<section class="relative py-24 sm:py-32 lg:py-40 border-t border-ink/8">
  <div class="mx-auto max-w-6xl px-6 grid lg:grid-cols-[0.85fr_1.15fr] gap-12 lg:gap-20 items-start">
    <figure class="reveal lg:sticky lg:top-32">
      <div class="aspect-[4/5] rounded-[1.75rem] overflow-hidden paper-grain bg-bone shadow-photo">
        <img
          src="/img/allaia/letter-portrait-placeholder.jpg"
          alt=""
          class="w-full h-full object-cover photo-warm"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <div
          class="absolute inset-0 z-0"
          style="background: linear-gradient(160deg, #F2EDE5, #E0D2BC);"
          aria-hidden="true"
        ></div>
      </div>
      <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
        <span>Photograph — Dubai, March 2026</span>
        <span>FIG. 02</span>
      </figcaption>
    </figure>

    <div>
      <p class="reveal eyebrow mb-7">{editorialOpening.eyebrow}</p>

      <h2 class="reveal display-lg text-ink mb-2">
        {editorialOpening.lead}
      </h2>
      <p class="reveal font-display italic text-2xl sm:text-3xl text-brown mb-9 leading-tight">
        {editorialOpening.sub}
      </p>

      <p class="reveal serif-lg text-ink-soft mb-6 max-w-prose">
        <span class="float-left font-display italic font-black text-7xl leading-[0.85] mr-3 mt-1 italic-grad">M</span>
        {editorialOpening.body.replace(/^M/, 'ainly')}
      </p>
      <p class="reveal serif-lg text-ink-soft mb-10 max-w-prose">
        {editorialOpening.body2}
      </p>

      <div class="reveal flex flex-col sm:flex-row gap-3 mb-8">
        {editorialOpening.ctas.map((cta) => (
          <a
            href={cta.href}
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener' : undefined}
            class={cta.primary ? 'cta-dark' : 'cta-ghost'}
          >
            {cta.label}
            <ArrowUpRight size={12} />
          </a>
        ))}
      </div>

      <p class="reveal byline text-ink-mute mt-12 pt-6 border-t border-ink/8 max-w-prose">
        By <span class="text-ink">Allaia</span>
        &nbsp;·&nbsp; Dubai + Bali
        &nbsp;·&nbsp; 2026
      </p>
    </div>
  </div>
</section>
