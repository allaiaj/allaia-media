---
import { editorialOpening } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

// Pull the first letter dynamically so the drop cap always matches
// the body's actual opening letter (fixes the stale "M" that hung
// around after the body copy was rewritten).
const firstLetter = editorialOpening.body.trim().charAt(0);
const bodyRest = editorialOpening.body.trim().slice(1);
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Local atmospheric depth -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute top-0 inset-x-0 h-[1px] bg-gradient-to-r from-transparent via-ink/15 to-transparent"></div>
    <div
      class="absolute top-1/4 left-[-10%] h-[55vh] w-[55vh] rounded-full opacity-40 blur-[140px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.4), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 right-0 h-[45vh] w-[45vh] rounded-full opacity-35 blur-[120px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.45), transparent 70%);"
    ></div>
  </div>
  <div class="mx-auto max-w-6xl px-6 grid lg:grid-cols-[0.85fr_1.15fr] gap-12 lg:gap-20 items-start">
    <figure class="reveal lg:sticky lg:top-32">
      <div class="aspect-[4/5] rounded-[1.75rem] overflow-hidden paper-grain bg-bone shadow-photo">
        <img
          src="/img/portraits/DV2vp-hiJzx.jpg"
          alt=""
          class="w-full h-full object-cover photo-warm"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
        <div
          class="absolute inset-0 z-0"
          style="background: linear-gradient(160deg, #F2EDE5, #E0D2BC);"
          aria-hidden="true"
        ></div>
      </div>
      <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
        <span class="uppercase tracking-[0.22em] text-[0.625rem]">Allaia</span>
        <span>FIG. 02</span>
      </figcaption>
    </figure>

    <div>
      <p class="reveal eyebrow mb-7">{editorialOpening.eyebrow}</p>

      <h2 class="reveal display-lg text-ink mb-2">
        {editorialOpening.lead}
      </h2>
      <p class="reveal font-display italic text-2xl sm:text-3xl text-brown mb-9 leading-tight">
        {editorialOpening.sub}
      </p>

      <p class="reveal serif-lg text-ink-soft mb-6 max-w-prose">
        <span class="float-left font-display italic font-black text-7xl leading-[0.85] mr-3 mt-1 italic-grad">{firstLetter}</span>
        {bodyRest}
      </p>
      <p class="reveal serif-lg text-ink-soft mb-10 max-w-prose">
        {editorialOpening.body2}
      </p>

      <div class="reveal flex flex-col sm:flex-row gap-3 mb-8">
        {editorialOpening.ctas.map((cta) => (
          <a
            href={cta.href}
            target={cta.external ? '_blank' : undefined}
            rel={cta.external ? 'noopener' : undefined}
            class={cta.primary ? 'cta-dark' : 'cta-ghost'}
          >
            {cta.label}
            <ArrowUpRight size={12} />
          </a>
        ))}
      </div>

      <p class="reveal byline text-ink-mute mt-12 pt-6 border-t border-ink/8 max-w-prose">
        By <span class="text-ink">Allaia</span>
      </p>
    </div>
  </div>
</section>
