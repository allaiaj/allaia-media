---
// Portrait scrub — sticky pinned scroll-driven portrait reveal.
// Lives BETWEEN the cinematic hero and the editorial opening.
// Allaia's face stays here, not on the hero (per her direction).
// 300vh outer / 100vh sticky inner. Image zooms + parallaxes,
// pinned text beats reveal as scroll progresses through.
---

<section
  class="portrait-scrub relative bg-bone"
  data-portrait-scrub
  aria-label="The woman behind the work"
>
  <!-- Outer track — controls scroll length -->
  <div class="ps-track relative" style="height: 320vh;">
    <div
      class="ps-stage sticky top-0 h-screen w-full overflow-hidden"
      style="perspective: 1200px; perspective-origin: 50% 50%;"
    >
      <!-- Backdrop tonal wash that shifts with progress -->
      <div
        class="ps-backdrop absolute inset-0 transition-colors duration-[1200ms]"
        data-ps-backdrop
        aria-hidden="true"
      ></div>

      <!-- Grain over backdrop -->
      <div
        class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-[0.06]"
        style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
        aria-hidden="true"
      ></div>

      <!-- Portrait — sits centered, scales + parallaxes on scroll -->
      <figure
        class="ps-portrait absolute"
        data-ps-portrait
        style="left: 50%; top: 50%; transform: translate(-50%, -50%); width: clamp(280px, 32vw, 460px);"
      >
        <div class="relative aspect-[4/5] rounded-[2rem] overflow-hidden shadow-photo bg-anthracite-warm paper-grain">
          <img
            src="/img/allaia/avatar.jpg"
            alt="Allaia — portrait"
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover photo-warm"
            style="object-position: 50% 35%;"
            data-ps-img
          />
          <!-- Subtle warm vignette over the bottom -->
          <div
            class="absolute inset-0 pointer-events-none"
            style="background: radial-gradient(ellipse at 50% 100%, rgba(14,13,11,0.45) 0%, transparent 60%);"
            aria-hidden="true"
          ></div>
        </div>
        <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute px-1">
          <span class="uppercase tracking-[0.22em] text-[0.625rem]">Allaia</span>
          <span data-ps-figN>FIG. 02</span>
        </figcaption>
      </figure>

      <!-- Text tower — left of portrait, beats fade through -->
      <div class="ps-type absolute inset-0 flex items-center pointer-events-none">
        <div class="mx-auto max-w-6xl px-6 w-full grid lg:grid-cols-[1fr_auto_1fr] gap-8 lg:gap-12 items-center">
          <!-- LEFT type column -->
          <div class="ps-type-col relative h-[60vh]">
            {[
              {
                eyebrow: 'THE WORK',
                head: 'An author.',
                italic: 'A coach.',
                body: 'The work is identity-led. The room is kept small — on purpose.',
              },
              {
                eyebrow: 'THE PRACTICE',
                head: 'A studio.',
                italic: 'A canvas.',
                body: 'A studio at scale. A practice that runs slow. Each expression carries the same thesis.',
              },
              {
                eyebrow: 'THE THESIS',
                head: 'Four expressions.',
                italic: 'One thesis.',
                body: 'What compounds is identity. Performance does not.',
              },
            ].map((b, i) => (
              <div
                class="ps-beat absolute inset-0 flex flex-col justify-center transition-opacity duration-[800ms]"
                data-ps-beat={i}
                style={`opacity: ${i === 0 ? 1 : 0};`}
              >
                <p class="eyebrow text-ink-mute mb-5">{b.eyebrow}</p>
                <h2 class="display-md text-ink leading-[1.06] mb-4">
                  <span class="block">{b.head}</span>
                  <span class="font-display italic font-medium italic-grad block">{b.italic}</span>
                </h2>
                <p class="serif-lg text-ink-soft max-w-prose">{b.body}</p>
              </div>
            ))}
          </div>

          <!-- spacer for portrait -->
          <div class="hidden lg:block" style="width: clamp(300px, 34vw, 480px);"></div>

          <!-- RIGHT column — counter + chapter progress -->
          <div class="hidden lg:flex flex-col items-end gap-6">
            <p class="font-mono text-[11px] tracking-widest text-ink-mute">
              <span data-ps-current>I</span>
              <span class="text-ink/25"> / III</span>
            </p>
            <div class="flex flex-col gap-2 items-end">
              {[0, 1, 2].map((i) => (
                <span class="ps-dot block h-px w-10 bg-ink/15 transition-all duration-500" data-ps-dot={i}></span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom rail -->
      <div class="absolute inset-x-0 bottom-6 sm:bottom-8 px-6 sm:px-10 flex items-end justify-between pointer-events-none">
        <span class="micro tracking-[0.24em] uppercase text-ink-mute">The portrait essay</span>
        <span class="font-mono text-[11px] tracking-widest text-ink-mute" data-ps-progress>00%</span>
      </div>
    </div>
  </div>
</section>

<style>
  .ps-backdrop {
    background: linear-gradient(160deg, #FAF6EE 0%, #F2EDE5 40%, #E8DDC9 100%);
  }
  .ps-stage[data-ps-tone="terracotta"] .ps-backdrop {
    background: linear-gradient(160deg, #F2EDE5 0%, #E8C9B7 60%, #B85542 130%);
  }
  .ps-stage[data-ps-tone="brown"] .ps-backdrop {
    background: linear-gradient(160deg, #F2EDE5 0%, #C7A48D 40%, #6B4F3D 100%);
  }
  .ps-portrait {
    transition: transform 1200ms cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
  }
  .ps-dot.is-active { width: 4rem; background: var(--color-terracotta); }
  @media (prefers-reduced-motion: reduce) {
    .ps-track { height: 100vh; }
    .ps-beat[data-ps-beat="0"] { opacity: 1 !important; }
    .ps-beat:not([data-ps-beat="0"]) { opacity: 0 !important; }
    .ps-portrait { transition: none !important; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-portrait-scrub]');
  if (root && matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const track = root.querySelector<HTMLElement>('.ps-track')!;
    const stage = root.querySelector<HTMLElement>('.ps-stage')!;
    const portrait = root.querySelector<HTMLElement>('[data-ps-portrait]')!;
    const img = root.querySelector<HTMLElement>('[data-ps-img]');
    const beats = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-beat]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-dot]'));
    const figN = root.querySelector<HTMLElement>('[data-ps-figN]');
    const curEl = root.querySelector<HTMLElement>('[data-ps-current]');
    const progressEl = root.querySelector<HTMLElement>('[data-ps-progress]');

    const tones = ['default', 'terracotta', 'brown'];
    const romans = ['I', 'II', 'III'];

    let last = 0;
    let activeIdx = -1;

    const setActive = (i: number) => {
      if (i === activeIdx) return;
      activeIdx = i;
      beats.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      dots.forEach((el, k) => el.classList.toggle('is-active', k === i));
      if (curEl) curEl.textContent = romans[i] ?? 'I';
      if (figN) figN.textContent = `FIG. 0${i + 2}`;
      stage.setAttribute('data-ps-tone', tones[i] ?? 'default');
    };

    const tick = () => {
      const rect = track.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const p = total > 0 ? scrolled / total : 0;
      last += (p - last) * 0.14;

      // Beat index — 3 beats over the scroll
      const idx = Math.min(2, Math.floor(last * 3 * 0.999));
      setActive(idx);

      // Portrait — scale + slow drift right as scroll progresses
      const scale = 1 + last * 0.18;
      const dx = -last * 60; // gentle pull toward the right column
      const dy = Math.sin(last * Math.PI * 1.2) * 14;
      portrait.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px)) scale(${scale})`;

      // Subtle img zoom for ken-burns inside the frame
      if (img) {
        const imgScale = 1 + last * 0.08;
        const imgY = last * -18;
        img.style.transform = `translateY(${imgY}px) scale(${imgScale})`;
      }

      // Progress %
      if (progressEl) progressEl.textContent = `${Math.round(last * 100)}%`;

      requestAnimationFrame(tick);
    };

    setActive(0);
    requestAnimationFrame(tick);
  }
</script>
