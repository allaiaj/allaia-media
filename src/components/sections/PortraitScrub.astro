---
// Portrait scrub — sticky pinned section between the cinematic hero
// and the editorial opening. Three different portraits cycle through
// as the user scrolls, one per beat. No more growing-zoom on the
// portrait container; just subtle ken-burns inside the frame.
//
// Desktop: clean 2-column grid — text left, portrait right
// Mobile : photo full-bleed background with warm scrim, text on top

const beats = [
  {
    eyebrow: 'THE LIFE',
    head: 'A free spirit.',
    italic: 'A life in motion.',
    body: 'Mainly between Dubai and Bali. Always in transit. A life that moves on its own terms — and proof, for the women building one of their own.',
    photo: '/img/portraits/DV2vp-hiJzx.jpg',
    figure: 'FIG. 02',
  },
  {
    eyebrow: 'THE WORK',
    head: 'A studio.',
    italic: 'A canvas.',
    body: 'A studio that ships at scale. A canvas practice that runs slow. A coaching room kept curated — on purpose.',
    photo: '/img/portraits/DXdmLBNFHa8.jpg',
    figure: 'FIG. 03',
  },
  {
    eyebrow: 'THE THESIS',
    head: 'You are not',
    italic: 'buying an offer.',
    body: 'You are buying the proof — that the dream life is built, slowly, by the woman who is already living one.',
    photo: '/img/portraits/DXv8snOlDS-.jpg',
    figure: 'FIG. 04',
  },
];
---

<section
  class="portrait-scrub relative bg-bone"
  data-portrait-scrub
  aria-label="Three portraits — the work, the practice, the thesis"
>
  <div class="ps-track relative" style="height: 320vh;">
    <div
      class="ps-stage sticky top-0 h-screen w-full overflow-hidden"
    >
      <!-- DESKTOP backdrop wash -->
      <div
        class="ps-backdrop hidden md:block absolute inset-0 transition-colors duration-[1200ms]"
        data-ps-backdrop
        aria-hidden="true"
      ></div>

      <!-- MOBILE: portrait stack full-bleed with scrim -->
      <div class="md:hidden absolute inset-0" aria-hidden="true">
        {beats.map((b, i) => (
          <div
            class="ps-mobile-photo absolute inset-0 transition-opacity duration-[500ms]"
            data-ps-mobile-photo={i}
            style={`opacity: ${i === 0 ? 1 : 0};`}
          >
            <img
              src={b.photo}
              alt=""
              loading={i === 0 ? 'eager' : 'lazy'}
              class="ps-mobile-img absolute inset-0 w-full h-full object-cover photo-warm"
            />
          </div>
        ))}
        <!-- Dark warm scrim so text reads -->
        <div
          class="absolute inset-0"
          style="background: linear-gradient(180deg, rgba(14,13,11,0.55) 0%, rgba(14,13,11,0.35) 40%, rgba(14,13,11,0.75) 100%);"
        ></div>
      </div>

      <!-- Grain overlay -->
      <div
        class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-[0.06]"
        style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
        aria-hidden="true"
      ></div>

      <!-- DESKTOP CONTENT — clean 2-column grid, no absolute overlap -->
      <div class="absolute inset-0 hidden md:flex items-center pointer-events-none">
        <div class="mx-auto max-w-[1280px] px-10 lg:px-16 w-full grid grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-20 items-center">
          <!-- LEFT: text beats stack (one shows at a time) -->
          <div class="relative h-[60vh] max-w-xl">
            {beats.map((b, i) => (
              <div
                class="ps-beat absolute inset-0 flex flex-col justify-center transition-opacity duration-[400ms]"
                data-ps-beat={i}
                style={`opacity: ${i === 0 ? 1 : 0};`}
              >
                <p class="eyebrow text-ink-mute mb-6">{b.eyebrow}</p>
                <h2 class="display-md text-ink leading-[1.06] mb-5">
                  <span class="block">{b.head}</span>
                  <span class="font-display italic font-medium italic-grad block">{b.italic}</span>
                </h2>
                <p class="serif-lg text-ink-soft max-w-prose">{b.body}</p>
              </div>
            ))}
          </div>

          <!-- RIGHT: portrait stack — 3 photos cross-fade per beat -->
          <div class="relative justify-self-center w-full max-w-[420px]">
            <figure class="relative">
              <div class="relative aspect-[4/5] rounded-[1.75rem] overflow-hidden bg-anthracite-warm paper-grain shadow-photo">
                {beats.map((b, i) => (
                  <div
                    class="ps-photo absolute inset-0 transition-opacity duration-[500ms]"
                    data-ps-photo={i}
                    style={`opacity: ${i === 0 ? 1 : 0};`}
                  >
                    <img
                      src={b.photo}
                      alt=""
                      loading={i === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                      class="ps-photo-img absolute inset-0 w-full h-full object-cover photo-warm"
                      style="object-position: 50% 30%;"
                    />
                  </div>
                ))}
                <!-- Bottom vignette -->
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: radial-gradient(ellipse at 50% 100%, rgba(14,13,11,0.4) 0%, transparent 60%);"
                  aria-hidden="true"
                ></div>
              </div>
              <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
                <span class="uppercase tracking-[0.22em] text-[0.625rem]">Allaia</span>
                <span data-ps-figN>FIG. 02</span>
              </figcaption>
            </figure>
          </div>
        </div>
      </div>

      <!-- MOBILE CONTENT — text on top of the scrim'd photo -->
      <div class="md:hidden absolute inset-0 flex flex-col justify-end pb-24 px-6 pointer-events-none">
        <div class="relative h-[40vh]">
          {beats.map((b, i) => (
            <div
              class="ps-mobile-beat absolute inset-0 flex flex-col justify-end transition-opacity duration-[400ms]"
              data-ps-mobile-beat={i}
              style={`opacity: ${i === 0 ? 1 : 0};`}
            >
              <p class="text-[0.625rem] uppercase tracking-[0.24em] text-cream/65 font-medium mb-4">{b.eyebrow}</p>
              <h2 class="font-display text-cream leading-[1.04] mb-4" style="font-size: clamp(2rem, 7vw, 2.75rem); letter-spacing: -0.025em;">
                <span class="block">{b.head}</span>
                <span class="font-display italic font-medium block" style="background: linear-gradient(135deg, #F2C2A8 0%, #E89878 55%, #C18B68 100%); -webkit-background-clip: text; background-clip: text; color: transparent; padding-bottom: 0.14em;">
                  {b.italic}
                </span>
              </h2>
              <p class="font-serif text-cream/85 text-[1.0625rem] leading-[1.55] max-w-prose">{b.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- DESKTOP rail: Roman + dots -->
      <div class="hidden md:flex absolute top-1/2 right-8 lg:right-12 -translate-y-1/2 flex-col items-end gap-6 pointer-events-none">
        <p class="font-mono text-[11px] tracking-widest text-ink-mute">
          <span data-ps-current>I</span>
          <span class="text-ink/25"> / III</span>
        </p>
        <div class="flex flex-col gap-2 items-end">
          {[0, 1, 2].map((i) => (
            <span class="ps-dot block h-px w-10 bg-ink/15 transition-all duration-500" data-ps-dot={i}></span>
          ))}
        </div>
      </div>

      <!-- MOBILE counter row top -->
      <div class="md:hidden absolute top-24 inset-x-6 flex items-center justify-between text-cream pointer-events-none">
        <p class="font-mono text-[10px] tracking-widest">
          <span data-ps-current-mobile>I</span>
          <span class="opacity-50"> / III</span>
        </p>
        <p class="text-[0.5625rem] uppercase tracking-[0.22em]">The portrait essay</p>
      </div>

      <!-- Bottom rail -->
      <div class="absolute inset-x-0 bottom-6 sm:bottom-8 px-6 sm:px-10 flex items-end justify-between pointer-events-none">
        <span class="text-[0.625rem] uppercase tracking-[0.24em] text-ink-mute hidden md:inline">The portrait essay</span>
        <span class="text-[0.625rem] uppercase tracking-[0.22em] text-cream/55 md:hidden" data-ps-figN-mobile>FIG. 02</span>
        <span class="font-mono text-[11px] tracking-widest text-ink-mute hidden md:inline" data-ps-progress>00%</span>
        <span class="font-mono text-[11px] tracking-widest text-cream/55 md:hidden" data-ps-progress-mobile>00%</span>
      </div>
    </div>
  </div>
</section>

<style>
  .ps-backdrop {
    background: linear-gradient(160deg, #FAF6EE 0%, #F2EDE5 40%, #E8DDC9 100%);
  }
  .ps-stage[data-ps-tone="warm"] .ps-backdrop {
    background: linear-gradient(160deg, #F2EDE5 0%, #E8C9B7 60%, #C7A48D 130%);
  }
  .ps-stage[data-ps-tone="brown"] .ps-backdrop {
    background: linear-gradient(160deg, #F2EDE5 0%, #C7A48D 40%, #8E6F58 100%);
  }
  /* Subtle ken-burns INSIDE the frame — not on the container */
  .ps-photo-img,
  .ps-mobile-img {
    transition: transform 1200ms cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
  }
  .ps-dot.is-active { width: 4rem; background: var(--color-terracotta); }

  @media (prefers-reduced-motion: reduce) {
    .ps-track { height: 100vh; }
    .ps-beat[data-ps-beat="0"],
    .ps-mobile-beat[data-ps-mobile-beat="0"],
    .ps-photo[data-ps-photo="0"],
    .ps-mobile-photo[data-ps-mobile-photo="0"] {
      opacity: 1 !important;
    }
    .ps-beat:not([data-ps-beat="0"]),
    .ps-mobile-beat:not([data-ps-mobile-beat="0"]),
    .ps-photo:not([data-ps-photo="0"]),
    .ps-mobile-photo:not([data-ps-mobile-photo="0"]) {
      opacity: 0 !important;
    }
    .ps-photo-img, .ps-mobile-img { transition: none !important; }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-portrait-scrub]');
  if (root && matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const track = root.querySelector<HTMLElement>('.ps-track')!;
    const stage = root.querySelector<HTMLElement>('.ps-stage')!;
    const beats = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-beat]'));
    const beatsMobile = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-mobile-beat]'));
    const photos = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-photo]'));
    const photoImgs = Array.from(root.querySelectorAll<HTMLElement>('.ps-photo-img'));
    const photosMobile = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-mobile-photo]'));
    const mobileImgs = Array.from(root.querySelectorAll<HTMLElement>('.ps-mobile-img'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-ps-dot]'));
    const figN = root.querySelector<HTMLElement>('[data-ps-figN]');
    const figNMobile = root.querySelector<HTMLElement>('[data-ps-figN-mobile]');
    const curEl = root.querySelector<HTMLElement>('[data-ps-current]');
    const curMobile = root.querySelector<HTMLElement>('[data-ps-current-mobile]');
    const progressEl = root.querySelector<HTMLElement>('[data-ps-progress]');
    const progressMobile = root.querySelector<HTMLElement>('[data-ps-progress-mobile]');

    const tones = ['default', 'warm', 'brown'];
    const romans = ['I', 'II', 'III'];
    const figs = ['FIG. 02', 'FIG. 03', 'FIG. 04'];

    let last = 0;
    let activeIdx = -1;

    const setActive = (i: number) => {
      if (i === activeIdx) return;
      activeIdx = i;
      beats.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      beatsMobile.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      photos.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      photosMobile.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      dots.forEach((el, k) => el.classList.toggle('is-active', k === i));
      if (curEl) curEl.textContent = romans[i] ?? 'I';
      if (curMobile) curMobile.textContent = romans[i] ?? 'I';
      if (figN) figN.textContent = figs[i] ?? 'FIG. 02';
      if (figNMobile) figNMobile.textContent = figs[i] ?? 'FIG. 02';
      stage.setAttribute('data-ps-tone', tones[i] ?? 'default');
    };

    // Only run the rAF while the section is on-screen. Two infinite
    // rAF loops (this one + the hero's) running together on iOS cause
    // measurable scroll jank, and contribute to the "page jumps back
    // up" reports — the heavy main-thread per-frame work fights with
    // the browser's scroll thread. IO pauses us when offscreen.
    let inView = false;
    let rafId = 0;

    const tick = () => {
      const rect = track.getBoundingClientRect();
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const p = total > 0 ? scrolled / total : 0;
      last += (p - last) * 0.14;

      const idx = Math.min(2, Math.floor(last * 3 * 0.999));
      setActive(idx);

      // Local progress within current scene → drives a subtle ken-burns
      // INSIDE the active photo frame only. Other photos sit still.
      const localP = (last * 3) - idx;
      const scale = 1.02 + Math.max(0, Math.min(1, localP)) * 0.04;
      const dy = -localP * 8;
      const tf = `translateY(${dy}px) scale(${scale})`;
      if (photoImgs[idx]) photoImgs[idx].style.transform = tf;
      if (mobileImgs[idx]) mobileImgs[idx].style.transform = `translateY(${dy * 1.5}px) scale(${scale + 0.02})`;

      const pct = `${Math.round(last * 100)}%`;
      if (progressEl) progressEl.textContent = pct;
      if (progressMobile) progressMobile.textContent = pct;

      if (inView) rafId = requestAnimationFrame(tick);
    };

    setActive(0);

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !inView) {
          inView = true;
          rafId = requestAnimationFrame(tick);
        } else if (!e.isIntersecting && inView) {
          inView = false;
          if (rafId) cancelAnimationFrame(rafId);
        }
      });
    }, { rootMargin: '50% 0px' });
    io.observe(root);
  }
</script>
