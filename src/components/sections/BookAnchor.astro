---
import { book } from '@data/site';
import { getCollection } from 'astro:content';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const parts = (await getCollection('bookChapters')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="book" class="relative scroll-mt-28 py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Section atmosphere — warmer tint, multiple depth layers -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(250,246,238,0.85) 0%, rgba(245,238,225,0.92) 50%, rgba(250,246,238,0.85) 100%);"></div>
    <div
      class="absolute top-0 right-0 h-[70vh] w-[70vh] rounded-full opacity-45 blur-[150px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.5), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-0 h-[55vh] w-[55vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(107,79,61,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-20 items-start">
      <!-- LEFT: cover -->
      <figure class="reveal relative lg:sticky lg:top-28">
        <div class="relative aspect-[2/3] max-w-[420px] mx-auto lg:mx-0 rounded-[1.5rem] overflow-hidden shadow-photo bg-anthracite">
          <!-- Fallback cover (CSS-rendered until the real artwork lands) -->
          <div
            class="absolute inset-0"
            style="background: #18181A;"
            aria-hidden="true"
          >
            <!-- Subtle textured paper noise -->
            <div
              class="absolute inset-0 opacity-[0.18] mix-blend-screen"
              style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
            ></div>
            <!-- Top mast row: "FOR THE WOMAN..." / "2026" / "ALLAIA POWER" -->
            <div class="absolute top-0 inset-x-0 pt-5 px-5">
              <div class="flex items-start justify-between text-cream text-[0.5rem] sm:text-[0.5625rem] tracking-[0.15em] uppercase font-medium leading-[1.3]">
                <span class="max-w-[40%]">For the woman<br/>who's done performing</span>
                <span class="self-center">2026</span>
                <span class="self-start">Allaia Power</span>
              </div>
              <!-- Hairline under the masthead -->
              <div class="mt-3 h-px bg-cream/35"></div>
            </div>
            <!-- Title block -->
            <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 px-6 text-center">
              <h3 class="font-sans font-black text-cream leading-[0.92] tracking-tight" style="font-size: clamp(2.25rem, 5.5vw, 3.75rem);">
                <span class="block">BECOME</span>
                <span class="block">HER</span>
              </h3>
              <p class="mt-7 font-display italic text-cream/85 leading-snug text-[0.875rem] sm:text-base max-w-[14rem] mx-auto">
                On the dethroning of the persona and the recovery of the Self.
              </p>
            </div>
            <!-- Bottom byline -->
            <div class="absolute bottom-7 inset-x-0 text-center">
              <p class="font-sans font-black text-cream tracking-[0.18em] text-[0.75rem] sm:text-[0.8125rem]">
                ALLAIA POWER
              </p>
            </div>
          </div>
          <!-- Real cover image painted on top once supplied -->
          <img
            src={book.cover}
            alt="Become Her — debut book cover by Allaia, 2026"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
          <span>{book.title} — first edition</span>
          <span>FIG. 03</span>
        </figcaption>
      </figure>

      <!-- RIGHT: meta + parts -->
      <div>
        <p class="reveal eyebrow mb-6">{book.meta}</p>
        <h2 class="reveal display-lg mb-6">
          {book.title.split(' ')[0]}{' '}
          <span class="italic-grad">{book.title.split(' ').slice(1).join(' ')}.</span>
        </h2>
        <p class="reveal serif-lg text-ink-soft mb-10 max-w-prose">
          {book.blurb}
        </p>

        <ol class="space-y-7 mb-10">
          {parts.map((p) => (
            <li class="reveal flex gap-6 pb-7 border-b border-ink/8 last:border-b-0">
              <div class="flex-none">
                <span class="font-display italic text-3xl sm:text-4xl text-terracotta leading-none block">
                  {p.data.part}
                </span>
                <span class="byline text-ink-mute block mt-2">
                  {p.data.chapters_count} ch.
                </span>
              </div>
              <div>
                <h3 class="font-display text-2xl sm:text-[1.75rem] text-ink leading-tight mb-2">
                  {p.data.part_title}
                </h3>
                <p class="serif-body text-ink-soft max-w-prose">
                  {p.data.description}
                </p>
              </div>
            </li>
          ))}
        </ol>

        <blockquote class="reveal pl-6 border-l-2 border-sage mb-10">
          <p class="pullquote italic-grad max-w-[28ch]">
            {book.endorsement.quote}
          </p>
          <p class="byline text-ink-mute mt-4">{book.endorsement.attribution}</p>
        </blockquote>

        <a
          href={book.cta.href}
          target="_blank"
          rel="noopener"
          class="cta-dark reveal"
        >
          {book.cta.label}
          <ArrowUpRight size={12} />
        </a>
      </div>
    </div>
  </div>
</section>
