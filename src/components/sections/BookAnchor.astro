---
import { book } from '@data/site';
import { getCollection } from 'astro:content';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const parts = (await getCollection('bookChapters')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="book" class="relative scroll-mt-28 py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Section atmosphere — warmer tint, multiple depth layers -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(250,246,238,0.85) 0%, rgba(245,238,225,0.92) 50%, rgba(250,246,238,0.85) 100%);"></div>
    <div
      class="absolute top-0 right-0 h-[70vh] w-[70vh] rounded-full opacity-45 blur-[150px]"
      style="background: radial-gradient(circle, rgba(184,85,66,0.5), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-0 h-[55vh] w-[55vh] rounded-full opacity-35 blur-[130px]"
      style="background: radial-gradient(circle, rgba(107,79,61,0.4), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-20 items-start">
      <!-- LEFT: cover -->
      <figure class="reveal relative lg:sticky lg:top-28">
        <div class="relative aspect-[2/3] max-w-[420px] mx-auto lg:mx-0 rounded-[1.5rem] overflow-hidden shadow-photo bg-anthracite">
          <img
            src={book.cover}
            alt="Become Her — debut book cover by Allaia, 2026"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.style.display='none'"
          />
          <!-- Fallback cover composition until real artwork lands -->
          <div class="absolute inset-0 flex flex-col items-center justify-center p-10 text-center"
               style="background: linear-gradient(160deg, #1A1A1A 0%, #2A2722 100%);">
            <span class="micro tracking-[0.32em] uppercase text-cream/55 mb-10">a debut · 2026</span>
            <h3 class="font-display font-black text-5xl sm:text-6xl text-cream leading-[0.95] mb-4">
              Become<br/><span class="italic font-medium text-terracotta">her.</span>
            </h3>
            <span class="micro tracking-[0.24em] uppercase text-cream/45 mt-10">
              Allaia
            </span>
          </div>
        </div>
        <figcaption class="mt-3 flex items-baseline justify-between byline text-ink-mute">
          <span>{book.title} — first edition</span>
          <span>FIG. 03</span>
        </figcaption>
      </figure>

      <!-- RIGHT: meta + parts -->
      <div>
        <p class="reveal eyebrow mb-6">{book.meta}</p>
        <h2 class="reveal display-lg mb-6">
          {book.title.split(' ')[0]}{' '}
          <span class="italic-grad">{book.title.split(' ').slice(1).join(' ')}.</span>
        </h2>
        <p class="reveal serif-lg text-ink-soft mb-10 max-w-prose">
          {book.blurb}
        </p>

        <ol class="space-y-7 mb-10">
          {parts.map((p) => (
            <li class="reveal flex gap-6 pb-7 border-b border-ink/8 last:border-b-0">
              <div class="flex-none">
                <span class="font-display italic text-3xl sm:text-4xl text-terracotta leading-none block">
                  {p.data.part}
                </span>
                <span class="byline text-ink-mute block mt-2">
                  {p.data.chapters_count} ch.
                </span>
              </div>
              <div>
                <h3 class="font-display text-2xl sm:text-[1.75rem] text-ink leading-tight mb-2">
                  {p.data.part_title}
                </h3>
                <p class="serif-body text-ink-soft max-w-prose">
                  {p.data.description}
                </p>
              </div>
            </li>
          ))}
        </ol>

        <blockquote class="reveal pl-6 border-l-2 border-sage mb-10">
          <p class="pullquote italic-grad max-w-[28ch]">
            {book.endorsement.quote}
          </p>
          <p class="byline text-ink-mute mt-4">{book.endorsement.attribution}</p>
        </blockquote>

        <a
          href={book.cta.href}
          target="_blank"
          rel="noopener"
          class="cta-dark reveal"
        >
          {book.cta.label}
          <ArrowUpRight size={12} />
        </a>
      </div>
    </div>
  </div>
</section>
