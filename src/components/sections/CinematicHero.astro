---
// CinematicHero — single full-bleed section with an autoplay-muted-loop
// video as the backdrop. Replaces the previous 500vh scroll-scrub
// (5 scenes pinned via position: sticky), which was the source of
// the mobile overlap + jank Allaia kept hitting. Video frames are
// GPU-decoded by the browser — no scroll math, no setActive() loop,
// just smooth motion.
//
// To wire the hero video: drop an MP4 at /public/img/hero/hero.mp4
// (and ideally a 1920x1080 poster jpg at /public/img/hero/hero-poster.jpg).
// While those files are missing, the <img> fallback below renders a
// beautiful portrait so the hero never looks broken.
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const heroVideo = '/img/hero/hero.mp4';
const heroPoster = '/img/hero/hero-poster.jpg';
const heroFallback = '/img/portraits/DV2vp-hiJzx.jpg';
---

<section
  class="hero-cinema relative w-full overflow-hidden"
  data-cinema-hero
  aria-label="Allaia — cinematic introduction"
>
  <!-- 100svh on mobile (stable height, doesn't fight iOS toolbar);
       100lvh on desktop so the hero is properly tall. -->
  <div class="hero-stage relative h-[100svh] min-h-[640px] w-full overflow-hidden">
    <!-- Layer 0 — fallback portrait. Sits behind the video so if the
         MP4 hasn't been dropped in yet, the hero still looks intentional. -->
    <img
      src={heroFallback}
      alt=""
      class="absolute inset-0 w-full h-full object-cover hero-fallback"
      style="object-position: 50% 30%;"
      aria-hidden="true"
      decoding="async"
    />

    <!-- Layer 1 — the video. Autoplay-muted-loop = browser-allowed on
         iOS + Android. preload="auto" so it's ready by the time the
         hero is visible. Hidden if no source available (see script). -->
    <video
      class="absolute inset-0 w-full h-full object-cover hero-video"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={heroPoster}
      data-hero-video
    >
      <source src={heroVideo} type="video/mp4" />
    </video>

    <!-- Layer 2 — atmospheric grain over the footage -->
    <div
      class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-[0.09]"
      style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
      aria-hidden="true"
    ></div>

    <!-- Layer 3 — dark scrim so the editorial text reads -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: linear-gradient(180deg, rgba(14,13,11,0.55) 0%, rgba(14,13,11,0.25) 40%, rgba(14,13,11,0.45) 70%, rgba(14,13,11,0.85) 100%);"
      aria-hidden="true"
    ></div>

    <!-- Layer 4 — editorial chrome -->
    <div class="absolute inset-0 flex items-center">
      <div class="mx-auto max-w-6xl px-6 w-full text-center text-cream">
        <p class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/70 mb-8 sm:mb-10 font-medium">
          A debut · by Allaia
        </p>
        <h1
          class="font-display leading-[0.9] mb-7 sm:mb-9"
          style="font-size: clamp(4rem, 13vw, 11rem); letter-spacing: -0.045em;"
        >
          <span class="block">Become</span>
          <span class="block font-display italic font-medium bg-gradient-to-br from-terracotta via-terracotta-deep to-brown bg-clip-text text-transparent" style="padding-bottom: 0.16em;">
            her.
          </span>
        </h1>
        <p class="font-display italic text-cream/85 max-w-2xl mx-auto text-[clamp(1rem,1.6vw,1.375rem)] leading-snug mb-10 sm:mb-12">
          A long letter — for the women already doing the work.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={site.stan.book} target="_blank" rel="noopener" class="cta-cream">
            Read the book <ArrowUpRight size={12} />
          </a>
          <a href={site.stan.application} class="cta-ghost-dark">
            Apply for The Architecture <ArrowUpRight size={12} />
          </a>
        </div>
      </div>
    </div>

    <!-- Layer 5 — bottom rail -->
    <div class="absolute bottom-6 sm:bottom-8 inset-x-0 flex items-end justify-between px-6 sm:px-10 pointer-events-none text-cream/70">
      <span class="font-mono text-[11px] tracking-widest">
        <span>2026</span> <span class="opacity-50">· allaiamedia.com</span>
      </span>
      <span class="text-[0.625rem] uppercase tracking-[0.32em]">Scroll the story</span>
    </div>
  </div>
</section>

<style>
  .hero-fallback { z-index: 0; }
  .hero-video { z-index: 1; }
  /* If the <video> element fails to load any source (e.g. /hero.mp4
     hasn't been dropped in yet), the JS below hides it and the
     fallback img alone carries the hero. */
  .hero-video[data-no-source] {
    display: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-video { display: none; }
  }
</style>

<script>
  // If the hero video has no playable source, hide the <video>
  // element so the fallback portrait shows through cleanly.
  const v = document.querySelector<HTMLVideoElement>('[data-hero-video]');
  if (v) {
    const checkAndHide = () => {
      // networkState 3 = NETWORK_NO_SOURCE (browser couldn't fetch any)
      if (v.networkState === 3 || v.error) {
        v.setAttribute('data-no-source', '');
      }
    };
    v.addEventListener('error', checkAndHide, { once: true });
    // Also check after a short delay — some browsers don't fire error
    // immediately on 404'd <source>.
    setTimeout(() => {
      if (v.readyState === 0 && v.networkState === 3) {
        v.setAttribute('data-no-source', '');
      }
    }, 600);
  }
</script>
