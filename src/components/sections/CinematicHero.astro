---
// CinematicHero — 5-scene scroll-scrub hero.
// 500vh tall outer section with a sticky-pinned 100vh inner stage.
// Scenes cross-fade and parallax as the user scrolls.
// 3D depth: perspective stage, translateZ layers, rotate3d chips,
// mouse-tracked parallax, morphing mesh gradient backdrop, grain.
// All animations respect prefers-reduced-motion.
import { site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

// Scene definitions — Allaia replaces the `image` paths with her own
// photos via the operator-todo. Until then the CSS-only fallback layers
// render an editorial composition per scene.
const scenes = [
  {
    n: '00',
    eyebrow: 'A debut · forthcoming',
    image: '/img/allaia/scene-00.jpg',
    grad: 'radial-gradient(ellipse at 50% 40%, rgba(184,85,66,0.55) 0%, transparent 55%), linear-gradient(180deg, #0E0D0B 0%, #1A1A1A 100%)',
    bgTone: 'dark',
  },
  {
    n: '01',
    eyebrow: 'AUTHOR · OPERATOR · ARTIST',
    // No face on hero — kept face out per Allaia's note;
    // the portrait scrub below the hero carries her.
    image: '/img/allaia/scene-01-placeholder.jpg',
    grad: 'radial-gradient(circle at 30% 30%, rgba(184,85,66,0.65), transparent 55%), radial-gradient(circle at 75% 80%, rgba(107,79,61,0.7), transparent 65%), linear-gradient(135deg, #F2EDE5, #C7A48D)',
    bgTone: 'warm',
  },
  {
    n: '02',
    eyebrow: 'A quiet manifesto',
    image: '/img/instagram/reel-DXwOfqdM_N0.jpg',
    grad: 'radial-gradient(ellipse at 70% 30%, rgba(254,205,170,0.7), transparent 60%), radial-gradient(ellipse at 25% 75%, rgba(184,85,66,0.55), transparent 60%), linear-gradient(160deg, #FAF6EE 0%, #B85542 130%)',
    bgTone: 'warm',
  },
  {
    n: '03',
    eyebrow: 'FOUR EXPRESSIONS · ONE THESIS',
    image: '/img/allaia/scene-03.jpg',
    grad: 'radial-gradient(circle at 20% 30%, rgba(139,157,126,0.55), transparent 50%), radial-gradient(circle at 80% 70%, rgba(184,85,66,0.55), transparent 55%), linear-gradient(135deg, #F2EDE5 0%, #6B4F3D 110%)',
    bgTone: 'mid',
  },
  {
    n: '04',
    eyebrow: 'A debut — forthcoming',
    image: '/img/book/become-her-cover.jpg',
    grad: 'radial-gradient(ellipse at 50% 50%, rgba(184,85,66,0.6) 0%, transparent 55%), linear-gradient(160deg, #1A1A1A 0%, #2A2722 100%)',
    bgTone: 'dark',
  },
];
---

<section
  class="hero-cinema relative"
  data-cinema-hero
  aria-label="Allaia — cinematic introduction"
>
  <!-- Skeleton heights — 500vh total, 100vh per scene. -->
  <div class="hero-track relative" style="height: 500vh;">
    <!-- Sticky stage -->
    <div
      class="hero-stage sticky top-0 h-screen w-full overflow-hidden"
      style="perspective: 1500px; perspective-origin: 50% 50%;"
    >
      <!-- Layer 0 — morphing background mesh -->
      <div class="hero-bg absolute inset-0" aria-hidden="true">
        {scenes.map((s, i) => (
          <div
            class="hero-bg-layer absolute inset-0 transition-opacity duration-[1200ms]"
            data-scene-bg={i}
            style={`background: ${s.grad}; opacity: ${i === 0 ? 1 : 0};`}
          ></div>
        ))}
      </div>

      <!-- Layer 1 — animated SVG orb (3D-feeling glass) -->
      <svg
        class="hero-orb absolute pointer-events-none"
        viewBox="0 0 600 600"
        aria-hidden="true"
        data-orb
      >
        <defs>
          <radialGradient id="orbGrad" cx="35%" cy="30%" r="65%">
            <stop offset="0%" stop-color="rgba(255,239,224,0.95)" />
            <stop offset="35%" stop-color="rgba(184,85,66,0.75)" />
            <stop offset="75%" stop-color="rgba(107,79,61,0.55)" />
            <stop offset="100%" stop-color="rgba(14,13,11,0.85)" />
          </radialGradient>
          <filter id="orbBlur"><feGaussianBlur stdDeviation="0.5" /></filter>
          <filter id="orbGlow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="18" result="b"/>
            <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>
        <circle cx="300" cy="300" r="240" fill="url(#orbGrad)" filter="url(#orbGlow)" />
        <!-- Inner spec highlight -->
        <ellipse cx="220" cy="200" rx="80" ry="42" fill="rgba(255,255,255,0.35)" filter="url(#orbBlur)" />
      </svg>

      <!-- Layer 2 — scene image stack -->
      <div class="hero-scenes absolute inset-0" aria-hidden="true">
        {scenes.map((s, i) => (
          <figure
            class="hero-scene absolute inset-0"
            data-scene={i}
            style={`opacity: ${i === 0 ? 1 : 0};`}
          >
            <img
              src={s.image}
              alt=""
              loading="eager"
              decoding="async"
              onerror="this.style.display='none'"
              class="hero-scene-img absolute inset-0 w-full h-full object-cover photo-warm"
              style="transform: translateZ(0);"
            />
          </figure>
        ))}
      </div>

      <!-- Layer 3 — grain overlay -->
      <div
        class="absolute inset-0 pointer-events-none mix-blend-multiply opacity-[0.09]"
        style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
        aria-hidden="true"
      ></div>

      <!-- Layer 4 — type tower -->
      <div class="hero-type absolute inset-0 flex items-center">
        <div class="mx-auto max-w-6xl px-6 w-full">
          <!-- Scene-keyed beats -->
          <div class="relative h-[60vh] sm:h-[58vh] flex items-center">
            {scenes.map((s, i) => (
              <div
                class="hero-beat absolute inset-0 flex flex-col justify-center transition-opacity duration-[350ms]"
                data-beat={i}
                style={`opacity: ${i === 0 ? 1 : 0}; transform: translateZ(0); pointer-events: ${i === 0 ? 'auto' : 'none'};`}
              >
                {/* Beat 0 — opening */}
                {i === 0 && (
                  <div class="text-center">
                    <p class="text-[0.6875rem] uppercase tracking-[0.32em] text-cream/55 mb-10 font-medium" data-letter-stagger>
                      A DEBUT · BY ALLAIA
                    </p>
                    <h1
                      class="font-display text-cream leading-[0.92]"
                      style="font-size: clamp(3.5rem, 11vw, 11rem); letter-spacing: -0.05em;"
                    >
                      <span class="block">Become</span>
                      <span class="font-display italic font-medium block bg-gradient-to-br from-terracotta via-terracotta-deep to-brown bg-clip-text text-transparent" style="padding-bottom: 0.16em;">
                        her.
                      </span>
                    </h1>
                    <p class="font-display italic text-cream/75 mt-8 text-[clamp(1rem,1.5vw,1.25rem)]">
                      A long letter — for the women already doing the work.
                    </p>
                  </div>
                )}

                {/* Beat 1 — the name */}
                {i === 1 && (
                  <div>
                    <p class="text-[0.6875rem] uppercase tracking-[0.28em] text-ink/65 mb-6 font-medium">
                      {s.eyebrow}
                    </p>
                    <h2 class="display-xl text-ink leading-[0.94]">
                      <span class="italic-grad">Allaia.</span>
                    </h2>
                    <p class="font-display italic text-ink/85 text-[clamp(1.25rem,2vw,1.625rem)] mt-7 max-w-[28ch]">
                      Author. Operator. Artist.<br/>One thesis.
                    </p>
                  </div>
                )}

                {/* Beat 2 — the tagline */}
                {i === 2 && (
                  <div class="max-w-3xl">
                    <p class="eyebrow text-ink-soft mb-7">{s.eyebrow}</p>
                    <h2
                      class="font-display text-ink leading-[0.96]"
                      style="font-size: clamp(2.5rem, 6.5vw, 5.5rem); letter-spacing: -0.035em;"
                    >
                      <span class="block">Know your worth.</span>
                      <span class="font-display italic font-medium italic-grad block">Then charge it.</span>
                    </h2>
                    <p class="serif-lg text-ink-soft mt-8 max-w-prose">
                      The work is slow, unphotogenic, and quietly compounding. The room is kept curated — on purpose.
                    </p>
                  </div>
                )}

                {/* Beat 3 — four identities */}
                {i === 3 && (
                  <div>
                    <p class="eyebrow text-ink-soft mb-7">{s.eyebrow}</p>
                    <h2
                      class="font-display text-ink leading-[1.02]"
                      style="font-size: clamp(2.25rem, 5.5vw, 4.5rem); letter-spacing: -0.03em;"
                    >
                      <span class="hero-word block opacity-0">Author.</span>
                      <span class="hero-word block opacity-0">Operator.</span>
                      <span class="hero-word block italic-grad font-medium opacity-0">Artist.</span>
                      <span class="hero-word block opacity-0">Creator.</span>
                    </h2>
                    <p class="font-display italic text-brown text-[clamp(1.125rem,1.6vw,1.375rem)] mt-7 max-w-md leading-snug">
                      What compounds is identity. Performance does not.
                    </p>
                  </div>
                )}

                {/* Beat 4 — the book + CTAs */}
                {i === 4 && (
                  <div class="text-center max-w-3xl mx-auto">
                    <p class="text-[0.6875rem] uppercase tracking-[0.28em] text-cream/55 mb-7 font-medium">
                      {s.eyebrow}
                    </p>
                    <h2
                      class="font-display text-cream leading-[0.96]"
                      style="font-size: clamp(2.75rem, 7vw, 5.5rem); letter-spacing: -0.035em;"
                    >
                      <span class="block">The work is becoming</span>
                      <span class="font-display italic font-medium block bg-gradient-to-br from-terracotta via-terracotta-deep to-brown bg-clip-text text-transparent" style="padding-bottom: 0.14em;">
                        who you are about to be.
                      </span>
                    </h2>
                    <p class="font-display italic text-cream/80 mt-8 text-[clamp(1rem,1.5vw,1.25rem)]">
                      Become Her — the debut.
                    </p>
                    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
                      <a href={site.stan.book} target="_blank" rel="noopener" class="cta-cream">
                        Read the book <ArrowUpRight size={12} />
                      </a>
                      <a href={site.stan.application} target="_blank" rel="noopener" class="cta-ghost-dark">
                        Apply for The Architecture <ArrowUpRight size={12} />
                      </a>
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Layer 5 — floating 3D chips -->
      <div class="hero-chips absolute pointer-events-none" data-chip-a aria-hidden="true">
        <div class="glass-pill px-3.5 py-2 rounded-full shadow-pill rotate-[-3deg] flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-terracotta"></span>
          <span class="byline text-ink">Become Her — 2026</span>
        </div>
      </div>
      <div class="hero-chips absolute pointer-events-none" data-chip-b aria-hidden="true">
        <div class="glass-pill px-3.5 py-2 rounded-full shadow-pill rotate-[2deg] flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-sage"></span>
          <span class="byline text-ink">COO — Blacklyne</span>
        </div>
      </div>
      <div class="hero-chips absolute pointer-events-none" data-chip-c aria-hidden="true">
        <div class="glass-pill px-3.5 py-2 rounded-full shadow-pill rotate-[-1deg] flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-brown"></span>
          <span class="byline text-ink">The Rupture — @allaia.art</span>
        </div>
      </div>

      <!-- Layer 6 — progress rail + scene index -->
      <div class="hero-progress absolute left-6 sm:left-10 top-1/2 -translate-y-1/2 flex flex-col gap-2 hidden md:flex" data-progress aria-hidden="true">
        {scenes.map((s, i) => (
          <div class="flex items-center gap-3">
            <span class="hero-dot h-1 w-6 rounded-full bg-ink/15 transition-all duration-500" data-dot={i}></span>
            <span class="hero-sceneN font-mono text-[10px] tracking-wider text-ink/30 transition-colors duration-500" data-sceneN={i}>{s.n}</span>
          </div>
        ))}
      </div>

      <!-- Layer 7 — bottom counter + scroll cue -->
      <div class="absolute bottom-6 sm:bottom-8 inset-x-0 flex items-end justify-between px-6 sm:px-10 pointer-events-none">
        <div class="flex items-center gap-3 hero-counter" data-counter>
          <span class="font-mono text-[11px] tracking-widest text-current">
            <span data-current-n>00</span> <span class="opacity-40">/ 04</span>
          </span>
        </div>
        <div class="flex items-center gap-3 hero-counter" data-counter>
          <span class="micro tracking-[0.24em] uppercase text-current">Scroll the story</span>
          <span class="block h-8 w-px bg-current opacity-30"></span>
        </div>
      </div>

      <!-- Reduced-motion fallback overlay (visible only when prefers-reduced-motion) -->
      <noscript>
        <div class="absolute inset-0 flex items-center justify-center bg-cream">
          <div class="text-center px-6">
            <p class="eyebrow mb-5">AUTHOR · COO · ARTIST · DUBAI + BALI</p>
            <h1 class="display-xl text-ink"><span class="italic-grad">Allaia.</span></h1>
          </div>
        </div>
      </noscript>
    </div>
  </div>
</section>

<style>
  /* Stage base */
  .hero-stage {
    background: #F2EDE5;
    transform-style: preserve-3d;
  }
  .hero-stage * { transform-style: inherit; }

  /* Scene image cross-fade — snappier so beats don't double-stack visually */
  .hero-scene {
    transition: opacity 380ms cubic-bezier(0.22, 0.61, 0.36, 1);
    pointer-events: none;
  }
  .hero-scene[style*="opacity: 1"] { pointer-events: auto; }
  .hero-scene-img { transition: transform 1400ms cubic-bezier(0.22, 0.61, 0.36, 1); }

  /* Background mesh layers */
  .hero-bg-layer { transition: opacity 380ms cubic-bezier(0.22, 0.61, 0.36, 1); }

  /* Orb — fixed position, but transform-driven by scroll */
  .hero-orb {
    width: clamp(380px, 60vw, 720px);
    height: clamp(380px, 60vw, 720px);
    right: -8%;
    top: 50%;
    transform: translateY(-50%) translateZ(-200px) scale(1);
    opacity: 0.85;
    transition: transform 600ms cubic-bezier(0.22, 0.61, 0.36, 1),
                opacity 800ms ease;
  }

  /* Type beats — fade & subtle slide-up */
  .hero-beat {
    will-change: opacity, transform;
  }

  /* Four-word stagger (beat 3) */
  .hero-word {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 700ms cubic-bezier(0.22, 0.61, 0.36, 1),
                transform 700ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .hero-beat[data-beat="3"].is-active .hero-word { opacity: 1; transform: none; }
  .hero-beat[data-beat="3"].is-active .hero-word:nth-child(1) { transition-delay: 80ms; }
  .hero-beat[data-beat="3"].is-active .hero-word:nth-child(2) { transition-delay: 240ms; }
  .hero-beat[data-beat="3"].is-active .hero-word:nth-child(3) { transition-delay: 400ms; }
  .hero-beat[data-beat="3"].is-active .hero-word:nth-child(4) { transition-delay: 560ms; }

  /* Floating chips — orbit positions per scene, tweened via JS */
  .hero-chips {
    transform-style: preserve-3d;
    transition: transform 900ms cubic-bezier(0.22, 0.61, 0.36, 1),
                opacity 700ms ease;
  }
  [data-chip-a] { top: 18%; left: 8%; }
  [data-chip-b] { top: 22%; right: 9%; }
  [data-chip-c] { bottom: 22%; left: 18%; }

  /* Progress dot states */
  .hero-dot.is-active { width: 2.5rem; background: var(--color-terracotta); }
  .hero-sceneN.is-active { color: var(--color-terracotta); }

  /* Counter colour swaps with scene tone */
  .hero-counter { color: var(--color-ink); opacity: 0.55; }
  .hero-stage[data-tone="dark"] .hero-counter { color: var(--color-cream); opacity: 0.65; }

  /* Tone overrides — when stage is dark, scene type-beat 1/2/3 colours shift */
  .hero-stage[data-tone="dark"] .hero-bg-layer { /* mesh remains */ }

  @media (prefers-reduced-motion: reduce) {
    .hero-track { height: 100vh; }
    .hero-stage { position: relative; }
    .hero-scene, .hero-bg-layer, .hero-beat, .hero-orb, .hero-chips { transition: none; }
    .hero-scene[data-scene="1"], .hero-bg-layer[data-scene-bg="1"], .hero-beat[data-beat="1"] {
      opacity: 1 !important;
    }
    .hero-scene:not([data-scene="1"]), .hero-bg-layer:not([data-scene-bg="1"]), .hero-beat:not([data-beat="1"]) {
      opacity: 0 !important;
    }
    .hero-word { opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  type Scene = { idx: number; tone: 'dark' | 'warm' | 'mid' };
  const sceneTones: Scene['tone'][] = ['dark', 'warm', 'warm', 'mid', 'dark'];

  const root = document.querySelector<HTMLElement>('[data-cinema-hero]');
  if (root) {
    const track = root.querySelector<HTMLElement>('.hero-track')!;
    const stage = root.querySelector<HTMLElement>('.hero-stage')!;
    const bgLayers = Array.from(root.querySelectorAll<HTMLElement>('[data-scene-bg]'));
    const scenes = Array.from(root.querySelectorAll<HTMLElement>('[data-scene]'));
    const beats = Array.from(root.querySelectorAll<HTMLElement>('[data-beat]'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    const sceneNs = Array.from(root.querySelectorAll<HTMLElement>('[data-sceneN]'));
    const currentN = root.querySelector<HTMLElement>('[data-current-n]');
    const orb = root.querySelector<HTMLElement>('[data-orb]');
    const chipA = root.querySelector<HTMLElement>('[data-chip-a]');
    const chipB = root.querySelector<HTMLElement>('[data-chip-b]');
    const chipC = root.querySelector<HTMLElement>('[data-chip-c]');

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fine = matchMedia('(pointer: fine)').matches;

    let activeIdx = -1;
    const setActive = (i: number) => {
      if (i === activeIdx) return;
      activeIdx = i;

      scenes.forEach((el, k) => {
        el.style.opacity = k === i ? '1' : '0';
        el.style.pointerEvents = k === i ? 'auto' : 'none';
      });
      bgLayers.forEach((el, k) => (el.style.opacity = k === i ? '1' : '0'));
      beats.forEach((el, k) => {
        el.style.opacity = k === i ? '1' : '0';
        el.style.pointerEvents = k === i ? 'auto' : 'none';
        el.classList.toggle('is-active', k === i);
      });
      dots.forEach((el, k) => el.classList.toggle('is-active', k === i));
      sceneNs.forEach((el, k) => el.classList.toggle('is-active', k === i));
      if (currentN) currentN.textContent = String(i).padStart(2, '0');
      stage.setAttribute('data-tone', sceneTones[i] ?? 'warm');
    };

    let lastProgress = 0;
    let mouseX = 0, mouseY = 0;
    let cMouseX = 0, cMouseY = 0;

    const update = () => {
      if (reduced) return;
      const rect = track.getBoundingClientRect();
      const sceneCount = 5;
      const total = rect.height - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const progress = total > 0 ? scrolled / total : 0;
      lastProgress += (progress - lastProgress) * 0.16;

      // 5 scenes — index from progress (with overlap window)
      const idx = Math.min(sceneCount - 1, Math.floor(lastProgress * sceneCount * 0.999));
      setActive(idx);

      // Within-scene progress (0..1) for fine-grained parallax
      const localP = (lastProgress * sceneCount) - idx;

      // Mouse lerp
      cMouseX += (mouseX - cMouseX) * 0.06;
      cMouseY += (mouseY - cMouseY) * 0.06;

      // Active scene image — Ken Burns + parallax
      const activeImg = scenes[idx]?.querySelector<HTMLElement>('.hero-scene-img');
      if (activeImg) {
        const scale = 1.08 - localP * 0.05; // gentle zoom-out across the scene
        const dx = cMouseX * 14;
        const dy = cMouseY * 10 - localP * 30;
        activeImg.style.transform = `translate3d(${dx}px, ${dy}px, 0) scale(${scale})`;
      }

      // Orb — rotates around the stage as scenes progress
      if (orb) {
        const orbX = (idx - 2) * 80 + cMouseX * 22;
        const orbY = Math.sin(lastProgress * Math.PI * 1.4) * 80 + cMouseY * 18;
        const orbZ = -200 - localP * 80;
        const orbScale = 0.9 + Math.sin(lastProgress * Math.PI) * 0.18;
        orb.style.transform = `translate(-50%, -50%) translate3d(${orbX}px, ${orbY}px, ${orbZ}px) scale(${orbScale})`;
        orb.style.left = '70%';
        orb.style.top = '50%';
        // Orb visibility — pulls back during beat 3 (identities)
        orb.style.opacity = idx === 3 ? '0.45' : '0.85';
      }

      // Chips — orbit, fade out on beat 0 and 4 (dark scenes need less furniture)
      const fadeChips = idx === 0 || idx === 4 ? '0' : '1';
      const chipDX = cMouseX * 16;
      const chipDY = cMouseY * 12;
      if (chipA) {
        chipA.style.opacity = fadeChips;
        chipA.style.transform = `translate3d(${chipDX}px, ${chipDY - localP * 18}px, ${20 - localP * 60}px) rotate(-3deg)`;
      }
      if (chipB) {
        chipB.style.opacity = fadeChips;
        chipB.style.transform = `translate3d(${-chipDX * 1.2}px, ${chipDY * 1.4 + localP * 22}px, ${-30 + localP * 50}px) rotate(2deg)`;
      }
      if (chipC) {
        chipC.style.opacity = fadeChips;
        chipC.style.transform = `translate3d(${chipDX * 0.6}px, ${-chipDY + localP * 12}px, ${10}px) rotate(-1deg)`;
      }

      // Subtle stage perspective shift on mouse
      stage.style.perspectiveOrigin = `${50 + cMouseX * 6}% ${50 + cMouseY * 6}%`;
    };

    const tick = () => {
      update();
      requestAnimationFrame(tick);
    };

    // Init
    setActive(0);
    stage.setAttribute('data-tone', sceneTones[0]);

    if (!reduced) {
      requestAnimationFrame(tick);
      if (fine) {
        window.addEventListener('pointermove', (e) => {
          mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
          mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
        }, { passive: true });
      }
    } else {
      // Reduced motion — pin to scene 1 (the brand name)
      setActive(1);
    }
  }
</script>
