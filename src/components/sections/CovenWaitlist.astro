---
import { coven } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';
---

<section id="coven" class="relative scroll-mt-28 py-24 sm:py-32 lg:py-40 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[80vh] w-[80vh] rounded-full opacity-25 blur-[160px]"
      style="background: radial-gradient(circle, rgba(139,157,126,0.55), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-3xl px-6 text-center">
    <p class="reveal eyebrow mb-7">{coven.eyebrow}</p>
    <h2 class="reveal display-lg mb-2">
      <span class="italic-grad">{coven.heading}</span>
    </h2>
    <p class="reveal serif-lg text-ink-soft mt-7 max-w-prose mx-auto mb-7">
      {coven.lead}
    </p>
    <p class="reveal serif-body text-ink-soft max-w-prose mx-auto mb-10">
      {coven.body}
    </p>

    <form
      action="https://allaia.beehiiv.com/subscribe?utm_source=site&utm_campaign=coven-waitlist"
      method="post"
      class="reveal flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <label class="flex-1">
        <span class="sr-only">Email address for the Coven waitlist</span>
        <input
          type="email"
          name="email"
          required
          placeholder="your email address"
          class="w-full px-5 py-3.5 rounded-full bg-cream border border-ink/12 text-ink placeholder:text-ink-mute focus:border-terracotta focus:outline-none transition-colors duration-300 ease-editorial font-serif text-[1.05rem]"
        />
      </label>
      <button type="submit" class="cta-dark whitespace-nowrap">
        {coven.cta.label}
        <ArrowUpRight size={11} />
      </button>
    </form>

    <p class="reveal byline text-ink-mute mt-6">
      Five hundred women maximum · launching Q3 2026
    </p>
  </div>
</section>
