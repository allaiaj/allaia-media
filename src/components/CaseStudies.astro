---
import { caseStudies } from "../data/site";

const accentMap = {
  violet: "linear-gradient(135deg, rgba(167,139,250,0.95), rgba(124,58,237,0.9))",
  pink: "linear-gradient(135deg, rgba(251,182,206,0.95), rgba(236,72,153,0.85))",
  peach: "linear-gradient(135deg, rgba(254,205,170,0.95), rgba(251,146,60,0.85))",
};
---

<section id="case-studies" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="reveal text-center max-w-3xl mx-auto mb-16 sm:mb-20">
      <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
        Case studies · 03 deep dives
      </p>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
        <span class="text-gradient-ink">Three brands.</span><br />
        <span class="font-serif italic text-gradient-violet">Three weeks of work each.</span>
      </h2>
      <p class="mt-6 text-base text-ink-700 leading-relaxed">
        The story behind the screenshots - what we found, what we built, what changed. Real founders, written-down outcomes.
      </p>
    </div>

    <!-- Cases -->
    <div class="space-y-12 sm:space-y-16">
      {
        caseStudies.map((c, i) => {
          const reversed = i % 2 === 1;
          return (
            <article
              class="reveal relative surface rounded-3xl overflow-hidden"
              style="box-shadow: 0 30px 80px -30px rgba(14,13,10,0.15), 0 1px 0 rgb(255 255 255 / 0.9) inset;"
            >
              <div class={`grid lg:grid-cols-12 gap-0 ${reversed ? "lg:[direction:rtl]" : ""}`}>
                {/* Visual side */}
                <div
                  class="relative lg:col-span-5 min-h-[280px] sm:min-h-[360px] lg:min-h-[520px] overflow-hidden lg:[direction:ltr]"
                  style={`background: ${accentMap[c.accent as keyof typeof accentMap]};`}
                >
                  {/* Soft mesh wash */}
                  <div class="pointer-events-none absolute inset-0 opacity-40" style="background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.55), transparent 55%), radial-gradient(circle at 75% 75%, rgba(255,255,255,0.35), transparent 55%);" />

                  {/* Big numeral */}
                  <div class="absolute left-6 sm:left-8 top-5 sm:top-7 text-white/75 font-serif italic text-[80px] sm:text-[120px] leading-none">
                    {c.n}
                  </div>

                  {/* Screenshot peek (top of site) */}
                  <div class="absolute left-6 right-6 bottom-6 sm:left-10 sm:right-10 sm:bottom-10 rounded-xl overflow-hidden border border-white/30" style="box-shadow: 0 18px 50px -15px rgba(14,13,10,0.35);">
                    <div class="relative aspect-[4/3] bg-white">
                      <img
                        src={`/screenshots/${c.slug}.jpg`}
                        alt={`${c.brand} site preview`}
                        loading="lazy"
                        decoding="async"
                        class="block w-full h-auto select-none"
                        draggable="false"
                      />
                      <div class="pointer-events-none absolute inset-0" style="background: linear-gradient(180deg, transparent 60%, rgba(255,255,255,0.5));" />
                    </div>
                  </div>

                  {/* Industry tag */}
                  <div class="absolute right-5 sm:right-7 top-5 sm:top-7 inline-flex items-center gap-1.5 rounded-full bg-white/25 backdrop-blur-sm px-3 py-1 text-[10px] uppercase tracking-wider text-white font-medium">
                    <span class="h-1 w-1 rounded-full bg-white" />
                    {c.timeline}
                  </div>
                </div>

                {/* Content side */}
                <div class="lg:col-span-7 p-8 sm:p-10 lg:p-14 lg:[direction:ltr]">
                  <p class="text-[11px] uppercase tracking-[0.22em] text-ink-500 mb-3">
                    {c.industry} · {c.market}
                  </p>
                  <h3 class="display text-4xl sm:text-5xl lg:text-6xl font-medium text-ink-900">
                    {c.brand}
                  </h3>

                  {/* Problem */}
                  <div class="mt-7 pl-4 border-l-2 border-ink-900/15">
                    <p class="text-[11px] uppercase tracking-[0.2em] text-ink-500 mb-1.5">
                      The problem
                    </p>
                    <p class="font-serif italic text-lg sm:text-xl text-ink-700 leading-snug max-w-xl">
                      {c.problem}
                    </p>
                  </div>

                  {/* Approach */}
                  <div class="mt-7">
                    <p class="text-[11px] uppercase tracking-[0.2em] text-ink-500 mb-3">
                      What we did
                    </p>
                    <ul class="space-y-2.5">
                      {c.approach.map((step) => (
                        <li class="flex items-start gap-3 text-[15px] text-ink-800 leading-relaxed">
                          <span
                            class="mt-1.5 flex h-1.5 w-1.5 flex-none rounded-full"
                            style="background: var(--color-accent);"
                          />
                          <span>{step}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  {/* Metrics */}
                  <div class="mt-8 pt-7 border-t border-ink-900/8 grid grid-cols-3 gap-4">
                    {c.metrics.map((m) => (
                      <div>
                        <div class="font-serif italic text-3xl sm:text-4xl text-gradient-violet leading-none">
                          {m.v}
                        </div>
                        <p class="mt-2 text-[10px] uppercase tracking-[0.16em] text-ink-500 leading-snug">
                          {m.l}
                        </p>
                      </div>
                    ))}
                  </div>

                  {/* Quote */}
                  <figure class="mt-8 pt-7 border-t border-ink-900/8">
                    <svg width="22" height="22" viewBox="0 0 28 28" class="mb-3" fill="currentColor" aria-hidden="true" style="color: var(--color-accent-bright);">
                      <path d="M11 8c-3 0-5 2.5-5 6v6h6v-6H8c0-2 1.2-3 3-3V8zm11 0c-3 0-5 2.5-5 6v6h6v-6h-4c0-2 1.2-3 3-3V8z" />
                    </svg>
                    <blockquote class="font-serif text-lg sm:text-xl text-ink-900 leading-snug">
                      "{c.quote}"
                    </blockquote>
                    <figcaption class="mt-3 text-xs text-ink-500">
                      {c.quoteBy}
                    </figcaption>
                  </figure>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="reveal mt-12 text-center text-xs text-ink-500">
      We've shipped 500+ builds. <a href="/work" class="underline decoration-ink-300 underline-offset-4 hover:text-ink-900 transition-colors">See more on the work page</a> or <a href="/contact" class="underline decoration-ink-300 underline-offset-4 hover:text-ink-900 transition-colors">ask for the one closest to your situation</a>.
    </p>
  </div>
</section>
