---
// Smooth dot-follower cursor. Desktop only (hover + fine pointer media query).
// Native cursor stays - this dot sits on top with mix-blend-mode so it reads
// against any background. Lerp gives it that buttery 2027 trail.
---

<div data-cursor-dot class="cursor-dot" aria-hidden="true"></div>
<div data-cursor-ring class="cursor-ring" aria-hidden="true"></div>

<style is:global>
  .cursor-dot,
  .cursor-ring {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    border-radius: 9999px;
    will-change: transform, width, height, opacity;
    opacity: 0;
    transition:
      opacity 0.3s ease,
      width 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      height 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    mix-blend-mode: difference;
  }
  .cursor-dot {
    width: 6px;
    height: 6px;
    margin-left: -3px;
    margin-top: -3px;
    background: #ffffff;
  }
  .cursor-ring {
    width: 32px;
    height: 32px;
    margin-left: -16px;
    margin-top: -16px;
    border: 1px solid rgb(255 255 255 / 0.7);
  }
  .cursor-ring.is-hover {
    width: 56px;
    height: 56px;
    margin-left: -28px;
    margin-top: -28px;
    background: rgb(255 255 255 / 0.05);
  }
  .cursor-dot.is-hover {
    width: 10px;
    height: 10px;
    margin-left: -5px;
    margin-top: -5px;
  }

  /* Only show on devices with a fine pointer (real mouse / trackpad) */
  @media (hover: hover) and (pointer: fine) {
    .cursor-dot.is-active,
    .cursor-ring.is-active {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-dot,
    .cursor-ring {
      display: none !important;
    }
  }
</style>

<script>
  const dot = document.querySelector<HTMLElement>("[data-cursor-dot]");
  const ring = document.querySelector<HTMLElement>("[data-cursor-ring]");

  if (
    dot &&
    ring &&
    matchMedia("(hover: hover) and (pointer: fine)").matches &&
    !matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    let dx = mx;
    let dy = my;
    let rx = mx;
    let ry = my;
    let visible = false;

    const onMove = (e: MouseEvent) => {
      mx = e.clientX;
      my = e.clientY;
      if (!visible) {
        visible = true;
        dx = mx;
        dy = my;
        rx = mx;
        ry = my;
        dot.classList.add("is-active");
        ring.classList.add("is-active");
      }
    };
    document.addEventListener("mousemove", onMove);
    document.addEventListener("mouseleave", () => {
      visible = false;
      dot.classList.remove("is-active");
      ring.classList.remove("is-active");
    });
    document.addEventListener("mouseenter", () => {
      visible = true;
      dot.classList.add("is-active");
      ring.classList.add("is-active");
    });

    // Hover-state on interactive targets
    const HOVER_SEL =
      'a, button, [role="button"], summary, input, textarea, label[for], select, [data-cursor-hover]';
    document.addEventListener(
      "mouseover",
      (e) => {
        const t = e.target as Element | null;
        if (t && t.closest && t.closest(HOVER_SEL)) {
          dot.classList.add("is-hover");
          ring.classList.add("is-hover");
        }
      },
      { passive: true }
    );
    document.addEventListener(
      "mouseout",
      (e) => {
        const t = e.target as Element | null;
        if (t && t.closest && t.closest(HOVER_SEL)) {
          dot.classList.remove("is-hover");
          ring.classList.remove("is-hover");
        }
      },
      { passive: true }
    );

    const tick = () => {
      // Dot tracks tightly, ring trails slightly
      dx += (mx - dx) * 0.55;
      dy += (my - dy) * 0.55;
      rx += (mx - rx) * 0.18;
      ry += (my - ry) * 0.18;
      dot.style.transform = `translate3d(${dx}px, ${dy}px, 0)`;
      ring.style.transform = `translate3d(${rx}px, ${ry}px, 0)`;
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }
</script>
