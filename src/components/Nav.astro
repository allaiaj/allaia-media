---
import { nav, site } from "../data/site";
import Logo from "./Logo.astro";
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center px-3 pt-3 sm:px-6 sm:pt-5">
  <nav
    class="glass-nav flex w-full max-w-6xl items-center justify-between gap-3 sm:gap-4 rounded-full px-3 py-2 sm:px-5 sm:py-3"
    aria-label="Primary"
  >
    <a
      href="/"
      class="group flex items-center pl-2 sm:pl-3 transition-opacity hover:opacity-80"
      aria-label="Allaia Media home"
    >
      <Logo size="sm" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1 text-[13px] text-ink-600">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-full px-3 py-1.5 transition-colors hover:bg-ink-900/5 hover:text-ink-900"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href={site.cal}
        target="_blank"
        rel="noopener"
        class="group relative inline-flex items-center gap-1.5 rounded-full bg-ink-900 px-3.5 py-2 sm:px-4 text-[12px] sm:text-[13px] font-medium text-ink-50 transition-transform hover:scale-[1.03] active:scale-[0.98]"
      >
        <span>Book a call</span>
        <svg
          width="12"
          height="12"
          viewBox="0 0 12 12"
          fill="none"
          class="transition-transform group-hover:translate-x-0.5"
          aria-hidden="true"
        >
          <path
            d="M2.5 6h7m0 0L6 2.5M9.5 6L6 9.5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink-900/5 hover:bg-ink-900/10 transition-colors"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          class="text-ink-900"
          aria-hidden="true"
        >
          <path
            d="M3 5h10M3 11h10"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile full-screen menu -->
<div
  id="mobile-menu"
  class="mobile-menu fixed inset-0 z-[55] md:hidden"
  data-menu
  hidden
>
  <!-- Backdrop -->
  <div
    class="mobile-menu-backdrop absolute inset-0"
    style="background: rgb(14 13 10 / 0.45); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
    data-menu-close
  ></div>

  <!-- Panel -->
  <div
    class="mobile-menu-panel absolute top-0 right-0 bottom-0 w-[88%] max-w-[420px] flex flex-col"
    style="background: linear-gradient(180deg, #ffffff 0%, var(--color-cream) 100%); box-shadow: -24px 0 80px -20px rgb(14 13 10 / 0.25); border-left: 1px solid rgb(14 13 10 / 0.06);"
  >
    <!-- Panel header -->
    <div class="flex items-center justify-between gap-4 px-6 pt-5 pb-4 border-b border-ink-900/8">
      <a href="/" class="inline-block" aria-label="Allaia Media home">
        <Logo size="sm" />
      </a>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink-900/5 hover:bg-ink-900/10 transition-colors"
        aria-label="Close menu"
        data-menu-close
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          class="text-ink-900"
          aria-hidden="true"
        >
          <path
            d="M3 3l8 8M11 3l-8 8"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 overflow-y-auto px-6 py-8" aria-label="Mobile">
      <ul class="space-y-1">
        {
          nav.map((item, i) => (
            <li>
              <a
                href={item.href}
                class="mobile-menu-link group flex items-center justify-between gap-4 rounded-2xl px-4 py-4 text-2xl font-medium tracking-tight text-ink-900 hover:bg-ink-900/5 transition-colors"
                style={`transition-delay: ${60 + i * 30}ms;`}
              >
                <span>
                  <span class="font-mono text-[11px] text-ink-400 mr-3 align-middle">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="align-middle">{item.label}</span>
                </span>
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 14 14"
                  fill="none"
                  class="text-ink-400 group-hover:text-ink-900 group-hover:translate-x-0.5 transition-all"
                  aria-hidden="true"
                >
                  <path
                    d="M3 11L11 3M11 3H4M11 3v7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Panel footer -->
    <div class="border-t border-ink-900/8 px-6 py-6 space-y-3">
      <a
        href={site.cal}
        target="_blank"
        rel="noopener"
        class="group flex items-center justify-center gap-2 rounded-full bg-ink-900 px-5 py-3.5 text-sm font-medium text-ink-50 hover:scale-[1.02] transition-transform"
      >
        Book a discovery call
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href={site.whatsapp}
        target="_blank"
        rel="noopener"
        class="flex items-center justify-center gap-2 rounded-full px-5 py-3.5 text-sm font-medium text-ink-50"
        style="background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.6 6.32A7.85 7.85 0 0012.05 4 7.94 7.94 0 005.32 16.05L4 21l5.05-1.32a7.92 7.92 0 003.78.96h.01a7.94 7.94 0 005.5-13.32m-5.5 12.21h-.01a6.6 6.6 0 01-3.36-.92l-.24-.14-2.99.78.8-2.92-.16-.25a6.59 6.59 0 1112.33-3.34 6.59 6.59 0 01-6.38 6.79"/>
        </svg>
        WhatsApp
      </a>
      <p class="pt-2 text-center text-[11px] text-ink-500">
        Reply within 4 hours. No pitch deck.
      </p>
    </div>
  </div>
</div>

<style>
  .mobile-menu {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s ease,
      visibility 0.3s;
  }
  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
  }
  .mobile-menu-panel {
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mobile-menu.is-open .mobile-menu-panel {
    transform: translateX(0);
  }
  .mobile-menu-link {
    opacity: 0;
    transform: translateX(20px);
    transition:
      opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      background-color 0.15s ease,
      color 0.15s ease;
  }
  .mobile-menu.is-open .mobile-menu-link {
    opacity: 1;
    transform: translateX(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .mobile-menu-panel,
    .mobile-menu-link {
      transition: none !important;
    }
  }
</style>

<script>
  const menu = document.querySelector<HTMLElement>("[data-menu]");
  const toggles = document.querySelectorAll<HTMLElement>("[data-menu-toggle]");
  const closes = document.querySelectorAll<HTMLElement>("[data-menu-close]");

  if (menu) {
    const open = () => {
      menu.hidden = false;
      // Force a reflow so the transition fires from the hidden state
      void menu.offsetWidth;
      menu.classList.add("is-open");
      document.body.style.overflow = "hidden";
      toggles.forEach((t) => t.setAttribute("aria-expanded", "true"));
    };
    const close = () => {
      menu.classList.remove("is-open");
      document.body.style.overflow = "";
      toggles.forEach((t) => t.setAttribute("aria-expanded", "false"));
      // Wait for transition before hiding
      setTimeout(() => {
        if (!menu.classList.contains("is-open")) menu.hidden = true;
      }, 400);
    };

    toggles.forEach((t) => t.addEventListener("click", open));
    closes.forEach((c) => c.addEventListener("click", close));

    // Close when a nav link is clicked
    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        // Small delay so navigation feels intentional
        setTimeout(close, 100);
      });
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.classList.contains("is-open")) close();
    });
  }
</script>
