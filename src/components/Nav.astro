---
import { nav, site } from "../data/site";
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center px-3 pt-3 sm:px-6 sm:pt-5">
  <nav
    class="glass-nav flex w-full max-w-6xl items-center justify-between gap-4 rounded-full px-3 py-2 sm:px-5 sm:py-3"
    aria-label="Primary"
  >
    <a
      href="/"
      class="group flex items-center gap-2 pl-1 sm:pl-2 text-sm font-medium tracking-tight"
    >
      <span
        class="relative flex h-7 w-7 items-center justify-center rounded-full"
        style="background: conic-gradient(from 220deg, var(--color-accent-bright), var(--color-accent-deep), var(--color-accent-glow), var(--color-accent-bright));"
      >
        <span class="absolute inset-[2px] rounded-full bg-paper" style="background: var(--color-paper);"></span>
        <span class="relative font-serif italic text-ink-900 text-[15px] leading-none">a</span>
      </span>
      <span class="hidden sm:inline text-ink-900">allaia<span class="text-ink-400">/media</span></span>
    </a>

    <ul class="hidden md:flex items-center gap-1 text-[13px] text-ink-600">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-full px-3 py-1.5 transition-colors hover:bg-ink-900/5 hover:text-ink-900"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href={site.cal}
      target="_blank"
      rel="noopener"
      class="group relative inline-flex items-center gap-1.5 rounded-full bg-ink-900 px-4 py-2 text-[13px] font-medium text-ink-50 transition-transform hover:scale-[1.03] active:scale-[0.98]"
    >
      <span>Book a call</span>
      <svg
        width="12"
        height="12"
        viewBox="0 0 12 12"
        fill="none"
        class="transition-transform group-hover:translate-x-0.5"
        aria-hidden="true"
      >
        <path
          d="M2.5 6h7m0 0L6 2.5M9.5 6L6 9.5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        ></path>
      </svg>
    </a>
  </nav>
</header>
