---
import { services, site } from "../data/site";

interface Props {
  showHeader?: boolean;
}
const { showHeader = true } = Astro.props;
---

<section
  id="pricing"
  class="relative isolate scroll-mt-24 overflow-hidden text-ink-900"
>
  <!-- subtle violet wash from bottom -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-50"
    style="background: radial-gradient(ellipse 60% 40% at 50% 100%, rgba(167,139,250,0.18), transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
    {showHeader && (
      <div class="reveal text-center max-w-3xl mx-auto mb-16">
        <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Honest pricing
        </p>
        <h2 class="display text-5xl sm:text-6xl lg:text-7xl font-medium">
          <span class="text-gradient-ink">Pay for what works.</span><br />
          <span class="font-serif italic text-gradient-violet">No retainers. No lock-in.</span>
        </h2>
        <p class="mt-6 text-base text-ink-700 leading-relaxed">
          Starting rates below. Final pricing is tailored to your scope. Month-to-month on everything except Meta Ads (3-month minimum, because the data needs time to compound).
        </p>
      </div>
    )}

    <!-- 4 service price cards -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((s) => (
          <article class="reveal surface group relative flex flex-col rounded-3xl p-7 transition-transform hover:-translate-y-1">
            <div class="flex items-start justify-between gap-3">
              <span class="font-mono text-xs text-ink-500 tracking-wider">{s.n}</span>
              <span class="rounded-full bg-ink-900/5 px-2.5 py-0.5 text-[10px] uppercase tracking-wider text-ink-600">
                {s.timeline}
              </span>
            </div>

            <h3 class="mt-8 text-xl font-medium tracking-tight text-ink-900">
              {s.title}
            </h3>

            <div class="mt-5 flex items-baseline gap-1.5">
              <span class="font-serif text-5xl text-gradient-ink leading-none">
                {s.price}
              </span>
            </div>
            <p class="mt-2 text-[12px] text-ink-500 uppercase tracking-[0.14em]">
              {s.cadence}
            </p>

            <p class="mt-5 text-[14px] text-ink-700 leading-relaxed flex-1">
              {s.sub}
            </p>

            <a
              href={site.cal}
              target="_blank"
              rel="noopener"
              class="mt-7 inline-flex items-center justify-center gap-1.5 rounded-full bg-ink-900 py-2.5 text-sm font-medium text-ink-50 hover:bg-ink-800 transition-colors"
            >
              Book a call
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 6h7m0 0L6 2.5M9.5 6L6 9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </article>
        ))
      }
    </div>

    <!-- bundle discount callout (bright violet-accent card) -->
    <div
      class="reveal shimmer-border relative mt-10 overflow-hidden rounded-3xl p-8 sm:p-10"
      style="box-shadow: 0 30px 80px -30px rgba(124,58,237,0.25);"
    >
      <div
        class="pointer-events-none absolute -top-32 -right-10 h-72 w-72 rounded-full opacity-40 blur-3xl"
        style="background: radial-gradient(circle, rgba(167,139,250,0.6), transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -bottom-32 -left-10 h-72 w-72 rounded-full opacity-35 blur-3xl"
        style="background: radial-gradient(circle, rgba(251,207,232,0.6), transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div class="max-w-2xl">
          <p class="text-[11px] uppercase tracking-[0.22em] text-accent-deep mb-3">
            Stacking two or more?
          </p>
          <h3 class="font-serif italic text-3xl sm:text-4xl text-gradient-violet leading-tight">
            Ask about our bundle discount.
          </h3>
          <p class="mt-3 text-[15px] text-ink-700 leading-relaxed">
            Most founders run web + one growth channel. Combining services brings the price down and the data sharper. We'll quote it on the call.
          </p>
        </div>
        <a
          href={site.cal}
          target="_blank"
          rel="noopener"
          class="group relative inline-flex items-center justify-center gap-2 overflow-hidden rounded-full bg-ink-900 px-6 py-3.5 text-sm font-medium text-ink-50 whitespace-nowrap flex-none"
          style="box-shadow: 0 12px 36px -10px rgba(14,13,10,0.4);"
        >
          Get a custom quote
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="relative transition-transform group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M2.5 6h7m0 0L6 2.5M9.5 6L6 9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>

    <p class="reveal mt-8 text-center text-xs text-ink-500">
      All prices in USD. Final scope and rate confirmed before any work starts.
    </p>
  </div>
</section>
