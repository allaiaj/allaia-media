---
// Become Her popup — appears a few seconds after the page loads
// with the cover + a Stan Store CTA. Closes via X / backdrop tap /
// ESC. localStorage remembers a close so it doesn't keep popping up
// (auto-expires after 7 days so it can reach a return visitor again).
//
// Hidden on /about — that page runs the YouTube quantum-leap modal
// instead, and stacking two modals on first visit would be hostile.
import { book, site } from '@data/site';
import ArrowUpRight from '@components/icons/ArrowUpRight.astro';

const path = Astro.url.pathname.replace(/\/+$/, '');
// Suppress on pages that run their own popup so the user never
// sees two modals stacked on first visit, and on the brand-collabs
// pitch page where a book popup would undercut the ask.
const ownsItsModal = path === '/about' || path === '/the-studio' || path === '/brand-collabs';
---

{!ownsItsModal && (

<div
  class="book-modal fixed inset-0 z-[80] hidden items-center justify-center px-4 sm:px-6"
  data-book-modal
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="book-modal-title"
>
  <!-- Backdrop -->
  <button
    type="button"
    class="absolute inset-0 w-full h-full bg-anthracite/55 backdrop-blur-md cursor-pointer"
    aria-label="Close"
    data-book-modal-close
  ></button>

  <!-- Modal card -->
  <div
    class="book-modal-card relative w-full max-w-[920px] max-h-[92vh] overflow-y-auto rounded-[1.75rem] shadow-anthracite"
    style="background: linear-gradient(160deg, #0E0D0B 0%, #1F1B16 60%, #2A2722 100%);"
    data-book-modal-card
  >
    <!-- Warm wash inside the card -->
    <div
      class="pointer-events-none absolute inset-0 opacity-60"
      style="background: radial-gradient(ellipse 60% 60% at 80% 10%, rgba(184,85,66,0.55), transparent 70%), radial-gradient(ellipse 55% 55% at 10% 95%, rgba(139,157,126,0.35), transparent 70%);"
      aria-hidden="true"
    ></div>

    <!-- Close button (top right) -->
    <button
      type="button"
      aria-label="Close"
      data-book-modal-close
      class="absolute top-4 right-4 sm:top-5 sm:right-5 z-10 grid place-items-center h-10 w-10 rounded-full bg-cream/12 backdrop-blur-md border border-cream/20 text-cream hover:bg-cream/25 hover:scale-110 transition-all duration-300 ease-editorial"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 3l8 8M11 3 3 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="relative grid sm:grid-cols-[1fr_1.1fr] gap-0">
      <!-- LEFT: cover -->
      <div class="relative p-7 sm:p-9 lg:p-11 flex items-center justify-center">
        <figure class="relative w-full max-w-[240px] sm:max-w-[260px]">
          <div
            class="relative aspect-[2/3] rounded-[0.875rem] overflow-hidden bg-anthracite"
            style="box-shadow: 0 32px 80px -16px rgba(184,85,66,0.55), 0 0 0 1px rgba(242,237,229,0.08) inset;"
          >
            <!-- CSS cover (matches Allaia's design) -->
            <div class="absolute inset-0" style="background: #18181A;" aria-hidden="true">
              <div
                class="absolute inset-0 opacity-[0.18] mix-blend-screen"
                style="background-image: url(&quot;data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>&quot;);"
              ></div>
              <div class="absolute top-0 inset-x-0 pt-3 px-3">
                <div class="flex items-start justify-between text-cream text-[0.4375rem] tracking-[0.15em] uppercase font-medium leading-[1.3]">
                  <span class="max-w-[40%]">For the woman<br/>who's done performing</span>
                  <span class="self-center">2026</span>
                  <span class="self-start">Allaia Power</span>
                </div>
                <div class="mt-2 h-px bg-cream/35"></div>
              </div>
              <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 px-3 text-center">
                <h3 class="font-sans font-black text-cream leading-[0.92] tracking-tight" style="font-size: clamp(1.5rem, 3.5vw, 2.25rem);">
                  <span class="block">BECOME</span>
                  <span class="block">HER</span>
                </h3>
                <p class="mt-3 font-display italic text-cream/85 leading-snug text-[0.625rem] max-w-[10rem] mx-auto">
                  On the dethroning of the persona and the recovery of the Self.
                </p>
              </div>
              <div class="absolute bottom-4 inset-x-0 text-center">
                <p class="font-sans font-black text-cream tracking-[0.18em] text-[0.5625rem]">
                  ALLAIA POWER
                </p>
              </div>
            </div>
            <!-- Real cover if file exists -->
            <img
              src={book.cover}
              alt=""
              loading="eager"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover"
              onerror="this.style.display='none'"
            />
          </div>
        </figure>
      </div>

      <!-- RIGHT: copy + CTA -->
      <div class="relative p-7 sm:p-9 lg:p-11 flex flex-col justify-center text-cream">
        <p class="text-[0.625rem] uppercase tracking-[0.28em] text-sage font-medium mb-4">
          A debut · 2026
        </p>
        <h2
          id="book-modal-title"
          class="font-display font-medium leading-[1.04] mb-5"
          style="font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.025em;"
        >
          <span class="block">Stop waiting</span>
          <span class="block font-display italic font-medium bg-gradient-to-br from-terracotta via-terracotta-deep to-brown bg-clip-text text-transparent" style="padding-bottom: 0.14em;">
            on someday.
          </span>
        </h2>

        <p class="font-display italic text-cream/85 text-[clamp(1.0625rem,1.5vw,1.25rem)] leading-snug mb-7 max-w-md">
          Become the woman who already lives the life you want.
        </p>

        <p class="font-serif text-cream/80 leading-[1.6] mb-8 max-w-md text-[1.0625rem]">
          {book.blurb}
        </p>

        <a
          href={site.stan.book}
          target="_blank"
          rel="noopener"
          class="cta-cream group inline-flex w-full sm:w-auto items-center justify-center"
          data-book-modal-cta
        >
          <span class="grid place-items-center h-5 w-5 rounded-full bg-ink text-cream font-display italic font-black text-[0.625rem] leading-none mr-1.5">s</span>
          <span>Read the book on Stan</span>
          <ArrowUpRight size={12} class="ml-1.5 transition-transform group-hover:translate-x-0.5" />
        </a>

        <p class="text-[0.6875rem] text-cream/45 mt-4">
          Opens at <span class="text-cream/70">{site.stan.book.replace('https://', '')}</span>
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Open state — driven by data-state="open" on .book-modal */
  .book-modal {
    opacity: 0;
    transition: opacity 320ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .book-modal[data-state="open"] {
    display: flex;
    opacity: 1;
  }
  .book-modal-card {
    transform: translateY(16px) scale(0.97);
    opacity: 0;
    transition:
      transform 480ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 380ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .book-modal[data-state="open"] .book-modal-card {
    transform: none;
    opacity: 1;
    transition-delay: 80ms;
  }
  @media (prefers-reduced-motion: reduce) {
    .book-modal, .book-modal-card { transition: none !important; }
  }
</style>

<script>
  // Per-session suppression only. Once the user closes the modal in
  // this tab/session, it stays closed until they refresh or open a
  // new visit. This is an active book campaign — long-lived suppression
  // makes the popup invisible to anyone who tested it once.
  const KEY = 'allaia_book_modal_dismissed';
  // Shared with InstagramModal — only one auto-popup opens per session.
  // The IG modal fires first (2500ms); the book popup waits until 2800ms
  // and stands down if the IG popup already claimed the session.
  const SHARED_KEY = 'allaia_popup_shown';
  const DELAY_MS = 2800;

  const modal = document.querySelector<HTMLElement>('[data-book-modal]');
  if (modal) {
    let dismissedThisSession = false;
    try {
      dismissedThisSession =
        sessionStorage.getItem(KEY) === '1' ||
        sessionStorage.getItem(SHARED_KEY) === '1';
    } catch { /* sessionStorage blocked — show anyway */ }

    // Optional force-show: append ?popup=1 to the URL to bypass suppression.
    const force = new URLSearchParams(location.search).get('popup') === '1';

    const open = () => {
      // Re-check the shared gate at fire time in case the IG modal
      // opened first during the delay window.
      try {
        if (!force && sessionStorage.getItem(SHARED_KEY) === '1') return;
        sessionStorage.setItem(SHARED_KEY, '1');
      } catch { /* ignore */ }
      modal.style.display = '';
      modal.setAttribute('data-state', 'open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      modal.removeAttribute('data-state');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      try { sessionStorage.setItem(KEY, '1'); } catch { /* ignore */ }
      setTimeout(() => { modal.style.display = 'none'; }, 360);
    };

    modal.querySelectorAll<HTMLElement>('[data-book-modal-close]').forEach((b) => {
      b.addEventListener('click', close);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.getAttribute('data-state') === 'open') close();
    });
    modal.querySelector<HTMLElement>('[data-book-modal-cta]')?.addEventListener('click', () => {
      try { sessionStorage.setItem(KEY, '1'); } catch { /* ignore */ }
    });

    if (force || !dismissedThisSession) {
      setTimeout(open, DELAY_MS);
    }
  }
</script>
)}
