---
const industries = [
  {
    name: "Aesthetic clinics",
    sub: "Laser, lipo, advanced facials",
    icon: "sparkle",
  },
  {
    name: "Dental & ortho",
    sub: "Aligners, implants, hygiene",
    icon: "tooth",
  },
  {
    name: "Beauty & skin",
    sub: "Lashes, brows, electrolysis",
    icon: "drop",
  },
  {
    name: "Wellness & spa",
    sub: "Massage, holistic, day spa",
    icon: "wave",
  },
  {
    name: "Florists & retail",
    sub: "Same-day delivery, local",
    icon: "leaf",
  },
  {
    name: "Hospitality",
    sub: "Cafes, bistros, dark kitchens",
    icon: "cup",
  },
];
---

<section id="industries" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Built for · 06 verticals
        </p>
        <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
          <span class="text-gradient-ink">Specialists,</span><br />
          <span class="font-serif italic text-gradient-violet">not generalists.</span>
        </h2>
      </div>
      <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
        We've gone deep in a handful of industries because depth compounds. Every keyword, every funnel, every angle we know cold.
      </p>
    </div>

    <div class="grid gap-3 sm:gap-4 grid-cols-2 md:grid-cols-3">
      {
        industries.map((ind) => (
          <article
            data-tilt
            data-tilt-max="6"
            data-tilt-lift="3"
            class="reveal group surface rounded-2xl p-5 sm:p-6 transition-all duration-500 hover:shadow-[0_20px_50px_-20px_rgba(124,58,237,0.22)]"
          >
            <div class="flex items-start gap-3">
              <span
                class="flex h-9 w-9 flex-none items-center justify-center rounded-xl text-white transition-transform group-hover:rotate-6"
                style="background: linear-gradient(135deg, var(--color-accent-bright), var(--color-accent-deep));"
              >
                {ind.icon === "sparkle" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3l2.2 6.8L21 12l-6.8 2.2L12 21l-2.2-6.8L3 12l6.8-2.2L12 3z" fill="currentColor"/>
                  </svg>
                )}
                {ind.icon === "tooth" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3c-3 0-5 1.5-5 4 0 2 1 3 1 5s-1 5 0 8c.5 1.5 1.5 2 2.5 1.5.7-.4 1-2 1.5-3.5.3-.9 1-1 1.5 0 .5 1.5 1 3 1.5 3.5 1 .5 2 0 2.5-1.5 1-3 0-6 0-8s1-3 1-5c0-2.5-2-4-5-4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                  </svg>
                )}
                {ind.icon === "drop" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3c2 4 6 7 6 11a6 6 0 11-12 0c0-4 4-7 6-11z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                  </svg>
                )}
                {ind.icon === "wave" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 12c2-2 4-2 6 0s4 2 6 0 4-2 6 0M3 17c2-2 4-2 6 0s4 2 6 0 4-2 6 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
                {ind.icon === "leaf" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 20c0-8 6-14 14-14 0 8-6 14-14 14z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M4 20l8-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                  </svg>
                )}
                {ind.icon === "cup" && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 9h12v6a4 4 0 01-4 4H9a4 4 0 01-4-4V9zM17 11h2a2 2 0 010 4h-2M8 4v2M11 4v2M14 4v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                )}
              </span>
              <div class="min-w-0">
                <h3 class="text-base font-medium text-ink-900 tracking-tight">{ind.name}</h3>
                <p class="mt-0.5 text-xs text-ink-500 leading-snug">{ind.sub}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Different vertical? We take one outside this list per quarter. <a href="/contact" class="underline decoration-ink-300 underline-offset-4 hover:text-ink-900 transition-colors">Ask if we'd be a fit.</a>
    </p>
  </div>
</section>
