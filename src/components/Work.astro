---
import { work } from "../data/site";

interface Props {
  showHeader?: boolean;
}
const { showHeader = true } = Astro.props;

// Local full-page JPEG screenshots captured by scripts/screenshot-work.mjs.
// Re-run that script when client sites change.
const shotUrl = (slug: string) => `/screenshots/${slug}.jpg`;
---

<section id="work" class="relative scroll-mt-24 py-24 sm:py-32" style="perspective: 2000px;">
  <div class="mx-auto max-w-5xl px-6">
    {showHeader && (
      <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
            Selected work · 8 from 500+ builds
          </p>
          <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
            <span class="text-gradient-ink">Sites that ship.</span><br />
            <span class="font-serif italic text-gradient-violet">Numbers that grow.</span>
          </h2>
        </div>
        <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
          Real builds for real founders. Scroll inside any preview to walk through the full page.
        </p>
      </div>
    )}

    <!-- Uniform 2-col (mobile) / 3-col (tablet) / 4-col (desktop) grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
      {
        work.map((w) => (
          <article
            data-tilt
            class={`reveal group relative overflow-hidden rounded-2xl transition-all duration-500 hover:-translate-y-0.5 will-change-transform ${w.featured ? "shimmer-border" : "surface"}`}
            style={`transform-style: preserve-3d; ${w.featured ? "box-shadow: 0 24px 60px -24px rgba(124,58,237,0.3), 0 1px 0 rgb(255 255 255 / 0.9) inset;" : ""}`}
          >
            {w.featured && (
              <span class="absolute right-2.5 top-2.5 z-10 inline-flex items-center gap-1 rounded-full bg-ink-900 px-2 py-0.5 text-[9px] uppercase tracking-wider text-ink-50 font-medium">
                <span class="h-1 w-1 rounded-full bg-accent-bright" />
                Flagship
              </span>
            )}

            {/* Scrollable full-page screenshot */}
            <div
              class="relative overflow-hidden cursor-grab active:cursor-grabbing"
              style="aspect-ratio: 16 / 10; background: linear-gradient(135deg, #f5f4f1 0%, #faf9f6 50%, #f5f4f1 100%); background-size: 200% 200%; animation: shimmer 4s ease-in-out infinite;"
            >
              <div
                class="absolute inset-0 overflow-y-auto overflow-x-hidden"
                style="scroll-behavior: auto; overscroll-behavior: contain; touch-action: pan-y; -webkit-overflow-scrolling: touch;"
              >
                <img
                  src={shotUrl(w.slug)}
                  alt={`${w.title} website preview`}
                  loading="lazy"
                  decoding="async"
                  class="block w-full h-auto select-none"
                  draggable="false"
                  style="background: #ffffff;"
                />
              </div>
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-white/40 to-transparent"></div>
            </div>

            {/* Info footer */}
            <div class="px-3 py-2.5 border-t border-ink-900/8 bg-white/60">
              <h3 class="text-xs sm:text-[13px] font-medium text-ink-900 truncate">
                {w.title}
              </h3>
              <p class="text-[10px] sm:text-[11px] text-ink-500 truncate">
                {w.label}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Eight recent builds, all shipped in the last 12 months.
    </p>
  </div>
</section>

<script>
  const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isFinePointer = matchMedia(
    "(hover: hover) and (pointer: fine)"
  ).matches;

  if (!prefersReduced && isFinePointer) {
    const MAX_TILT = 4;
    document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
      let rect: DOMRect | null = null;
      const onEnter = () => {
        rect = card.getBoundingClientRect();
        card.style.transition = "transform 0.15s ease-out";
      };
      const onMove = (e: MouseEvent) => {
        if (!rect) rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        const rx = (-y * MAX_TILT).toFixed(2);
        const ry = (x * MAX_TILT).toFixed(2);
        card.style.transform = `perspective(1200px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;
      };
      const onLeave = () => {
        card.style.transition = "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
        card.style.transform = "";
        rect = null;
      };
      card.addEventListener("mouseenter", onEnter);
      card.addEventListener("mousemove", onMove);
      card.addEventListener("mouseleave", onLeave);
    });
  }
</script>
