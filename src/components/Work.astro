---
import { work } from "../data/site";

interface Props {
  showHeader?: boolean;
}
const { showHeader = true } = Astro.props;

// Build a microlink screenshot URL per device.
// Microlink fetches + caches each unique URL on its CDN, so subsequent
// visitors load the cached image instantly. No iframe scroll, no race
// conditions, no empty heroes - each preview is always a clean shot.
function shotUrl(url: string, device: "desktop" | "mobile") {
  const isMobile = device === "mobile";
  const params = new URLSearchParams({
    url: `https://${url}`,
    screenshot: "true",
    meta: "false",
    embed: "screenshot.url",
    "viewport.width": isMobile ? "390" : "1440",
    "viewport.height": isMobile ? "844" : "900",
    "viewport.deviceScaleFactor": "2",
    waitForTimeout: "1500",
    type: "jpeg",
    "screenshot.quality": "82",
    "screenshot.fullPage": "false",
  });
  return `https://api.microlink.io/?${params.toString()}`;
}
---

<section id="work" class="relative scroll-mt-24 py-24 sm:py-32" style="perspective: 2000px;">
  <div class="mx-auto max-w-5xl px-6">
    {showHeader && (
      <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
            Selected work · 8 from 500+ builds
          </p>
          <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
            <span class="text-gradient-ink">Sites that ship.</span><br />
            <span class="font-serif italic text-gradient-violet">Numbers that grow.</span>
          </h2>
        </div>
        <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
          Real builds for real founders. Each one launched in seven days, ranking and converting in its own market.
        </p>
      </div>
    )}

    <!-- Bento -->
    <div class="grid grid-cols-6 gap-3 sm:gap-4 sm:grid-cols-12">
      {
        work.map((w) => (
          <article
            data-tilt
            class={`reveal group relative overflow-hidden rounded-2xl transition-all duration-500 hover:-translate-y-0.5 col-span-6 will-change-transform ${w.span} ${w.featured ? "shimmer-border" : "surface"}`}
            style={`transform-style: preserve-3d; ${w.featured ? "box-shadow: 0 30px 80px -30px rgba(124,58,237,0.35), 0 1px 0 rgb(255 255 255 / 0.9) inset;" : ""}`}
          >
            {w.featured && (
              <span class="absolute right-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-ink-900 px-2.5 py-1 text-[9px] uppercase tracking-wider text-ink-50 font-medium">
                <span class="h-1 w-1 rounded-full bg-accent-bright" />
                Latest flagship
              </span>
            )}
            {w.device === "mobile" && !w.featured && (
              <span class="absolute left-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-ink-900/85 backdrop-blur-sm px-2 py-0.5 text-[9px] uppercase tracking-wider text-ink-50 font-medium">
                <svg width="8" height="10" viewBox="0 0 8 10" fill="none" aria-hidden="true">
                  <rect x="0.6" y="0.6" width="6.8" height="8.8" rx="1.2" stroke="currentColor" stroke-width="1.2" />
                  <line x1="3" y1="8" x2="5" y2="8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                </svg>
                Mobile
              </span>
            )}

            {/* Screenshot - object-cover crops to the top of the page so hero is always visible */}
            <div
              class="relative overflow-hidden"
              style={`aspect-ratio: ${w.aspect}; background: linear-gradient(135deg, #f5f4f1 0%, #faf9f6 50%, #f5f4f1 100%); background-size: 200% 200%; animation: shimmer 4s ease-in-out infinite;`}
            >
              <img
                src={shotUrl(w.url, w.device)}
                alt={`${w.title} website preview`}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover object-top"
                style="background: #ffffff;"
              />
              {/* Subtle gradient overlay - reads as "preview" not "live" */}
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-10 bg-gradient-to-t from-white/30 to-transparent"></div>
            </div>

            {/* Info footer */}
            <div class="px-3 py-2.5 border-t border-ink-900/8 bg-white/60">
              <h3 class="text-xs sm:text-[13px] font-medium text-ink-900 truncate">
                {w.title}
              </h3>
              <p class="text-[10px] sm:text-[11px] text-ink-500 truncate">
                {w.label}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Eight recent builds, all shipped in the last 12 months. Ayahs Beauty is our latest flagship.
    </p>
  </div>
</section>

<script>
  // Subtle 3D tilt on hover (mouse only, respects reduced motion)
  const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isFinePointer = matchMedia(
    "(hover: hover) and (pointer: fine)"
  ).matches;

  if (!prefersReduced && isFinePointer) {
    const MAX_TILT = 5;
    document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
      let rect: DOMRect | null = null;
      const onEnter = () => {
        rect = card.getBoundingClientRect();
        card.style.transition = "transform 0.15s ease-out";
      };
      const onMove = (e: MouseEvent) => {
        if (!rect) rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        const rx = (-y * MAX_TILT).toFixed(2);
        const ry = (x * MAX_TILT).toFixed(2);
        card.style.transform = `perspective(1200px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;
      };
      const onLeave = () => {
        card.style.transition = "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
        card.style.transform = "";
        rect = null;
      };
      card.addEventListener("mouseenter", onEnter);
      card.addEventListener("mousemove", onMove);
      card.addEventListener("mouseleave", onLeave);
    });
  }
</script>
