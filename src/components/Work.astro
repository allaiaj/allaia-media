---
import { work } from "../data/site";

interface Props {
  showHeader?: boolean;
}

const { showHeader = true } = Astro.props;

// Cache-bust query so iframes pull fresh content on every deploy
const cacheBust = Date.now().toString(36);
---

<section id="work" class="relative scroll-mt-24 py-24 sm:py-32" style="perspective: 2000px;">
  <div class="mx-auto max-w-5xl px-6">
    {showHeader && (
      <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
            Selected work · 8 from 500+ builds
          </p>
          <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
            <span class="text-gradient-ink">Sites that ship.</span><br />
            <span class="font-serif italic text-gradient-violet">Numbers that grow.</span>
          </h2>
        </div>
        <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
          Each one launched in seven days. Each one ranks where it counts. Scroll inside any preview to walk through the build.
        </p>
      </div>
    )}

    <!-- Bento (12-col, smaller cards, mixed mobile + desktop frames) -->
    <div class="grid grid-cols-6 gap-3 sm:gap-4 sm:grid-cols-12">
      {
        work.map((w) => (
          <article
            data-tilt
            class={`reveal group block relative overflow-hidden rounded-2xl transition-all duration-500 hover:-translate-y-0.5 col-span-6 will-change-transform ${w.span} ${w.featured ? "shimmer-border" : "surface"}`}
            style={`transform-style: preserve-3d; ${w.featured ? "box-shadow: 0 30px 80px -30px rgba(124,58,237,0.35), 0 1px 0 rgb(255 255 255 / 0.9) inset;" : ""}`}
          >
            {w.featured && (
              <span class="absolute right-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-ink-900 px-2.5 py-1 text-[9px] uppercase tracking-wider text-ink-50 font-medium">
                <span class="h-1 w-1 rounded-full bg-accent-bright" />
                Latest flagship
              </span>
            )}
            {/* Tiny device tag (no URL bar - per design) */}
            {w.device === "mobile" && (
              <span class="absolute left-3 top-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-ink-900/85 backdrop-blur-sm px-2 py-0.5 text-[9px] uppercase tracking-wider text-ink-50 font-medium">
                <svg width="8" height="10" viewBox="0 0 8 10" fill="none" aria-hidden="true">
                  <rect x="0.6" y="0.6" width="6.8" height="8.8" rx="1.2" stroke="currentColor" stroke-width="1.2" />
                  <line x1="3" y1="8" x2="5" y2="8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                </svg>
                Mobile
              </span>
            )}

            {/* Preview frame */}
            <div
              data-preview-frame
              data-device={w.device}
              data-start-at={w.startAt}
              class="relative cursor-grab active:cursor-grabbing"
              style={`aspect-ratio: ${w.aspect}; background: linear-gradient(135deg, #f5f4f1 0%, #faf9f6 50%, #f5f4f1 100%); background-size: 200% 200%; animation: shimmer 4s ease-in-out infinite;`}
            >
              <div
                class="absolute inset-0 overflow-y-auto overflow-x-hidden"
                data-preview-scroll
              >
                <div data-preview-reservoir class="relative w-full" style="height: 1px;">
                  <iframe
                    src={`https://${w.url}?_=${cacheBust}`}
                    class="absolute top-0 left-0 origin-top-left pointer-events-none border-0 bg-white"
                    style="width: 1440px; height: 5000px;"
                    referrerpolicy="no-referrer"
                    loading="lazy"
                    title={w.title}
                    aria-label={`Preview of ${w.title}`}
                  />
                </div>
              </div>
              {/* Subtle gradient overlay */}
              <div class="pointer-events-none absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-white/30 to-transparent"></div>
            </div>

            {/* Info footer (no clickable link) */}
            <div class="px-3 py-2.5 border-t border-ink-900/8 bg-white/60">
              <h3 class="text-xs sm:text-[13px] font-medium text-ink-900 truncate">
                {w.title}
              </h3>
              <p class="text-[10px] sm:text-[11px] text-ink-500 truncate">
                {w.label}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <p class="reveal mt-10 text-center text-xs text-ink-500">
      Eight recent builds, all shipped in the last 12 months. Ayahs Beauty is our latest flagship.
    </p>
  </div>
</section>

<script>
  // Scale each iframe to fit its card; render mobile previews at mobile width
  const DESKTOP_WIDTH = 1440;
  const MOBILE_WIDTH = 390;
  const IFRAME_HEIGHT = 5000;

  function fitFrame(frame: HTMLElement) {
    const reservoir = frame.querySelector<HTMLElement>(
      "[data-preview-reservoir]"
    );
    const iframe = frame.querySelector<HTMLIFrameElement>("iframe");
    const scroll = frame.querySelector<HTMLElement>("[data-preview-scroll]");
    if (!reservoir || !iframe || !scroll) return;

    const containerWidth = frame.offsetWidth;
    if (containerWidth === 0) return;

    const renderWidth =
      frame.dataset.device === "mobile" ? MOBILE_WIDTH : DESKTOP_WIDTH;
    const scale = containerWidth / renderWidth;

    iframe.style.transform = `scale(${scale})`;
    iframe.style.width = renderWidth + "px";
    iframe.style.height = IFRAME_HEIGHT + "px";
    reservoir.style.height = IFRAME_HEIGHT * scale + "px";
    reservoir.style.width = "100%";

    // Pre-scroll past the hero whitespace so user sees real content
    const startAt = parseFloat(frame.dataset.startAt || "0.22");
    requestAnimationFrame(() => {
      const target = (scroll.scrollHeight - scroll.clientHeight) * startAt;
      scroll.scrollTop = target;
    });
  }

  function fitAll() {
    document
      .querySelectorAll<HTMLElement>("[data-preview-frame]")
      .forEach(fitFrame);
  }

  // Initial fit
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", fitAll);
  } else {
    fitAll();
  }
  // Re-fit when iframes finish loading (so pre-scroll lands on real content)
  document
    .querySelectorAll<HTMLIFrameElement>(
      "[data-preview-frame] iframe"
    )
    .forEach((iframe) => {
      iframe.addEventListener(
        "load",
        () => {
          const frame = iframe.closest<HTMLElement>("[data-preview-frame]");
          if (frame) {
            setTimeout(() => fitFrame(frame), 250);
          }
        },
        { once: true }
      );
    });

  window.addEventListener("load", fitAll);

  if ("ResizeObserver" in window) {
    const ro = new ResizeObserver((entries) => {
      for (const entry of entries) {
        fitFrame(entry.target as HTMLElement);
      }
    });
    document
      .querySelectorAll<HTMLElement>("[data-preview-frame]")
      .forEach((el) => ro.observe(el));
  }

  let resizeTimer: number | undefined;
  window.addEventListener("resize", () => {
    if (resizeTimer) window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(fitAll, 80);
  });

  // Subtle 3D tilt on hover (mouse only, respects reduced motion)
  const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isFinePointer = matchMedia("(hover: hover) and (pointer: fine)").matches;

  if (!prefersReduced && isFinePointer) {
    const MAX_TILT = 5; // degrees
    document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
      let rect: DOMRect | null = null;
      const onEnter = () => {
        rect = card.getBoundingClientRect();
        card.style.transition = "transform 0.15s ease-out";
      };
      const onMove = (e: MouseEvent) => {
        if (!rect) rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        const rx = (-y * MAX_TILT).toFixed(2);
        const ry = (x * MAX_TILT).toFixed(2);
        card.style.transform = `perspective(1200px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;
      };
      const onLeave = () => {
        card.style.transition = "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
        card.style.transform = "";
        rect = null;
      };
      card.addEventListener("mouseenter", onEnter);
      card.addEventListener("mousemove", onMove);
      card.addEventListener("mouseleave", onLeave);
    });
  }
</script>
