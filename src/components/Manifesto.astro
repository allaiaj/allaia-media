---
// Editorial diary entry - magazine-feature treatment with drop cap,
// marginalia, and a centred pull quote. Sits between the hero and
// the coaching waitlist as the moment the personal voice lands.

const paragraphs = [
  "There is a season of building that nobody photographs. It is the part where the spreadsheet doesn't add up and the inbox is silent and the friend from school is launching something better-looking on Instagram and you are sitting at your desk wondering if you should just go get a normal job.",
  "I lived in that season for two years. I am writing this from the other side of it - and I am here to tell you the photograph eventually gets taken. Not because the market shifted or someone discovered you. Because you stayed.",
  "The women I coach are mostly in that season now. Smart, capable, undersold by the version of themselves the internet can see. We work on positioning. We work on voice. We work on saying the thing you've been afraid to say in case it sounded too earnest. We work on the diary entry that turns out to be your best post of the year.",
  "I am building Allaia out loud on purpose. Because the version of me that needed to see what figuring-it-out actually looked like - I want to be that for someone else. The whole reason this page exists is because somewhere there is a twenty-six-year-old reading it on her phone at eleven at night, wondering if she is allowed.",
  "You are. Build it anyway.",
];

const pullQuoteIndex = 2; // pull quote rendered after paragraph 2
const pullQuoteText =
  "The photograph eventually gets taken. Because you stayed.";
---

<section
  id="diary"
  class="relative scroll-mt-24 py-24 sm:py-32 isolate overflow-hidden"
>
  <!-- Backdrop -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-0 h-[55vh] w-[55vh] rounded-full opacity-50 blur-[120px]"
      style="background: radial-gradient(circle, rgba(251,182,206,0.55), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-0 h-[50vh] w-[50vh] rounded-full opacity-50 blur-[120px]"
      style="background: radial-gradient(circle, rgba(167,139,250,0.55), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-5xl px-6">
    <!-- Editorial masthead row -->
    <div class="reveal flex items-baseline justify-between gap-4 mb-10 pb-5 border-b border-ink-900/15">
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-900 font-medium">
        Diary · entry 01
      </p>
      <p class="hidden sm:block text-[10px] uppercase tracking-[0.28em] text-ink-500">
        Essay · 540 words · 3 min read
      </p>
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-500">
        By Allaia
      </p>
    </div>

    <!-- Headline -->
    <header class="reveal mb-12 sm:mb-16">
      <p class="text-[11px] uppercase tracking-[0.24em] text-ink-500 mb-5">
        On the unglamorous middle
      </p>
      <h2
        class="font-medium text-ink-900 max-w-3xl"
        style="font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: -0.03em; line-height: 1.02;"
      >
        <span class="text-ink-900">The season nobody</span>
        <span class="font-serif italic font-normal text-gradient-violet">photographs.</span>
      </h2>
    </header>

    <!-- Two-column body with optional marginalia -->
    <div class="grid lg:grid-cols-[1fr_22rem] gap-12 lg:gap-16">
      <!-- Main body -->
      <article
        class="text-[17px] sm:text-[19px] text-ink-800 leading-[1.7] max-w-2xl"
        style="font-feature-settings: 'ss01';"
      >
        {
          paragraphs.map((p, i) => {
            const isLast = i === paragraphs.length - 1;
            const isFirst = i === 0;
            return (
              <>
                <p
                  class={`reveal mb-7 ${
                    isLast
                      ? "font-serif italic text-2xl sm:text-3xl text-gradient-violet leading-snug"
                      : ""
                  }`}
                >
                  {isFirst ? (
                    <>
                      <span
                        class="float-left font-serif italic mr-3 mt-1 text-gradient-violet"
                        style="font-size: 5.5rem; line-height: 0.82;"
                        aria-hidden="true"
                      >
                        T
                      </span>
                      {p.replace(/^T/, "")}
                    </>
                  ) : (
                    p
                  )}
                </p>

                {i === pullQuoteIndex && (
                  <aside class="reveal lg:hidden my-10 py-6 border-y border-ink-900/15 text-center">
                    <p
                      class="font-serif italic text-gradient-violet leading-tight"
                      style="font-size: clamp(1.5rem, 4vw, 2.25rem);"
                    >
                      "{pullQuoteText}"
                    </p>
                  </aside>
                )}
              </>
            );
          })
        }
      </article>

      <!-- Marginalia / sidebar -->
      <aside class="reveal hidden lg:block relative">
        <div class="sticky top-32 space-y-8">
          <!-- Pull quote -->
          <blockquote class="pl-5 border-l-2 border-accent">
            <p
              class="font-serif italic text-gradient-violet leading-tight"
              style="font-size: clamp(1.5rem, 2.5vw, 2rem);"
            >
              "{pullQuoteText}"
            </p>
            <footer class="mt-4 text-[10px] uppercase tracking-[0.22em] text-ink-500">
              Pull quote · page 02
            </footer>
          </blockquote>

          <!-- Editor's note -->
          <div class="pt-7 border-t border-ink-900/15">
            <p class="text-[10px] uppercase tracking-[0.22em] text-ink-500 mb-2">
              Editor's note
            </p>
            <p class="text-[13px] text-ink-700 leading-relaxed font-serif italic">
              A letter, not a sales page. Read it, then decide if any of it sounds like the next six months of your life.
            </p>
          </div>

          <!-- Pagination chip -->
          <div class="pt-7 border-t border-ink-900/15 flex items-baseline justify-between text-[10px] uppercase tracking-[0.22em] text-ink-500">
            <span>Issue · 026</span>
            <span>Page · 02 / 12</span>
          </div>
        </div>
      </aside>
    </div>

    <!-- Signature -->
    <div class="reveal mt-14 sm:mt-20 pt-8 border-t border-ink-900/15 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5">
      <div>
        <p class="font-serif italic text-3xl sm:text-4xl text-ink-900 leading-none">
          Allaia
        </p>
        <p class="mt-3 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          London · for whoever needs it
        </p>
      </div>
      <a
        href="#coaching"
        class="inline-flex items-center gap-1.5 text-sm text-ink-900 underline decoration-ink-300 underline-offset-4 hover:decoration-ink-900 transition-colors self-start sm:self-auto"
      >
        Read the offer next
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
