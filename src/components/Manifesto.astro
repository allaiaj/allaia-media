---
// Diary-style letter from the founder to women + aspiring founders.
// Sits between the hero/scrub and the coaching waitlist - the moment
// where the personal voice lands before the offer.

const paragraphs = [
  "There is a season of building nobody photographs. It is the part where the spreadsheet doesn't add up and the inbox is silent and the friend from school is launching something better-looking on Instagram and you are sitting at your desk wondering if you should just go get a normal job.",
  "I lived in that season for two years. I'm writing this from the other side of it, and I am here to tell you: the photograph eventually gets taken. Not because the market shifted or someone discovered you. Because you stayed.",
  "The women I coach are mostly in that season. Smart, capable, undersold by the version of themselves the internet can see. We work on positioning, voice, rhythm. We work on saying the thing you've been afraid to say in case it sounds too earnest. We work on the diary entry that turns out to be your best post of the year.",
  "I am building Allaia out loud on purpose. Because the version of me that needed to see what figuring-it-out looked like - I want to be that for someone else. The whole reason this website exists is because somewhere there is a 26-year-old reading it on her phone at 11pm wondering if she's allowed.",
  "You are. Build it anyway.",
];
---

<section
  id="diary"
  class="relative scroll-mt-24 py-28 sm:py-36 isolate overflow-hidden"
>
  <!-- Backdrop -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-0 right-0 h-[60vh] w-[60vh] rounded-full opacity-50 blur-[120px]"
      style="background: radial-gradient(circle, rgba(251,182,206,0.55), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 left-0 h-[55vh] w-[55vh] rounded-full opacity-55 blur-[120px]"
      style="background: radial-gradient(circle, rgba(167,139,250,0.6), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-3xl px-6">
    <!-- Letter meta -->
    <div class="reveal flex items-baseline justify-between mb-12 pb-6 border-b border-ink-900/10">
      <p class="text-[11px] uppercase tracking-[0.24em] text-ink-500">
        Entry no. 01
      </p>
      <p class="text-[11px] uppercase tracking-[0.24em] text-ink-500">
        A letter · personally written
      </p>
    </div>

    <!-- Headline -->
    <h2
      class="reveal display text-4xl sm:text-5xl lg:text-6xl font-medium mb-12"
      style="letter-spacing: -0.025em; line-height: 1.05;"
    >
      <span class="text-ink-900">The season nobody</span><br />
      <span class="font-serif italic text-gradient-violet">photographs.</span>
    </h2>

    <!-- Letter body -->
    <div class="space-y-7 text-[17px] sm:text-[19px] text-ink-800 leading-[1.65]" style="font-feature-settings: 'ss01';">
      {
        paragraphs.map((p, i) => (
          <p class={`reveal ${i === paragraphs.length - 1 ? "font-serif italic text-2xl sm:text-3xl text-gradient-violet leading-snug" : ""}`}>
            {p}
          </p>
        ))
      }
    </div>

    <!-- Signature -->
    <div class="reveal mt-14 pt-8 border-t border-ink-900/10 flex items-end justify-between">
      <div>
        <p class="font-serif italic text-3xl sm:text-4xl text-ink-900 leading-none">
          Allaia
        </p>
        <p class="mt-3 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          Written from London · for whoever needs it
        </p>
      </div>
      <a
        href="#coaching"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm text-ink-900 underline decoration-ink-300 underline-offset-4 hover:decoration-ink-900 transition-colors"
      >
        Read the offer
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 11L11 3M11 3H4M11 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
