---
import { services } from "../data/site";
---

<section id="services" class="relative scroll-mt-24 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="reveal flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
      <div>
        <p class="mb-4 text-[11px] uppercase tracking-[0.22em] text-ink-500">
          What we build · 05
        </p>
        <h2 class="display max-w-2xl text-5xl sm:text-6xl lg:text-7xl font-medium">
          <span class="text-gradient-ink">Five engines.</span><br />
          <span class="font-serif italic text-gradient-violet">Stack what you need.</span>
        </h2>
      </div>
      <p class="md:max-w-sm text-base text-ink-600 leading-relaxed">
        Start with one. Add the next when the numbers say so. We never sell you something your business cannot absorb yet.
      </p>
    </div>

    <!-- Bento grid: 5 cards arranged 4+2 / 2+4 / 6 on md+ for asymmetric rhythm -->
    <div class="grid gap-4 sm:gap-5 md:grid-cols-6">
      {
        services.map((s, i) => {
          // 0: web (wide), 1: GBP (narrow), 2: meta ads (narrow), 3: social (wide), 4: coaching (full-width finale)
          const spanClass =
            i === 0
              ? "md:col-span-4"
              : i === 1
              ? "md:col-span-2"
              : i === 2
              ? "md:col-span-2"
              : i === 3
              ? "md:col-span-4"
              : "md:col-span-6";
          return (
          <article
            data-tilt
            data-tilt-max="4"
            data-tilt-lift="3"
            class={`reveal group relative overflow-hidden rounded-3xl surface p-7 sm:p-9 transition-all duration-500 ${spanClass}`}
          >
            {/* hover glow */}
            <div
              class="pointer-events-none absolute -inset-px rounded-3xl opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              style="background: radial-gradient(600px circle at var(--mx, 50%) var(--my, 0%), rgba(167,139,250,0.18), transparent 40%);"
            />

            <div class="relative flex flex-col h-full min-h-[280px] sm:min-h-[320px]">
              <div class="flex items-start justify-between gap-4">
                <span class="font-mono text-xs text-ink-500 tracking-wider">{s.n}</span>
                <span class="rounded-full bg-ink-900/5 px-3 py-1 text-[11px] text-ink-700">
                  {s.price}
                </span>
              </div>

              <div class="mt-10 sm:mt-14 flex-1">
                <h3 class="text-2xl sm:text-3xl font-medium tracking-tight text-ink-900">
                  {s.title}
                </h3>
                <p class="mt-2 font-serif italic text-lg sm:text-xl text-ink-500">
                  {s.sub}
                </p>
                <p class="mt-5 text-sm sm:text-[15px] text-ink-700 leading-relaxed max-w-md">
                  {s.body}
                </p>
              </div>

              <div class="mt-6 pt-5 border-t border-ink-900/8 flex flex-wrap gap-x-5 gap-y-2">
                {s.deliverables.map((d) => (
                  <span class="inline-flex items-center gap-1.5 text-xs text-ink-600">
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                      <circle cx="5" cy="5" r="2" fill="currentColor" style="color: var(--color-accent);" />
                    </svg>
                    {d}
                  </span>
                ))}
              </div>
            </div>
          </article>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>("#services article");
  cards.forEach((card) => {
    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      card.style.setProperty("--mx", `${x}%`);
      card.style.setProperty("--my", `${y}%`);
    });
  });
</script>
