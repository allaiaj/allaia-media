---
// Editorial timeline - a short biography in five chapters.
// Replaces the previous 500vh sticky-pin section which left a long
// stretch of empty scroll. This reads as a magazine feature instead:
// vertical chapter list with marginalia + a pull quote in the middle.

const chapters = [
  {
    n: "I",
    year: "2022",
    label: "Year one · the studio begins",
    headline: "Built the studio from a borrowed desk.",
    body: "A laptop. A Notion doc. The first founder who said yes. There were no investor decks, no team photo, no playbook - only the work and the next call.",
  },
  {
    n: "II",
    year: "2023",
    label: "Year two · the volume year",
    headline: "Shipped five hundred founder-led brands.",
    body: "Clinics in West London. Florists in Romford. Pizzerias in Ilford. The unsexy work that compounded - websites that converted, listings that ranked, ads that actually paid for themselves.",
  },
  {
    n: "III",
    year: "2024",
    label: "Year three · the pivot to coaching",
    headline: "Started coaching the founders, not just the brands.",
    body: "The pattern was hard to miss - the women I built sites for were the bottleneck themselves. So I began coaching personal brand: positioning, voice, the on-camera reps. The 1:1 work I now run by application.",
  },
  {
    n: "IV",
    year: "2025",
    label: "Year four · the partnerships",
    headline: "Said yes to the right brands, no to the rest.",
    body: "Hotels in places I'd actually return to. Fashion labels I already wore. Lifestyle goods I used on slow mornings before the camera was on. Editorial collaborations, never gifted-content theatre.",
  },
  {
    n: "V",
    year: "2026",
    label: "Year five · what's next",
    headline: "Building it - out loud, on purpose, on the record.",
    body: "Coaching opens monthly. Brand inquiries reviewed weekly. The studio side runs at Blacklyne. The diary keeps going, because someone, somewhere, is reading this on her phone at 11pm wondering if she's allowed.",
  },
];
---

<section
  id="timeline"
  class="relative isolate overflow-hidden py-24 sm:py-32"
>
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-1/4 -right-32 h-[55vh] w-[55vh] rounded-full opacity-50 blur-[120px]"
      style="background: radial-gradient(circle, rgba(167,139,250,0.55), transparent 70%);"
    ></div>
    <div
      class="absolute bottom-0 -left-32 h-[50vh] w-[50vh] rounded-full opacity-50 blur-[120px]"
      style="background: radial-gradient(circle, rgba(251,182,206,0.55), transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-5xl px-6">
    <!-- Masthead row -->
    <div class="reveal flex items-baseline justify-between mb-10 pb-6 border-b border-ink-900/15">
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-500">
        Feature · 026
      </p>
      <p class="text-[11px] uppercase tracking-[0.28em] text-ink-500">
        Biography · in five chapters
      </p>
    </div>

    <!-- Section heading -->
    <h2
      class="reveal display max-w-3xl mb-16 sm:mb-20"
      style="font-size: clamp(2.5rem, 6.5vw, 5.5rem); letter-spacing: -0.03em; line-height: 1.02;"
    >
      <span class="text-ink-900">A short biography of</span>
      <span class="font-serif italic font-normal text-gradient-violet">a woman who didn't wait.</span>
    </h2>

    <!-- Chapter list -->
    <ol class="relative space-y-16 sm:space-y-20">
      <!-- Vertical rule -->
      <span
        class="pointer-events-none absolute left-[1.75rem] top-2 bottom-2 w-px hidden md:block"
        style="background: linear-gradient(180deg, transparent, var(--color-accent-bright) 8%, var(--color-accent) 50%, var(--color-accent-deep) 92%, transparent);"
        aria-hidden="true"
      ></span>

      {
        chapters.map((c, i) => (
          <li class="reveal relative grid md:grid-cols-[3.5rem_1fr] gap-6 md:gap-10">
            <!-- Roman numeral -->
            <div class="relative">
              <span
                class="font-serif italic text-4xl sm:text-5xl text-gradient-violet leading-none block"
                aria-hidden="true"
              >
                {c.n}
              </span>
              <p class="hidden md:block mt-3 text-[10px] uppercase tracking-[0.18em] text-ink-500">
                Ch. {String(i + 1).padStart(2, "0")}
              </p>
            </div>

            <!-- Chapter body -->
            <article>
              <div class="flex items-baseline gap-3 mb-3">
                <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-900">
                  {c.year}
                </span>
                <span class="h-px flex-1 bg-ink-900/15" aria-hidden="true"></span>
                <span class="text-[10px] uppercase tracking-[0.18em] text-ink-500">
                  {c.label}
                </span>
              </div>

              <h3
                class="font-medium text-ink-900 mb-4"
                style="font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; line-height: 1.15;"
              >
                {c.headline}
              </h3>

              <p class="text-[16px] sm:text-[17px] text-ink-700 leading-[1.7] max-w-2xl">
                {c.body}
              </p>
            </article>
          </li>
        ))
      }
    </ol>

    <!-- Pull quote / closer -->
    <div class="reveal mt-20 sm:mt-28 max-w-3xl mx-auto text-center">
      <p
        class="font-serif italic text-gradient-violet leading-tight"
        style="font-size: clamp(1.75rem, 4vw, 2.75rem);"
      >
        "Five chapters in, the only thing I know for sure is that you keep the next page open."
      </p>
      <p class="mt-5 text-[11px] uppercase tracking-[0.28em] text-ink-500">
        — From the diary
      </p>
    </div>
  </div>
</section>
